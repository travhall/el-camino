---
// /src/components/RecentlyViewed.astro
// "Trading card" — structured panels with branded header strips. Horizontal scroll.
interface Props {
  title?: string;
  currentProductId?: string;
}

const { title = "Recently Viewed", currentProductId } = Astro.props;
---

<section
  class="recently-viewed"
  id="recently-viewed-section"
  style="display: none;"
  data-current-product-id={currentProductId}
>
  <!-- Heading with extending rule line -->
  <div class="flex items-center gap-4 mb-6">
    <h2
      class="text-sm font-bold uppercase tracking-widest text-(--content-heading) shrink-0"
    >
      {title}
    </h2>
    <div class="h-px flex-1 bg-(--border-primary)"></div>
  </div>

  <!-- Horizontal scroll — bleeds to parent edges -->
  <div
    id="recently-viewed-container"
    class="-mx-4 sm:-mx-6 lg:-mx-8 flex gap-1 overflow-x-auto pb-4 scrollbar-hide px-4 sm:px-6 lg:px-8"
    role="region"
    aria-label="Recently viewed products"
  >
    <!-- Trading cards inserted by JavaScript -->
  </div>
</section>

<script>
  import { recentlyViewed } from "@/lib/product/recentlyViewed";
  import { MoneyUtils } from "@/lib/square/money";

  // Route any external image URL through Netlify Image CDN for compression,
  // format negotiation (AVIF/WebP), and edge caching — covers squarecdn.com,
  // s3.amazonaws.com, and any other Square storage backend.
  function optimizeProductImage(src: string): string {
    if (!src || src.startsWith("/") || src.startsWith("data:")) return src;
    const p = new URLSearchParams({ url: src, w: "400", h: "400", fit: "cover", q: "80" });
    return `/.netlify/images?${p.toString()}`;
  }

  async function renderRecentlyViewed() {
    const section = document.getElementById("recently-viewed-section");
    const container = document.getElementById("recently-viewed-container");

    if (!section || !container) return;

    const currentProductId = section.getAttribute("data-current-product-id");
    const items = recentlyViewed
      .get(8)
      .filter((item) => item.id !== currentProductId);

    if (items.length === 0) {
      section.style.display = "none";
      return;
    }

    // Populate content while still display:none, then reveal in one paint.
    // This prevents CLS — the section goes from 0px to full height in a single
    // frame after content is ready, rather than expanding from empty to populated.
    const [inventoryMap, saleInfoMap] = await Promise.all([
      fetchInventoryForItems(items),
      fetchSaleInfoForItems(items),
    ]);

    container.innerHTML = items
      .map((item) => {
        const saleInfo = saleInfoMap[item.variationId];
        const isOnSale = !!saleInfo;
        const displayPrice = saleInfo?.salePrice ?? item.price;
        const formattedPrice = MoneyUtils.format(
          MoneyUtils.fromFloat(displayPrice),
        );
        const formattedOriginal = saleInfo
          ? MoneyUtils.format(MoneyUtils.fromFloat(saleInfo.originalPrice))
          : null;
        const isOutOfStock = !inventoryMap[item.variationId];
        const optimizedImage = optimizeProductImage(item.image);
        const brand = item.brand ?? "El Camino";
        const priceClass =
          isOnSale && !isOutOfStock
            ? "text-(--color-elco-sweet-tea-500) font-black text-base"
            : "text-(--product-price) font-black text-base";

        return `
          <a
            href="${item.url}"
            class="group flex-none w-56 relative rounded-xs overflow-hidden border border-(--border-primary) hover:border-(--color-elco-sweet-tea-300) transition-colors duration-200 shrink-0 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--content-link)"
            aria-label="${item.title} — ${formattedPrice}${isOutOfStock ? " — Sold Out" : ""}${isOnSale ? " — On Sale" : ""}"
          >
            <!-- Colored brand header strip -->
            <div class="bg-(--color-elco-sweet-tea-300) px-3 py-2 flex items-center justify-between gap-2 min-h-[2rem]" aria-hidden="true">
              <span class="text-xs font-black uppercase tracking-widest text-(--color-elco-sweet-tea-900) truncate leading-none">
                ${brand}
              </span>
              ${
                isOnSale
                  ? `
              <span class="text-xs font-black uppercase tracking-wide bg-state-success-surface text-state-success-text px-1.5 py-0.5 rounded-xs leading-none shrink-0">
                Sale
              </span>`
                  : ""
              }
            </div>

            <!-- Product image — square -->
            <div class="relative aspect-square overflow-hidden bg-(--surface-secondary)${isOutOfStock ? " opacity-70" : ""}" aria-hidden="true">
              <img
                src="${optimizedImage}"
                alt=""
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105${isOutOfStock ? " grayscale-[30%]" : ""}"
                loading="lazy"
                width="200"
                height="200"
              />
              ${
                isOutOfStock
                  ? `
              <div class="absolute inset-0 flex items-end justify-start p-2">
                <span class="text-xs font-black uppercase tracking-widest bg-state-error-surface text-state-error-text px-2 py-1 rounded-xs leading-none">
                  Sold Out
                </span>
              </div>`
                  : ""
              }
            </div>

            <!-- Info panel — structured, not overlay -->
            <div class="h-full bg-(--surface-secondary) p-3">
              <p class="text-sm font-semibold text-(--content-heading) line-clamp-2 leading-snug min-h-[2.5rem]">
                ${item.title}
              </p>
              <div class="flex items-baseline gap-2 mt-2" aria-hidden="true">
                ${
                  formattedOriginal
                    ? `
                <del class="text-xs text-(--content-meta)">
                  ${formattedOriginal}
                </del>`
                    : ""
                }
                <span class="${priceClass}">
                  ${formattedPrice}
                </span>
              </div>
            </div>
          </a>
        `;
      })
      .join("");

    // Reveal after content is fully populated — single paint, no shift
    section.classList.add("pt-10", "lg:pt-12");
    section.style.display = "block";
  }

  async function fetchInventoryForItems(
    items: any[],
  ): Promise<Record<string, boolean>> {
    // Gift cards have no inventory tracking in Square — always in stock
    const giftCardIds = items
      .filter((item) => item.isGiftCard)
      .map((item) => item.variationId);
    const trackableItems = items.filter((item) => !item.isGiftCard);

    const inventoryMap: Record<string, boolean> = {};
    for (const id of giftCardIds) {
      inventoryMap[id] = true;
    }

    if (trackableItems.length === 0) return inventoryMap;

    try {
      const variationIds = trackableItems.map((item) => item.variationId);
      const response = await fetch("/api/cart-inventory", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ variationIds }),
      });
      if (!response.ok) {
        for (const id of variationIds) inventoryMap[id] = true;
        return inventoryMap;
      }
      const data = await response.json();
      if (!data.success || !data.inventory) {
        for (const id of variationIds) inventoryMap[id] = true;
        return inventoryMap;
      }
      for (const id of variationIds) {
        inventoryMap[id] = (data.inventory[id] || 0) > 0;
      }
      return inventoryMap;
    } catch {
      for (const item of trackableItems) inventoryMap[item.variationId] = true;
      return inventoryMap;
    }
  }

  async function fetchSaleInfoForItems(
    items: any[],
  ): Promise<Record<string, any>> {
    try {
      const variationIds = items.map((item) => item.variationId);
      const response = await fetch("/api/sale-info", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ variationIds }),
      });
      if (!response.ok) return {};
      const data = await response.json();
      if (!data.success || !data.saleInfo) return {};
      return data.saleInfo;
    } catch {
      return {};
    }
  }

  function initRecentlyViewed() {
    const section = document.getElementById("recently-viewed-section");
    if (section) {
      const variationData = document.getElementById(
        "variation-data",
      ) as HTMLInputElement;
      if (variationData?.value) {
        try {
          const data = JSON.parse(variationData.value);
          section.setAttribute("data-current-product-id", data.productId);
        } catch {
          // ignore
        }
      }
      renderRecentlyViewed();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initRecentlyViewed);
  } else {
    initRecentlyViewed();
  }

  document.addEventListener("astro:page-load", initRecentlyViewed);
</script>
