---
// src/components/BackInStock.astro
// Shown when a product/variant is sold out. Captures customer email and stores
// the subscription in Netlify Blobs. Tyler triggers notification emails from
// the admin Back in Stock page when the product is restocked.

interface Props {
  productId: string;
  variationId: string;
  productTitle: string;
  variationName?: string;
  hidden?: boolean;
}

const {
  productId,
  variationId,
  productTitle,
  variationName,
  hidden = false,
} = Astro.props;

import { getContactInfo } from "@/lib/contactInfo";
const contact = await getContactInfo();
const productUrl = Astro.url.href;
const label = variationName
  ? `${productTitle} — ${variationName}`
  : productTitle;
---

<div
  id="back-in-stock-section"
  data-product-title={productTitle}
  class:list={[
    "mt-6 p-4 border-2 border-(--border-secondary) rounded-sm bg-(--surface-secondary)",
    hidden && "hidden",
  ]}
>
  <p class="text-base font-bold text-(--content-heading) mb-1">
    Get notified when it's back
  </p>
  <p class="text-sm text-(--content-body) mb-4">
    Enter your email and we'll reach out when <span
      id="bis-label-product"
      class="font-medium">{label}</span
    > is back in stock.
  </p>

  <form
    id="back-in-stock-form"
    name="back-in-stock"
    method="POST"
    action="/api/back-in-stock"
    class="flex flex-col sm:flex-row gap-2"
    novalidate
  >
    <input type="hidden" name="product_id" value={productId} />
    <input type="hidden" name="product_url" value={productUrl} />
    <input
      type="hidden"
      id="bis-variation-id"
      name="variation_id"
      value={variationId}
    />
    <input
      type="hidden"
      id="bis-product-title"
      name="product_title"
      value={label}
    />

    <input
      type="email"
      name="email"
      id="bis-email"
      placeholder="your@email.com"
      required
      autocomplete="email"
      class="flex-1 h-10 px-3 text-sm border border-(--ui-input-border)/50 rounded-sm bg-(--ui-input-surface) text-(--ui-input-text) placeholder:text-(--content-meta)/50 focus:outline-none focus:ring-2 focus:ring-(--ui-button-ring) transition"
    />
    <button
      type="submit"
      id="bis-submit"
      class="h-10 px-4 text-sm font-semibold rounded-sm bg-(--ui-button-surface) text-(--ui-button-text) border-2 border-(--ui-button-border) hover:opacity-80 transition whitespace-nowrap cursor-pointer"
    >
      Notify Me
    </button>
  </form>

  <p
    id="bis-success"
    class="hidden mt-3 text-sm text-state-success-surface font-semibold"
  >
    ✓ You're on the list! We'll email you when it's available.
  </p>
  <p id="bis-error" class="hidden mt-3 text-sm text-state-error-surface">
    Something went wrong — please try again or <a
      href="mailto:{contact.email}"
      class="underline hover:no-underline">email us directly</a
    >.
  </p>
</div>

<script>
  function initBackInStock() {
    const form = document.getElementById(
      "back-in-stock-form",
    ) as HTMLFormElement | null;
    if (!form || form.dataset.initialized) return;
    form.dataset.initialized = "true";

    const submitBtn = document.getElementById(
      "bis-submit",
    ) as HTMLButtonElement;
    const successMsg = document.getElementById("bis-success");
    const errorMsg = document.getElementById("bis-error");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = (
        document.getElementById("bis-email") as HTMLInputElement
      )?.value?.trim();
      if (!email) return;

      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      try {
        const body = new FormData(form);
        const res = await fetch("/api/back-in-stock", {
          method: "POST",
          body,
        });

        if (res.ok) {
          form.classList.add("hidden");
          successMsg?.classList.remove("hidden");
          errorMsg?.classList.add("hidden");
        } else {
          throw new Error("Non-OK response");
        }
      } catch {
        errorMsg?.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = "Notify Me";
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBackInStock);
  } else {
    initBackInStock();
  }
  document.addEventListener("astro:page-load", initBackInStock);
</script>
