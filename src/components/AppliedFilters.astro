---
// src/components/AppliedFilters.astro

export interface Props {
  classes?: string;
}

const { classes } = Astro.props;

// Parse current filters from URL
const currentParams = new URLSearchParams(Astro.url.search);
const currentBrands = currentParams.getAll("brands") || [];
const currentAvailability = currentParams.get("availability") === "true";

// Only show content if there are active filters
const hasActiveFilters = currentBrands.length > 0 || currentAvailability;
---

<style>
  .applied-filters-container {
    margin-bottom: 0.5rem;
    opacity: 1;
    transition: opacity 300ms ease;
  }

  .applied-filters-container.no-filters {
    opacity: 0;
    pointer-events: none;
  }
</style>

<div
  id="applied-filters-container"
  class:list={[
    "applied-filters-container px-2",
    classes,
    !hasActiveFilters ? "no-filters" : "",
  ]}
>
  <div class="flex flex-wrap items-center gap-3 my-2">
    {
      hasActiveFilters && (
        <>
          <div class="flex flex-wrap gap-2">
            {currentBrands.map((brand) => (
              <button
                type="button"
                data-remove-brand={brand}
                class="inline-flex items-center px-2.5 py-1.5 text-sm border rounded-full bg-(--surface-primary) hover:bg-(--surface-tertiary) transition-colors text-(--ui-input-text) border-(--ui-input-border)/50 group"
                title={`Remove ${brand} filter`}
              >
                <span>{brand}</span>
                <svg
                  class="w-3 h-3 ml-1 text-(--content-meta) group-hover:text-(--content-body)"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"
                  />
                </svg>
              </button>
            ))}
            {currentAvailability && (
              <button
                type="button"
                data-remove-availability
                class="inline-flex items-center px-2.5 py-1.5 text-sm border rounded-full bg-(--surface-primary) hover:bg-(--surface-tertiary) transition-colors text-(--ui-input-text) border-(--ui-input-border)/50 group"
                title="Remove availability filter"
              >
                <span>In stock only</span>
                <svg
                  class="w-3 h-3 ml-1 text-(--state-success-text)/70 group-hover:text-(--state-success-text)"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"
                  />
                </svg>
              </button>
            )}
          </div>
          <button
            type="button"
            data-clear-all-filters
            class="text-sm text-(--content-meta) hover:text-(--content-emphasis) transition-colors text-nowrap"
          >
            Clear All
          </button>
        </>
      )
    }
  </div>
</div>

<script>
  // ENHANCED: Client-side filter badge removal with no navigation
  document.addEventListener("astro:page-load", () => {
    setupFilterHandlers();
  });

  function setupFilterHandlers() {
    // Individual brand removal
    document.querySelectorAll("[data-remove-brand]").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        const target = e.currentTarget as HTMLElement;
        const brand = target?.dataset.removeBrand;
        if (brand) await removeFilter("brand", brand);
      });
    });

    // Availability removal
    document
      .querySelector("[data-remove-availability]")
      ?.addEventListener("click", async () => {
        await removeFilter("availability");
      });

    // Clear All - use existing global system
    document
      .querySelector("[data-clear-all-filters]")
      ?.addEventListener("click", () => {
        const globalClearAll = (window as any).globalClearAllFilters;
        if (globalClearAll) {
          globalClearAll();
        } else {
          // Fallback: Try client-side clear
          clearAllFiltersClientSide();
        }
      });
  }

  async function removeFilter(type: string, value: string | null = null) {
    // Try client-side filtering first (desktop)
    const filterForm = document.getElementById("filter-form") as HTMLFormElement;
    const urlParams = new URLSearchParams(window.location.search);
    const forceDesktop = urlParams.get("test-desktop") === "true";
    const isMobile = !forceDesktop && window.innerWidth < 1024;

    if (!isMobile && filterForm) {
      // DESKTOP: Use client-side filtering
      const currentParams = new URLSearchParams(window.location.search);
      const currentBrands = currentParams.getAll("brands") || [];
      const currentAvailability = currentParams.get("availability") === "true";

      // Update form checkboxes to reflect the removal
      if (type === "brand" && value) {
        const checkbox = filterForm.querySelector(
          `input[name="brands"][value="${value}"]`
        ) as HTMLInputElement;
        if (checkbox) {
          checkbox.checked = false;
        }
      } else if (type === "availability") {
        const checkbox = filterForm.querySelector(
          'input[name="availability"]'
        ) as HTMLInputElement;
        if (checkbox) {
          checkbox.checked = false;
        }
      }

      // Build new filter state
      const newBrands =
        type === "brand" && value
          ? currentBrands.filter((b) => b !== value)
          : currentBrands;
      const newAvailability =
        type === "availability" ? false : currentAvailability;

      // Get filter engine and apply
      try {
        const { getFilterEngine } = await import(
          "@/lib/square/clientFilterEngine"
        );
        const grid = document.getElementById("filterable-product-grid");
        const categoryPath = grid?.dataset.categoryPath;
        const categoryId = categoryPath ? categoryPath.split("/").pop() : undefined;
        const engine = getFilterEngine(categoryId);

        // Ensure metadata is loaded
        await engine.loadMetadata();

        // Apply filter
        const filters = {
          brands: newBrands,
          availability: newAvailability,
        };

        const filteredIds = engine.getFilteredProductIds(filters);
        const totalCount = engine.getTotalCount();

        console.log(
          `[AppliedFilters] ⚡ Removed filter - ${totalCount} → ${filteredIds.length} products`
        );

        // Update URL without navigation
        updateURLWithoutNavigation(filters);

        // Apply filter to grid
        applyClientSideFilter(filteredIds);

        // Update result count
        updateResultCount(filteredIds.length, totalCount);

        // Update applied filters display
        updateAppliedFiltersDisplay(filters);
      } catch (error) {
        console.warn(
          "[AppliedFilters] ⚠️ Client-side filtering failed, falling back to navigation:",
          error
        );
        navigateToFilters(type, value);
      }
    } else {
      // MOBILE or no filter form: Use server-side navigation
      navigateToFilters(type, value);
    }
  }

  function navigateToFilters(type: string, value: string | null = null) {
    const currentParams = new URLSearchParams(window.location.search);
    const currentBrands = currentParams.getAll("brands") || [];
    const currentAvailability = currentParams.get("availability") === "true";

    const params = new URLSearchParams();

    if (type === "brand" && value) {
      const otherBrands = currentBrands.filter((b) => b !== value);
      otherBrands.forEach((brand) => params.append("brands", brand));
      if (currentAvailability) params.set("availability", "true");
    } else if (type === "availability") {
      currentBrands.forEach((brand) => params.append("brands", brand));
    }

    const queryString = params.toString();
    const url = `${window.location.pathname}${queryString ? "?" + queryString : ""}`;
    window.location.href = url;
  }

  function updateURLWithoutNavigation(filters: {
    brands: string[];
    availability: boolean;
  }): void {
    const params = new URLSearchParams();

    filters.brands.forEach((brand) => params.append("brands", brand));
    if (filters.availability) {
      params.set("availability", "true");
    }

    const queryString = params.toString();
    const newURL = `${window.location.pathname}${queryString ? "?" + queryString : ""}`;

    window.history.pushState({}, "", newURL);
  }

  function applyClientSideFilter(filteredIds: string[]): void {
    const grid = document.getElementById("filterable-product-grid");
    if (!grid) return;

    const allCards = grid.querySelectorAll(".product-card-wrapper");
    const filteredIdSet = new Set(filteredIds);

    allCards.forEach((card) => {
      const htmlCard = card as HTMLElement;
      const productId = htmlCard.dataset.productId;
      const shouldShow = productId && filteredIdSet.has(productId);

      if (shouldShow) {
        htmlCard.style.display = "";
        htmlCard.classList.remove("opacity-0");
        htmlCard.classList.add("opacity-100");
      } else {
        htmlCard.classList.remove("opacity-100");
        htmlCard.classList.add("opacity-0");

        setTimeout(() => {
          if (htmlCard.classList.contains("opacity-0")) {
            htmlCard.style.display = "none";
          }
        }, 300);
      }
    });

    // Show "no results" if needed
    const noResults = document.getElementById("no-results");
    if (noResults) {
      if (filteredIds.length === 0) {
        noResults.style.display = "flex";
      } else {
        noResults.style.display = "none";
      }
    }
  }

  function updateResultCount(filtered: number, total: number): void {
    const resultCountElements = document.querySelectorAll(
      "[data-result-count]"
    );

    resultCountElements.forEach((el) => {
      if (filtered === total) {
        el.textContent = `${total} products`;
      } else {
        el.textContent = `${filtered} of ${total} products`;
      }
    });

    // Update screen reader live region
    const liveRegion = document.getElementById("filter-results-live-region");
    if (liveRegion) {
      const message =
        filtered === total
          ? `Showing all ${total} products`
          : `Filtered to ${filtered} of ${total} products`;

      setTimeout(() => {
        liveRegion.textContent = message;
      }, 100);
    }
  }

  function updateAppliedFiltersDisplay(filters: {
    brands: string[];
    availability: boolean;
  }): void {
    const container = document.getElementById("applied-filters-container");
    if (!container) return;

    const hasFilters = filters.brands.length > 0 || filters.availability;

    if (!hasFilters) {
      // Fade out and hide
      container.classList.add("no-filters");
    } else {
      container.classList.remove("no-filters");
    }
  }

  async function clearAllFiltersClientSide(): Promise<void> {
    const filterForm = document.getElementById("filter-form") as HTMLFormElement;
    if (!filterForm) {
      window.location.href = window.location.pathname;
      return;
    }

    // Uncheck all checkboxes
    const checkboxes = filterForm.querySelectorAll(
      'input[type="checkbox"]'
    ) as NodeListOf<HTMLInputElement>;
    checkboxes.forEach((cb) => {
      cb.checked = false;
    });

    try {
      const { getFilterEngine } = await import("@/lib/square/clientFilterEngine");
      const grid = document.getElementById("filterable-product-grid");
      const categoryPath = grid?.dataset.categoryPath;
      const categoryId = categoryPath ? categoryPath.split("/").pop() : undefined;
      const engine = getFilterEngine(categoryId);

      await engine.loadMetadata();
      const totalCount = engine.getTotalCount();
      const allIds = engine.getFilteredProductIds({ brands: [], availability: false });

      console.log(`[AppliedFilters] 🧹 Cleared all filters - showing ${totalCount} products`);

      updateURLWithoutNavigation({ brands: [], availability: false });
      applyClientSideFilter(allIds);
      updateResultCount(totalCount, totalCount);
      updateAppliedFiltersDisplay({ brands: [], availability: false });
    } catch (error) {
      console.warn("[AppliedFilters] ⚠️ Clear all failed, falling back to navigation");
      window.location.href = window.location.pathname;
    }
  }
</script>
