---
import { Icon } from 'astro-icon/components';

// src/components/wordpress/blocks/WPEmbed.astro
// Custom embed component for wp-block-embed

interface Props {
  url: string;
  embedType: 'youtube' | 'vimeo' | 'twitter' | 'instagram' | 'generic';
  originalHtml: string;
}

const { url, embedType, originalHtml } = Astro.props;

// Extract video ID for YouTube/Vimeo
function getVideoId(url: string, type: string): string | null {
  if (type === 'youtube') {
    // Handle multiple YouTube URL formats
    const patterns = [
      /(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\n?#]+)/,
      /youtube\.com\/embed\/([^&\n?#]+)/,
      /youtube\.com\/v\/([^&\n?#]+)/
    ];

    for (const pattern of patterns) {
      const match = url.match(pattern);
      if (match) return match[1];
    }
  }

  if (type === 'vimeo') {
    const match = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
    return match?.[1] || null;
  }

  return null;
}

const videoId = getVideoId(url, embedType);
---

<div class="wp-embed my-8">
  {embedType === 'youtube' && videoId ? (
    <div
      class="youtube-facade aspect-video bg-(--surface-secondary) rounded-lg overflow-hidden relative group"
      data-videoid={videoId}
    >
      <img
        src={`https://img.youtube.com/vi/${videoId}/hqdefault.jpg`}
        alt="YouTube video thumbnail"
        class="w-full h-full object-cover"
        width="480"
        height="360"
        decoding="async"
        loading="lazy"
      />
      <button
        class="youtube-play-btn absolute inset-0 w-full h-full flex items-center justify-center bg-transparent border-0 cursor-pointer"
        data-videoid={videoId}
        aria-label="Play YouTube video"
      >
        <span
          class="w-16 h-16 rounded-full bg-black/70 flex items-center justify-center group-hover:bg-[#FF0000] transition-colors duration-200 pointer-events-none"
          aria-hidden="true"
        >
          <svg class="w-8 h-8 text-white ml-1" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
      </button>
    </div>
  ) : embedType === 'vimeo' && videoId ? (
    <div class="aspect-video bg-(--surface-secondary) rounded-lg overflow-hidden">
      <iframe
        src={`https://player.vimeo.com/video/${videoId}`}
        title="Vimeo video player"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        class="w-full h-full vimeo-embed"
        loading="lazy"
      />
    </div>
  ) : embedType === 'twitter' ? (
    <div class="max-w-lg mx-auto">
      <!-- Twitter embeds require their script, so we'll show a link -->
      <div class="border border-(--border-secondary) rounded-lg p-4 bg-(--surface-secondary)">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-6 h-6 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
          <span class="font-semibold text-(--content-heading)">Twitter Post</span>
        </div>
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-(--ui-accent) hover:underline"
        >
          View on Twitter <Icon
                class="h-4 w-4 text-(--content-emphasis)"
                name="uil:arrow-right"
              />
        </a>
      </div>
    </div>
  ) : embedType === 'instagram' ? (
    <div class="max-w-lg mx-auto">
      <div class="border border-(--border-secondary) rounded-lg p-4 bg-(--surface-secondary)">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-6 h-6 text-pink-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987 6.62 0 11.987-5.367 11.987-11.987C24.014 5.367 18.637.001 12.017.001zM8.23 18.148c-2.016 0-3.651-1.635-3.651-3.651V9.505c0-2.016 1.635-3.651 3.651-3.651h7.54c2.016 0 3.651 1.635 3.651 3.651v4.992c0 2.016-1.635 3.651-3.651 3.651H8.23z"/>
          </svg>
          <span class="font-semibold text-(--content-heading)">Instagram Post</span>
        </div>
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-(--ui-accent) hover:underline"
        >
          View on Instagram <Icon
                class="h-4 w-4 text-(--content-emphasis)"
                name="uil:arrow-right"
              />
        </a>
      </div>
    </div>
  ) : (
      <div class="embed-fallback" set:html={originalHtml} />
    )}
  </div>

<script>
  // YouTube facade: replace thumbnail+button with live iframe on click.
  // Uses youtube-nocookie.com to avoid SameSite cookie issues.
  // Event delegation handles multiple embeds per page with a single listener.
  document.addEventListener('click', (e: MouseEvent) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.youtube-play-btn');
    if (!btn) return;

    const videoId = btn.dataset.videoid;
    const container = btn.closest<HTMLElement>('.youtube-facade');
    if (!videoId || !container) return;

    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
    iframe.title = 'YouTube video player';
    iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
    iframe.setAttribute('allowfullscreen', '');
    iframe.className = 'absolute inset-0 w-full h-full';
    iframe.style.border = 'none';

    // Swap facade for live player
    container.innerHTML = '';
    container.appendChild(iframe);
    iframe.focus();
  }, { passive: true });
</script>

<style>
  .vimeo-embed {
    border: none;
  }
</style>
