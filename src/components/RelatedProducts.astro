---
// /src/components/RelatedProducts.astro
// Editorial horizontal scroll filmstrip — wider breathing room, stronger hierarchy.
import type { Product } from "@/lib/square/types";
import { MoneyUtils } from "@/lib/square/money";
import { batchInventoryService } from "@/lib/square/batchInventory";
import { toNetlifyImageCDN } from "@/lib/image/enhanced-optimizer";

interface Props {
  products: Product[];
  title?: string;
}

const { products, title = "Complete Your Setup" } = Astro.props;

if (products.length === 0) {
  return null;
}

// Cap at 5 — quality over quantity
const displayProducts = products.slice(0, 5);

// Derive brand for "See All" link from first product
const brand = displayProducts[0]?.brand;
const seeAllUrl = brand
  ? `/shop/all?brands=${encodeURIComponent(brand)}`
  : "/shop/all";

const variationIds = displayProducts.map((p) => p.variationId).filter(Boolean);
const inventoryMap =
  await batchInventoryService.getBatchInventoryStatus(variationIds);

---

<section class="related-products py-12 lg:py-16">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6 lg:mb-8">
    <div>
      <p class="text-xs uppercase tracking-widest text-(--content-meta) mb-1.5">
        From the Catalog
      </p>
      <h2
        class="text-2xl lg:text-3xl font-display font-bold text-(--content-heading) leading-none"
      >
        {title}
      </h2>
    </div>
    {
      products.length > 4 && (
        <a
          href={seeAllUrl}
          class="px-2.5 py-1.5 text-sm border rounded-sm bg-(--surface-primary) hover:bg-(--surface-tertiary) transition-colors text-(--ui-input-text) border-(--ui-input-border)/50 hidden lg:inline-block"
          aria-label={`See all products${brand ? ` from ${brand}` : ""}`}
        >
          See all from {brand}
        </a>
      )
    }
  </div>

  <!-- Horizontal scroll — bleeds to parent edges -->
  <div
    class="-mx-4 sm:-mx-6 lg:-mx-8 overflow-x-auto pb-4 scrollbar-hide"
    role="region"
    aria-label={`More from ${brand ?? "this brand"}`}
  >
    <div class="flex gap-3 lg:gap-4 px-4 sm:px-6 lg:px-8">
      {
        displayProducts.map((product, index) => {
          const inventoryStatus = inventoryMap.get(product.variationId);
          const isOutOfStock = inventoryStatus?.isOutOfStock ?? false;
          const defaultVariation = product.variations?.[0];
          const saleInfo = defaultVariation?.saleInfo;
          const isOnSale = !!saleInfo && !isOutOfStock;
          const displayPrice = saleInfo?.salePrice ?? product.price;
          const formattedPrice = MoneyUtils.format(
            MoneyUtils.fromFloat(displayPrice),
          );
          const formattedOriginal = saleInfo
            ? MoneyUtils.format(MoneyUtils.fromFloat(saleInfo.originalPrice))
            : null;
          const imageUrl = toNetlifyImageCDN(product.image ?? "", 600, { height: 600 });
          const productUrl = product.url;

          return (
            <a
              href={productUrl}
              data-astro-prefetch="viewport"
              class:list={[
                "group relative flex-none w-52 sm:w-60 lg:w-72 overflow-hidden rounded-sm bg-(--surface-secondary) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--content-link)",
                isOutOfStock && "opacity-80",
              ]}
              aria-label={`${product.brand ? product.brand + " " : ""}${product.title} — ${formattedPrice}${isOutOfStock ? " — Sold Out" : ""}${isOnSale ? " — On Sale" : ""}`}
            >
              {/* Image */}
              <div class="aspect-3/4 overflow-hidden">
                <img
                  src={imageUrl}
                  alt=""
                  aria-hidden="true"
                  class:list={[
                    "w-full h-full object-cover transition-transform duration-500 group-hover:scale-105",
                    isOutOfStock && "grayscale-40",
                  ]}
                  loading={index < 2 ? "eager" : "lazy"}
                  width="600"
                  height="800"
                />
              </div>

              {/* Gradient overlay — stronger for readability */}
              <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/30 to-transparent" />

              {/* Text overlay */}
              <div class="absolute inset-x-0 bottom-0 p-4 lg:p-5">
                {product.brand && (
                  <p class="text-xs uppercase tracking-widest font-bold text-(--color-elco-sweet-tea-300) mb-1.5 leading-none">
                    {product.brand}
                  </p>
                )}
                <p class="text-base lg:text-lg font-bold text-white leading-snug line-clamp-2 mb-2.5">
                  {product.title}
                </p>
                <div class="flex items-baseline gap-2" aria-hidden="true">
                  {formattedOriginal && (
                    <del class="text-sm text-white/50">{formattedOriginal}</del>
                  )}
                  <span
                    class:list={[
                      "text-xl font-black",
                      isOnSale
                        ? "text-(--color-elco-sweet-tea-300)"
                        : "text-white",
                    ]}
                  >
                    {formattedPrice}
                  </span>
                </div>
              </div>

              {/* Status badges — aria-hidden since aria-label on the link carries this info */}
              {isOutOfStock && (
                <div
                  aria-hidden="true"
                  class="absolute top-3 left-3 bg-state-error-surface text-state-error-text px-2.5 py-1 text-sm font-black uppercase tracking-widest rounded-xs"
                >
                  Sold Out
                </div>
              )}
              {!isOutOfStock && isOnSale && saleInfo && (
                <div
                  aria-hidden="true"
                  class="absolute top-3 left-3 bg-state-success-surface text-state-success-text px-2.5 py-1 text-sm font-black uppercase tracking-widest rounded-xs"
                >
                  {saleInfo.discountPercent}% Off
                </div>
              )}
            </a>
          );
        })
      }

      {/* "See all" terminal card */}
      <a
        href={seeAllUrl}
        class="group relative flex-none w-32 sm:w-36 overflow-hidden rounded-sm bg-(--surface-secondary) border-2 border-(--border-primary) hover:border-(--color-elco-sweet-tea-300) transition-colors duration-200 flex flex-col items-center justify-center gap-3 p-4 text-center focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--content-link)"
      >
        <svg
          class="w-8 h-8 text-(--content-meta) group-hover:text-(--color-elco-sweet-tea-400) transition-colors"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
        <p
          class="text-xs font-bold uppercase tracking-widest text-(--content-meta) group-hover:text-(--content-heading) transition-colors leading-snug"
        >
          See all{brand ? ` from ${brand}` : ""}
        </p>
      </a>
    </div>
  </div>
</section>
