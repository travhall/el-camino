---
// src/components/Notification.astro
---

<div id="notification-container" class="fixed top-4 right-4 z-[9999] flex flex-col gap-2 items-end pointer-events-none">
</div>

<script>
  // Add TypeScript declaration for the global function
  declare global {
    interface Window {
      showNotification(
        message: string,
        type?: "success" | "error" | "info" | "warning",
        duration?: number,
        action?:
          | { label: string; href: string }
          | { label: string; onClick: () => void }
      ): void;
    }
  }

  type NotificationType = "success" | "error" | "info" | "warning";

  type NotificationAction =
    | { label: string; href: string }
    | { label: string; onClick: () => void };

  const notificationManager = {
    showNotification(
      message: string,
      type: NotificationType = "success",
      duration: number = 3000,
      action?: NotificationAction
    ): void {
      const container = document.getElementById("notification-container");
      if (!container) {
        console.error("Notification container not found!");
        return;
      }

      const bgClass =
        type === "success"
          ? "bg-state-success-surface text-state-success-text"
          : type === "error"
            ? "bg-state-error-surface text-state-error-text"
            : type === "warning"
              ? "bg-state-warning-surface text-state-warning-text"
              : "bg-state-info-surface text-state-info-text";

      const notification = document.createElement("div");
      notification.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 text-base font-light rounded shadow-md opacity-0 translate-x-4 transition-all duration-300 ${bgClass}`;

      const textNode = document.createElement("span");
      textNode.textContent = message;
      notification.appendChild(textNode);

      if (action) {
        if ("onClick" in action) {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.textContent = action.label;
          btn.className =
            "ml-2 font-semibold underline underline-offset-2 shrink-0 hover:opacity-75 transition-opacity cursor-pointer";
          btn.addEventListener("click", () => {
            notification.classList.add("opacity-0", "translate-x-4");
            setTimeout(() => notification.remove(), 300);
            action.onClick();
          });
          notification.appendChild(btn);
        } else {
          const link = document.createElement("a");
          link.href = action.href;
          link.textContent = action.label;
          link.className =
            "ml-2 font-semibold underline underline-offset-2 shrink-0 hover:opacity-75 transition-opacity";
          notification.appendChild(link);
        }
      }

      container.appendChild(notification);

      // Entrance animation
      requestAnimationFrame(() => {
        notification.classList.remove("opacity-0", "translate-x-4");
      });

      // Exit animation
      setTimeout(() => {
        notification.classList.add("opacity-0", "translate-x-4");
        setTimeout(() => notification.remove(), 300);
      }, duration);
    },
  };

  window.showNotification =
    notificationManager.showNotification.bind(notificationManager);
</script>
