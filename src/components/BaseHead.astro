---
// src/components/BaseHead.astro
import { ClientRouter } from "astro:transitions";
import { SEOMetadata } from "astro-seo-metadata";
import { siteConfig } from "@/lib/site-config";
import SpeculationRules from "@/components/SpeculationRules.astro";
import "@/styles/global.css";

interface Props {
    title: string;
    /** Page-specific structured data (e.g. Product, Article schema) */
    structuredData?: object;
    /** Org-level schema from getStructuredData() — caller's responsibility */
    orgSchema: object;
    currentPath: string;
    isHighTrafficPage: boolean;
}

const { title, structuredData, orgSchema, currentPath, isHighTrafficPage } =
    Astro.props;

const seoData = {
    ...siteConfig.seo,
};
---

<meta charset="UTF-8" />
<script is:inline>
    (function () {
        const storedTheme = localStorage.getItem("theme");
        const systemPrefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
        ).matches;
        const theme = storedTheme ?? (systemPrefersDark ? "dark" : "light");
        document.documentElement.classList.add(theme);
        document.documentElement.setAttribute("data-theme", theme);

        // ENHANCED: Font loading state management for View Transitions
        document.documentElement.classList.add("fonts-loading");

        // CRITICAL: Use localStorage instead of sessionStorage for View Transitions persistence
        const fontsLoaded = localStorage.getItem("fonts-loaded");
        const fontsCached =
            document.fonts.check("700 48px Alumni") &&
            document.fonts.check("400 16px Cabin");

        if (fontsLoaded === "true" || fontsCached) {
            // Fonts already loaded - prevent FOUT immediately
            document.documentElement.classList.remove("fonts-loading");
            document.documentElement.classList.add("fonts-loaded");
        } else {
            // Force preloaded fonts to load immediately (critical weights)
            Promise.all([
                document.fonts.load("700 48px Alumni"),
                document.fonts.load("600 24px Alumni"), // Navigation weight
                document.fonts.load("400 16px Cabin"),
                document.fonts.load("500 16px Cabin"), // Filter weights
            ])
                .then(() => {
                    document.documentElement.classList.remove("fonts-loading");
                    document.documentElement.classList.add("fonts-loaded");
                    localStorage.setItem("fonts-loaded", "true");
                })
                .catch(() => {
                    document.documentElement.classList.remove("fonts-loading");
                    document.documentElement.classList.add("fonts-failed");
                    // Still set loaded to prevent retries during View Transitions
                    localStorage.setItem("fonts-loaded", "true");
                });
        }
    })();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- OPTIMIZED: Font preloading for FOUT prevention during View Transitions -->
<!-- Alumni Sans: Display font - high priority for headings/LCP -->
<link
    rel="preload"
    href="/fonts/AlumniSans.woff2"
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
    fetchpriority="high"
/>
<!-- Cabin: Body font - standard priority -->
<link
    rel="preload"
    href="/fonts/Cabin.woff2"
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
/>

<!-- Critical CSS: design tokens + base styles inlined for immediate first-paint.
     The browser can render body background/text/headings before global.css downloads.
     Values must stay in sync with src/styles/global.css @theme and .dark blocks. -->
<style>
    /* Palette values used by critical semantic tokens */
    :root {
        --color-elco-beeswax-100: oklch(96.5% 0.008 70);
        --color-elco-beeswax-200: oklch(92% 0.012 70);
        --color-elco-beeswax-800: oklch(40% 0.026 70);
        --color-elco-beeswax-900: oklch(18% 0.024 70);
        --color-elco-sweet-tea-700: oklch(35% 0.06 60);
        --color-elco-fig-leaf-50: oklch(98.5% 0.008 117);
        --color-elco-fig-leaf-100: oklch(90% 0.016 117);
        --color-elco-fig-leaf-800: oklch(22% 0.052 117);
        --color-elco-fig-leaf-900: oklch(12.5% 0.042 117);
        --color-elco-sweet-tea-200: oklch(85% 0.04 60);

        /* Semantic surface + content tokens (light mode defaults) */
        --surface-primary: var(--color-elco-beeswax-100);
        --surface-secondary: var(--color-elco-beeswax-200);
        --content-heading: var(--color-elco-beeswax-800);
        --content-body: var(--color-elco-beeswax-900);
        --content-meta: var(--color-elco-sweet-tea-700);

        /* Font stacks */
        --font-display: "Alumni", "Alumni Fallback", serif;
        --font-sans: "Cabin", sans-serif;
    }

    /* Dark mode token overrides */
    .dark {
        --surface-primary: var(--color-elco-fig-leaf-900);
        --surface-secondary: var(--color-elco-fig-leaf-800);
        --content-heading: var(--color-elco-fig-leaf-100);
        --content-body: var(--color-elco-fig-leaf-50);
        --content-meta: var(--color-elco-sweet-tea-200);
    }

    /* Base body styles — prevents flash of white before global.css applies */
    body {
        background-color: var(--surface-primary);
        color: var(--content-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    h1 {
        font-family:
            "Alumni",
            "Alumni Fallback",
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            system-ui,
            sans-serif;
        font-synthesis: none;
        font-optical-sizing: auto;
    }

    /* Use opacity (not visibility/display) to avoid harming LCP measurement.
     The browser still considers opacity:0 elements as LCP candidates,
     whereas visibility:hidden elements are excluded from LCP. */
    .fonts-loading h1 {
        opacity: 0;
        transition: opacity 0.1s ease;
    }

    .fonts-loaded h1,
    .fonts-failed h1 {
        opacity: 1;
    }
</style>

<!-- OPTIMIZED: Resource hints for external domains -->
<!-- preconnect: full TLS handshake up-front for domains hit on every page load -->
<link rel="preconnect" href="https://elcaminoskateshop.wordpress.com" />
<link rel="preconnect" href="https://api.zippopotam.us" />
<!-- dns-prefetch: lightweight hint for domains hit conditionally -->
<link rel="dns-prefetch" href="https://squarecdn.com" />
<link rel="dns-prefetch" href="https://api.elcaminoskateshop.com" />

<SEOMetadata
    siteName={siteConfig.name}
    title={title}
    description={seoData.defaultDescription}
    image={seoData.defaultImage}
    favicon="/favicon.svg"
    author={siteConfig.name}
    copyright="ISC"
    astroSitemap={true}
    canonicalUrl={Astro.url.toString()}
    type="website"
    astroGenerator={true}
/>

<!-- Speculation Rules for Advanced Prefetching -->
<SpeculationRules currentPath={currentPath} eager={isHighTrafficPage} />

<script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(orgSchema)}
/>
{
    structuredData && (
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(structuredData)}
        />
    )
}

<!-- Allow pages to inject custom head content -->
<slot name="head" />

<script
    is:inline
    define:vars={{ squareEnv: import.meta.env.PUBLIC_SQUARE_ENVIRONMENT }}
>
    // Only load Square when needed (cart/product pages)
    if (
        window.location.pathname.includes("/cart") ||
        window.location.pathname.includes("/product") ||
        window.location.pathname.includes("/category") ||
        window.location.pathname.includes("/shop")
    ) {
        window.loadSquareScript = function () {
            if (!window.squareLoaded && !window.Square) {
                window.squareLoaded = true;
                const script = document.createElement("script");
                script.src =
                    squareEnv === "production"
                        ? "https://web.squarecdn.com/v1/square.js"
                        : "https://sandbox.web.squarecdn.com/v1/square.js";
                script.async = true;
                document.head.appendChild(script);
                return new Promise((resolve) => {
                    script.onload = resolve;
                });
            }
            return Promise.resolve();
        };
    }
</script>

<!-- Font cache warmer: re-load fonts into active memory after each View Transition.
     font-display:swap ensures they render when ready, but proactively warming
     the cache prevents a visible swap flash on the *next* navigation. -->
<script is:inline>
    document.addEventListener("astro:page-load", function () {
        if (document.fonts && document.fonts.load) {
            Promise.all([
                document.fonts.load("700 48px Alumni"),
                document.fonts.load("600 24px Alumni"),
                document.fonts.load("400 16px Cabin"),
                document.fonts.load("500 16px Cabin"),
            ]).catch(function () {
                // Ignore — fonts will render via font-display:swap fallback
            });
        }
    });
</script>

<!-- Clean news parameters when outside news section -->
<script is:inline>
    document.addEventListener("astro:page-load", function () {
        if (!window.location.pathname.startsWith("/news")) {
            const url = new URL(window.location);
            if (url.searchParams.has("view")) {
                url.searchParams.delete("view");
                const newUrl =
                    url.pathname +
                    (url.searchParams.toString()
                        ? "?" + url.searchParams.toString()
                        : "");
                if (
                    newUrl !==
                    window.location.pathname + window.location.search
                ) {
                    window.history.replaceState({}, "", newUrl);
                }
            }
        }
    });
</script>

<ClientRouter />
