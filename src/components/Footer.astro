---
// src/components/Footer.astro
import { Icon } from "astro-icon/components";
import ThemeToggle from "./ThemeToggle.astro";
import { getLegalPages } from "@/lib/wordpress/api";
import type { WordPressPage } from "@/lib/wordpress/types";
import { siteConfig } from "@/lib/site-config";
import { getSiteContext } from "@/lib/siteContext";
import OpenStatusBadge from "./OpenStatusBadge.astro";

const currentYear = new Date().getFullYear();
const { tagline } = siteConfig;

// Shared per-request bundle (parallel-fetched in Layout). Avoids the
// previous 3 serial blob reads here, plus the duplicate calls Nav was
// making for contact/social.
const siteCtx = await getSiteContext(Astro.locals);
const { hours, contact, social } = siteCtx;

// Fetch footer pages from WordPress (independent — runs in parallel with
// the page's own fetches via Astro's render scheduler).
let footerPages: WordPressPage[] = [];
let wpError: string | null = null;

try {
  footerPages = await getLegalPages();
  if (footerPages.length === 0) {
    throw new Error("No legal pages returned from API");
  }
} catch (error) {
  wpError =
    error instanceof Error ? error.message : "WordPress connection failed";
  console.error("Footer pages error:", wpError);
}
---

<!-- Pre-fetched legal pages for the policy modal — read by showPolicyModal() -->
<script
  id="legal-pages-data"
  type="application/json"
  set:html={JSON.stringify(
    footerPages.map((p) => ({
      slug: p.slug,
      title: p.title,
      content: p.content,
    })),
  )}
/>

<!-- Store hours data island — read by OpenStatusBadge on every page -->
<script
  id="site-hours-data"
  type="application/json"
  set:html={JSON.stringify(hours)}
/>

<footer
  class="p-4 lg:px-8 w-full bg-(--surface-secondary) border-4 border-(--border-secondary) border-t-0 z-0"
>
  <div class="flex flex-col items-start lg:flex-row lg:justify-between py-4">
    <div>
      <div
        class="footer-logo flex flex-row items-center justify-center border border-(--content-heading)"
      >
        <Icon
          name="Icon"
          aria-hidden="true"
          class="w-20 h-auto p-4 text-(--surface-secondary) bg-(--content-heading)"
        />
        <p
          class="max-w-[18ch] px-4 leading-5 text-balance text-(--content-heading)"
        >
          {tagline}
        </p>
      </div>

      <!-- Social links + theme toggle -->
      <div
        class="flex flex-row items-center gap-4 lg:self-end my-12 lg:mt-8 lg:mb-0"
      >
        <nav aria-label="Social media links" class="flex items-center">
          <ul class="inline-flex flex-row gap-2">
            {
              social.map((item) => (
                <li>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Visit our ${item.platform} page (opens in new tab)`}
                    class="text-(--content-heading) hover:text-(--content-emphasis) transition-colors"
                  >
                    <Icon
                      name={item.icon}
                      class="w-6 h-auto"
                      aria-hidden="true"
                    />
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <ThemeToggle />
      </div>
    </div>

    <div class="flex flex-col justify-end gap-6">
      <address
        class="flex flex-col gap-6 lg:gap-2 mb-4 not-italic place-items-start lg:place-items-end text-(--content-heading)"
      >
        <strong class="sr-only">Contact Information</strong>
        <span class="flex items-center gap-2">
          <span aria-label="Business name" class="uppercase"
            >{contact.name}</span
          >
          <OpenStatusBadge />
        </span>
        <span aria-label="Address" class="lg:mb-4"
          >{
            `${contact.street}, ${contact.city}, ${contact.state} ${contact.zip}`
          }</span
        >
        <a
          href={`tel:${contact.phoneRaw}`}
          class="relative font-semibold text-(--content-heading) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all"
          aria-label={`Call us at ${contact.phone}`}
        >
          {contact.phone}
        </a>
        <a
          href={`mailto:${contact.email}`}
          class="relative font-semibold text-(--content-heading) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all"
          aria-label={`Email us at ${contact.email}`}
        >
          {contact.email}
        </a>
      </address>
    </div>
  </div>

  <div class="border-t border-(--surface-tertiary) mt-2 pt-4">
    <div
      class="flex flex-col-reverse lg:flex-row lg:justify-between lg:items-center py-4 gap-6"
    >
      <small class="block text-sm text-(--content-heading)">
        &copy;{currentYear}&nbsp;
        {contact.name}, all rights reserved
      </small>
      <div class="flex flex-col lg:flex-row lg:flex-wrap gap-6">
        {
          footerPages.map((page) => (
            <button
              type="button"
              data-policy-slug={page.slug}
              class="policy-modal-trigger text-base md:text-sm font-semibold relative p-1 text-(--content-heading) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all cursor-pointer self-start"
            >
              {page.title.rendered}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<script>
  import { showPolicyModal } from "@/lib/events";

  function setupPolicyTriggers() {
    document
      .querySelectorAll<HTMLButtonElement>(".policy-modal-trigger")
      .forEach((btn) => {
        if (btn.getAttribute("data-policy-initialized") === "true") return;
        btn.setAttribute("data-policy-initialized", "true");
        btn.addEventListener("click", () => {
          const slug = btn.dataset.policySlug;
          if (slug) showPolicyModal(slug);
        });
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupPolicyTriggers);
  } else {
    setupPolicyTriggers();
  }

  document.addEventListener("astro:page-load", setupPolicyTriggers);
</script>
