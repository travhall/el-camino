---
// src/components/Footer.astro
import { Icon } from "astro-icon/components";
import ThemeToggle from "./ThemeToggle.astro";
import { getLegalPages } from "@/lib/wordpress/api";
import type { WordPressPage } from "@/lib/wordpress/types";
import { siteConfig } from "@/lib/site-config";

const currentYear = new Date().getFullYear();
const { contact, social, tagline } = siteConfig;

// Fetch footer pages from WordPress
let footerPages: WordPressPage[] = [];
let wpError: string | null = null;

try {
  footerPages = await getLegalPages();
  if (footerPages.length === 0) {
    throw new Error("No legal pages returned from API");
  }
} catch (error) {
  wpError =
    error instanceof Error ? error.message : "WordPress connection failed";
  console.error("Footer pages error:", wpError);
}
---

<!-- Pre-fetched legal pages for the policy modal — read by showPolicyModal() -->
<script
  id="legal-pages-data"
  type="application/json"
  set:html={JSON.stringify(
    footerPages.map((p) => ({
      slug: p.slug,
      title: p.title,
      content: p.content,
    })),
  )}
/>

<footer
  class="p-4 w-full bg-(--surface-secondary) border-4 border-(--border-secondary) border-t-0 z-0"
>
  <div class="flex flex-col items-start lg:flex-row lg:justify-between py-4">
    <div>
      <div
        class="footer-logo flex flex-row items-center justify-center border border-(--content-heading) mb-8 lg:mb-0"
      >
        <Icon
          name="Icon"
          aria-hidden="true"
          class="w-20 h-auto p-4 text-(--surface-primary) bg-(--content-heading)"
        />
        <p
          class="max-w-[18ch] px-4 leading-5 text-balance text-(--content-heading)"
        >
          {tagline}
        </p>
      </div>

      <!-- Business Hours -->
      <!-- <div class="mt-6">
        <h3 class="text-sm font-medium text-(--content-heading) mb-2 uppercase">
          Hours
        </h3>
        <div class="space-y-1">
          {
            businessHours.map((day) => (
              <div
                class={`flex justify-between ${
                  day === today
                    ? "text-(--content-emphasis) font-medium"
                    : "text-(--content-body)"
                }`}
              >
                <span>{day.day}</span>
                <span
                  class={
                    day.isOpen
                      ? "text-(--content-body)"
                      : "text-(--content-meta)"
                  }
                >
                  {day.hours}
                </span>
              </div>
            ))
          }
        </div>
      </div> -->
    </div>

    <div class="flex flex-col justify-end">
      <!-- Address -->
      <address
        class="flex flex-col gap-2 mb-4 uppercase not-italic place-items-start lg:place-items-end text-(--content-heading)"
      >
        <strong class="sr-only">Contact Information</strong>
        <span aria-label="Business name">{siteConfig.name}</span>
        <span aria-label="Address" class="mb-4">{contact.address.display}</span>
        <a
          href={`tel:${contact.phone.number}`}
          class="relative font-semibold text-(--content-heading) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all"
          aria-label={`Call us at ${contact.phone.display}`}
        >
          {contact.phone.display}
        </a>
        <a
          href={`mailto:${contact.email}`}
          class="relative font-semibold text-(--content-heading) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all"
          aria-label={`Email us at ${contact.email}`}
        >
          {contact.email}
        </a>
      </address>

      <!-- Social links + theme toggle -->
      <div class="flex flex-row items-center gap-3 lg:self-end">
        <nav aria-label="Social media links">
          <ul class="inline-flex flex-row gap-2">
            {
              social.map((item) => (
                <li>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Visit our ${item.platform} page (opens in new tab)`}
                    class="text-(--content-heading) hover:text-(--content-emphasis) transition-colors"
                  >
                    <Icon
                      name={item.icon}
                      class="w-6 h-auto"
                      aria-hidden="true"
                    />
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <ThemeToggle />
      </div>
    </div>
  </div>

  <!-- Divider -->
  <div class="border-t border-(--surface-tertiary) mt-2">
    <div class="flex flex-col lg:flex-row lg:justify-between lg:items-center py-4 gap-3">
      <small class="block text-base text-(--content-heading) md:text-sm">
        &copy;{currentYear} {siteConfig.name}, all rights reserved
      </small>
      <div class="flex flex-wrap gap-4 lg:gap-6">
        {
          footerPages.map((page) => (
            <button
              type="button"
              data-policy-slug={page.slug}
              class="policy-modal-trigger text-base md:text-sm font-semibold relative text-(--content-heading) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all cursor-pointer"
            >
              {page.title.rendered}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<script>
  function setupPolicyTriggers() {
    document
      .querySelectorAll<HTMLButtonElement>(".policy-modal-trigger")
      .forEach((btn) => {
        if (btn.getAttribute("data-policy-initialized") === "true") return;
        btn.setAttribute("data-policy-initialized", "true");
        btn.addEventListener("click", () => {
          const slug = btn.dataset.policySlug;
          if (slug && typeof window.showPolicyModal === "function") {
            window.showPolicyModal(slug);
          }
        });
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupPolicyTriggers);
  } else {
    setupPolicyTriggers();
  }

  document.addEventListener("astro:page-load", setupPolicyTriggers);
</script>
