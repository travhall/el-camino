---
// src/components/Header.astro
import Nav from "@/components/Nav.astro";
import { Icon } from "astro-icon/components";
import CartButton from "./CartButton.astro";
import CartButtonMobile from "./CartButtonMobile.astro";
import AnnouncementBanner from "./AnnouncementBanner.astro";
import { detectDeviceFromUA } from "@/utils/device";

interface Props {
  activeCategory?: string;
  /** Set to false to hide the cart button — used by CartLayout */
  showCart?: boolean;
}

const { activeCategory, showCart = true } = Astro.props;

// Device detection for conditional rendering
const userAgent = Astro.request.headers.get("user-agent") || "";
const deviceInfo = detectDeviceFromUA(userAgent);
const isMobile = deviceInfo.isMobile;
---

<script is:inline>
  (function () {
    if (!sessionStorage.getItem("header-animated")) {
      document.documentElement.classList.add("header-first-load");
      sessionStorage.setItem("header-animated", "true");
    }
  })();
</script>

<style is:global>
  /* Fade-in on first session load — prevents the snap-in feeling on cold
     starts without animating on every in-session navigation. */
  .header-first-load #site-header {
    opacity: 0;
    animation: fadeInHeader 0.6s ease-out 0.2s forwards;
  }

  @keyframes fadeInHeader {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .header-first-load #site-header {
      animation: none;
      opacity: 1;
    }
  }
</style>

<header
  id="site-header"
  class="flex flex-col -mb-1 sticky top-0 z-50 border-4 border-(--border-secondary) bg-(--surface-secondary)"
>
  <AnnouncementBanner />

  <div class="flex flex-row items-center justify-between">
    <a
      href="/"
      class="flex self-center justify-start hover:opacity-60 transition-opacity rounded-sm focus-visible:ring-2 focus-visible:ring-(--content-body) focus-visible:ring-offset-2 focus-visible:ring-offset-(--surface-secondary) outline-none"
      aria-label="Home Link"
    >
      <Icon
        name="Logo"
        class="w-48 xl:w-56 h-auto p-1 m-4 text-(--content-heading)"
        aria-hidden="true"
      />
    </a>

    <Nav activeCategory={activeCategory} />

    <div
      class="utility-menu self-center justify-end lg:order-last flex mr-1 gap-2"
    >
      {
        showCart ? (
          isMobile ? (
            <CartButtonMobile />
          ) : (
            <CartButton />
          )
        ) : (
          <div class="p-2" aria-hidden="true">
            <div class="h-6 w-6 m-1" />
          </div>
        )
      }
      <button
        id="mobile-menu-toggle"
        class="p-2 lg:hidden text-(--content-body) rounded-sm focus-visible:ring-2 focus-visible:ring-(--content-body) focus-visible:ring-offset-2 focus-visible:ring-offset-(--surface-secondary) outline-none"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="main-nav"
      >
        <Icon
          name="uil:bars"
          class="w-6 h-6"
          id="menu-icon"
          aria-hidden="true"
        />
        <Icon
          name="uil:times"
          class="w-6 h-6 hidden"
          id="close-icon"
          aria-hidden="true"
        />
      </button>
    </div>
  </div>
</header>

<script>
  // Handle menu toggle functionality
  // AbortController lets us cleanly remove ALL listeners on each page swap
  // instead of trying to removeEventListener on locally-scoped functions.
  let menuAbortController: AbortController | null = null;

  function setupMobileMenu() {
    // Tear down previous listeners before re-registering
    if (menuAbortController) {
      menuAbortController.abort();
    }
    menuAbortController = new AbortController();
    const signal = menuAbortController.signal;

    const toggleButton = document.getElementById(
      "mobile-menu-toggle",
    ) as HTMLButtonElement;
    const menuIcon = document.getElementById("menu-icon") as HTMLElement;
    const closeIcon = document.getElementById("close-icon") as HTMLElement;
    const nav = document.querySelector("nav") as HTMLElement;

    // Early return if elements don't exist
    if (!toggleButton || !menuIcon || !closeIcon || !nav) return;

    // Always reset to closed state on setup — ensures icon/aria sync after page transitions
    toggleButton.setAttribute("aria-expanded", "false");
    toggleButton.setAttribute("aria-label", "Open navigation");
    menuIcon.classList.remove("hidden");
    closeIcon.classList.add("hidden");
    nav.classList.remove("nav-open");
    document.body.style.overflow = "";

    function openMenu() {
      toggleButton.setAttribute("aria-expanded", "true");
      toggleButton.setAttribute("aria-label", "Close navigation");
      menuIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
      nav.classList.add("nav-open");
      document.body.style.overflow = "hidden";

      // Move focus to first focusable item in nav
      const firstNavLink = nav.querySelector<HTMLElement>("a, button");
      if (firstNavLink) {
        requestAnimationFrame(() => firstNavLink.focus());
      }
    }

    function closeMenu() {
      toggleButton.setAttribute("aria-expanded", "false");
      toggleButton.setAttribute("aria-label", "Open navigation");
      menuIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      nav.classList.remove("nav-open");
      document.body.style.overflow = "";

      // Return focus to the toggle button
      toggleButton.focus();
    }

    toggleButton.addEventListener(
      "click",
      (e: MouseEvent) => {
        e.stopPropagation();
        const isExpanded =
          toggleButton.getAttribute("aria-expanded") === "true";
        if (isExpanded) {
          closeMenu();
        } else {
          openMenu();
        }
      },
      { signal },
    );

    // Close menu when clicking outside
    document.addEventListener(
      "click",
      (e: MouseEvent) => {
        const isExpanded =
          toggleButton.getAttribute("aria-expanded") === "true";
        const clickTarget = e.target as Node;
        if (
          isExpanded &&
          !nav.contains(clickTarget) &&
          !toggleButton.contains(clickTarget)
        ) {
          closeMenu();
        }
      },
      { signal },
    );

    // Close menu on Escape + focus trap
    document.addEventListener(
      "keydown",
      (e: KeyboardEvent) => {
        const isExpanded =
          toggleButton.getAttribute("aria-expanded") === "true";

        if (e.key === "Escape" && isExpanded) {
          closeMenu();
          return;
        }

        if (e.key !== "Tab" || !isExpanded) return;

        const focusable = Array.from(
          nav.querySelectorAll<HTMLElement>(
            'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
          ),
        ).filter(
          (el) => !el.closest(".lg\\:hidden") || window.innerWidth < 1024,
        );

        if (focusable.length === 0) return;

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            toggleButton.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      },
      { signal },
    );
  }

  // Initialize menu
  setupMobileMenu();

  // Re-initialize on each page transition — AbortController handles cleanup
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
