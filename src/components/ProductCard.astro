---
// src/components/ProductCard.astro - Enhanced with Quick View
import type { Product, InventoryStatus } from "@/lib/square/types";
import { MoneyUtils } from "@/lib/square/money";
import { checkItemInventory } from "@/lib/square/inventory";
import { Icon } from "astro-icon/components";
import {
  EL_CAMINO_LOGO_DATA_URI,
  EL_CAMINO_LOADER_DATA_URI,
} from "@/lib/constants/assets";
import { EnhancedImageOptimizer } from "@/lib/image/enhanced-optimizer";

interface Props {
  product: Product;
  priority?: boolean;
  index?: number;
  skipInventoryCheck?: boolean;
  inventoryStatus?: InventoryStatus;
}

const {
  product,
  priority = false,
  index = 0,
  skipInventoryCheck = false,
  inventoryStatus,
} = Astro.props;

// Use inventory status if provided, otherwise perform individual check
let isOutOfStock = false;

// If we have batch inventory status, use it
if (inventoryStatus) {
  isOutOfStock = inventoryStatus.isOutOfStock;
} else if (!skipInventoryCheck && product.variationId) {
  // Fallback to individual inventory check
  try {
    const quantity = await checkItemInventory(product.variationId);
    isOutOfStock = quantity <= 0;
  } catch (error) {
    console.error(
      `ProductCard inventory check failed for ${product.title}:`,
      error
    );
    // Default to in stock on error
  }
}

// Enhanced alt text generation for better accessibility
function generateProductAltText(
  product: Product,
  isOutOfStock: boolean
): string {
  const brand = product.brand ? `${product.brand} ` : "";
  const price = product.price
    ? `, priced at ${MoneyUtils.format(MoneyUtils.fromFloat(product.price))}`
    : "";
  const stock = isOutOfStock ? ", currently sold out" : ", in stock";

  return `${brand}${product.title}${price}${stock}`;
}

// Generate enhanced alt text
const enhancedAltText = generateProductAltText(product, isOutOfStock);

// Check for sale pricing (from default/first variation)
const defaultVariation = product.variations?.[0];
const saleInfo = defaultVariation?.saleInfo;
const isOnSale = !!saleInfo && !isOutOfStock; // Don't show sale if sold out

// Format prices for display
const formattedPrice = saleInfo
  ? MoneyUtils.format(MoneyUtils.fromFloat(saleInfo.salePrice))
  : MoneyUtils.format(MoneyUtils.fromFloat(product.price));

const formattedOriginalPrice = saleInfo
  ? MoneyUtils.format(MoneyUtils.fromFloat(saleInfo.originalPrice))
  : null;

// Schema.org availability
const availabilitySchema = isOutOfStock
  ? "https://schema.org/OutOfStock"
  : "https://schema.org/InStock";

// Generate unique IDs
const imageId = `img-${product.id}`;
const placeholderId = `placeholder-${product.id}`;

// Dynamic priority - OPTIMIZED FOR MOBILE NETWORKS
// Conservative prefetching to prevent network congestion
// Each product = 3 image formats (AVIF, WebP, JPEG)
// 2 products × 3 formats = 6 high-priority images (optimal for mobile 4G)
// Previous: index < 4 (12 images) was still overwhelming slower connections
const MAX_PRIORITY_IMAGES = 2;
const isDynamicPriority = priority || index < MAX_PRIORITY_IMAGES;

// Enhanced image optimization using new system
// Only generate srcsets if we have a valid image URL
const hasValidImage = product.image && product.image.length > 0 && product.image.startsWith('http');

let optimizedImageSrc = EL_CAMINO_LOGO_DATA_URI; // Default fallback
let avifSrcSet: string | undefined;
let webpSrcSet: string | undefined;
let jpegSrcSet: string | undefined;
let imageSizes = "(max-width: 640px) 50vw, (max-width: 1024px) 33vw, (max-width: 1280px) 25vw, 16vw";

if (hasValidImage) {
  const imageSet = EnhancedImageOptimizer.generateOptimizedSources(
    product.image,
    {
      width: 600,
      height: 400,
      quality: 85,
      priority: isDynamicPriority,
    }
  );

  optimizedImageSrc = imageSet.avif || imageSet.webp || imageSet.jpeg;

  // Generate responsive srcset for each format
  avifSrcSet = imageSet.avif 
    ? EnhancedImageOptimizer.generateResponsiveSrcSet(product.image, 'avif', {
        width: 600,
        height: 400,
        quality: 85
      })
    : undefined;

  webpSrcSet = imageSet.webp
    ? EnhancedImageOptimizer.generateResponsiveSrcSet(product.image, 'webp', {
        width: 600,
        height: 400,
        quality: 85
      })
    : undefined;

  jpegSrcSet = EnhancedImageOptimizer.generateResponsiveSrcSet(product.image, 'jpeg', {
    width: 600,
    height: 400,
    quality: 85
  });
}
---

<div
  class="group relative w-full h-full product-card"
  data-title={product.title}
  data-price={product.price.toString()}
  data-id={product.id}
>
  <a
    href={product.url}
    data-astro-prefetch="viewport"
    class={`grid grid-rows-[auto_1fr] gap-2 w-full h-full p-1 bg-(--ui-card-surface) text-(--ui-card-text) hover:bg-(--ui-card-surface-hover) transition-all duration-200 ${isOutOfStock ? "opacity-75" : ""}`}
    itemscope
    itemtype="http://schema.org/Product"
  >
    <!-- Product Image Container -->
    <div class="relative aspect-square overflow-hidden">
      <!-- Unified Loading Placeholder with Logo - Only show for valid images -->
      {
        hasValidImage && (
          <div
            class="loading-skeleton loading-image absolute inset-0 w-full h-full"
            id={placeholderId}
            aria-hidden="true"
          >
            <!-- El Camino logo using data URI -->
            <div
              class="absolute inset-0 flex items-center justify-center"
              style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat; opacity: 0.7;`}
            >
            </div>
          </div>
        )
      }
      <!-- Enhanced Image with Responsive srcset -->
      {
        hasValidImage ? (
          <picture>
            {/* AVIF format (best compression) */}
            {avifSrcSet && (
              <source
                type="image/avif"
                srcset={avifSrcSet}
                sizes={imageSizes}
              />
            )}

            {/* WebP format (good compression) */}
            {webpSrcSet && (
              <source
                type="image/webp"
                srcset={webpSrcSet}
                sizes={imageSizes}
              />
            )}

            {/* JPEG fallback */}
            <img
              id={imageId}
              src={optimizedImageSrc}
              srcset={jpegSrcSet}
              sizes={imageSizes}
              alt={enhancedAltText}
              class={`hover-img object-cover grayscale-50 group-hover:grayscale-0 w-full h-full opacity-0 lg:group-hover:scale-105 transition-all duration-300 ${isOutOfStock ? "opacity-50" : ""} image-enhanced will-change-transform`}
              loading={isDynamicPriority ? "eager" : "lazy"}
              fetchpriority={isDynamicPriority ? "high" : "auto"}
              decoding={isDynamicPriority ? "sync" : "async"}
              width="600"
              height="400"
              data-placeholder-id={placeholderId}
              onload={`this.classList.add('opacity-100', 'loaded'); document.getElementById('${placeholderId}')?.remove()`}
              onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; this.classList.add('opacity-100', 'error'); document.getElementById('${placeholderId}')?.remove()`}
            />
          </picture>
        ) : (
          <img
            id={imageId}
            src={EL_CAMINO_LOGO_DATA_URI}
            alt={enhancedAltText}
            class={`object-cover w-full h-full opacity-100 ${isOutOfStock ? "opacity-50" : ""} image-enhanced error`}
            loading="eager"
            width="600"
            height="400"
          />
        )
      }

      <!-- Stock/Sale status overlay - Sold Out takes priority -->
      {
        isOutOfStock ? (
          <div class="absolute top-0 left-0 bg-state-error-surface text-state-error-text px-3 py-2 text-sm font-bold rounded-br-sm z-20">
            Sold Out
          </div>
        ) : isOnSale && saleInfo ? (
          <div class="absolute top-0 left-0 bg-state-success-surface text-state-success-text px-3 py-2 text-sm font-bold rounded-br-sm z-20">
            {saleInfo.discountPercent}% Off
          </div>
        ) : null
      }

      <!-- Quick View Trigger (appears on hover) -->
      <div
        class="hover-layer absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-end z-10 pointer-events-none"
      >
        <button
          type="button"
          class="quick-view-trigger hidden lg:block text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) focus-visible:ring-(--ui-button-secondary-ring) px-4 py-2 font-semibold text-sm rounded-tl-sm transition-colors duration-200 transform translate-y-4 group-hover:translate-y-0 pointer-events-auto"
          data-product-id={product.id}
          aria-label={`Quick view ${product.title}`}
        >
          <Icon name="uil:eye" class="w-4 h-4 inline mr-2" />
          Quick View
        </button>
      </div>
    </div>

    <!-- Product Info -->
    <div class="grid px-1">
      <div class={`self-start ${isOutOfStock ? "opacity-50" : ""}`}>
        {
          product.brand && (
            <p
              class="text-xs uppercase text-(--content-meta) mb-0"
              itemprop="brand"
            >
              {product.brand}
            </p>
          )
        }
        <h2
          id={`product-title-${product.id}`}
          class="text-base text-(--product-heading) font-light leading-tight line-clamp-2 mb-1"
          itemprop="name"
        >
          {product.title}
        </h2>
      </div>

      <div
        class={`text-(--product-price) self-end mb-2 lg:mb-0 ${isOutOfStock ? "opacity-50" : ""}`}
      >
        <meta itemprop="availability" content={availabilitySchema} />
        
        {/* Show original price with strikethrough when on sale */}
        {isOnSale && formattedOriginalPrice && (
          <div class="text-sm text-(--content-meta) line-through">
            {formattedOriginalPrice}
          </div>
        )}
        
        <span
          id={`product-price-${product.id}`}
          class={`font-display font-semibold text-3xl whitespace-nowrap ${isOnSale ? "text-(--content-emphasis)" : ""}`}
          itemprop="offers"
          itemscope
          itemtype="http://schema.org/Offer"
        >
          <meta itemprop="price" content={(saleInfo?.salePrice || product.price).toString()} />
          <meta itemprop="priceCurrency" content="USD" />
          <meta itemprop="availability" content={availabilitySchema} />
          {formattedPrice}
          {product.unit && <span class="text-lg ml-1">{product.unit}</span>}
        </span>
      </div>
    </div>
  </a>
</div>

<style>
  .image-enhanced.error {
    filter: grayscale(100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .image-enhanced {
      transition: none !important;
    }
  }

  /*
   * Touch devices: disable hover-dependent visual effects.
   * CSS :hover states can get "stuck" after a tap on iOS/Android, leaving the
   * overlay visible and the image scaled/desaturated until the user taps elsewhere.
   * @media (hover: none) targets devices that lack a true hover pointer (touchscreens).
   * Bonus: showing full-color images (no grayscale) is better UX on mobile.
   */
  @media (hover: none) {
    .hover-img {
      filter: grayscale(0) !important;
      transform: none !important;
    }
    .hover-layer {
      opacity: 0 !important;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    // Mobile detection — evaluated at click time, not setup time
    function isMobileDevice(): boolean {
      return window.innerWidth < 1024; // lg breakpoint
    }

    // Attach click handlers to product card anchor elements.
    //
    // IMPORTANT: We do NOT clone/replace elements here. The previous clone-and-replace
    // pattern silently detached each <a> from Astro's prefetch IntersectionObserver,
    // which meant data-astro-prefetch="viewport" never fired and every PDP click
    // triggered a cold SSR fetch.
    //
    // Instead, a data-mobile-handler attribute guards against duplicate listeners
    // if this function is somehow called more than once for the same elements.
    // isMobileDevice() is evaluated on every click so no resize re-setup is needed.
    function setupMobileQuickView(): void {
      const productCards = document.querySelectorAll(
        '[itemtype="http://schema.org/Product"]:not([data-mobile-handler])'
      );

      productCards.forEach((card) => {
        const link = card as HTMLAnchorElement;
        const productId = card
          .querySelector(".quick-view-trigger")
          ?.getAttribute("data-product-id");

        if (!productId) return;

        // Mark element so subsequent calls skip it (prevents listener accumulation)
        link.dataset.mobileHandler = "true";

        // Mobile tap → open Quick View; desktop click → let Astro handle navigation
        link.addEventListener("click", (e) => {
          if (isMobileDevice()) {
            // On mobile: prevent navigation, open Quick View
            e.preventDefault();
            e.stopPropagation();

            // Trigger Quick View if function exists
            if (typeof (window as any).openQuickView === "function") {
              (window as any).openQuickView(productId);
            } else {
              // Fallback to PDP if Quick View not available
              window.location.href = link.href;
            }
          }
          // On desktop: let the link and Astro's view transition work normally
        });

        // Quick View button (desktop hover) — always opens Quick View
        const quickViewButton = link.querySelector(".quick-view-trigger");
        if (quickViewButton) {
          quickViewButton.addEventListener("click", (e) => {
            // Always prevent link navigation when Quick View button is clicked
            e.preventDefault();
            e.stopPropagation();

            if (typeof (window as any).openQuickView === "function") {
              (window as any).openQuickView(productId);
            }
          });
        }
      });
    }

    setupMobileQuickView();
  });
</script>
