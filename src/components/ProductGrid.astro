---
// src/components/ProductGrid.astro - Enhanced with batch inventory optimization
import ProductCard from "./ProductCard.astro";
import ProductCardSkeleton from "./ProductCardSkeleton.astro";
import type { Product, ProductWithInventory } from "@/lib/square/types";
import { batchInventoryService } from "@/lib/square/batchInventory";
// import { logger } from "@/lib/utils/logger";

interface Props {
  products: Product[];
  allProducts?: Product[]; // Deprecated: kept for backward compat, ignored now
  categoryPath?: string;
  skipInventoryCheck?: boolean;
  filteredIds?: string[]; // IDs of server-filtered products (when URL has active filters)
  slugToIdMap?: Record<string, string>; // Slug→ID map for client-side category filtering
  hideSoldOut?: boolean; // When true, sold-out products are omitted entirely (e.g. Sale page)
}

const {
  products,
  categoryPath = "",
  skipInventoryCheck = false,
  filteredIds,
  slugToIdMap = {},
  hideSoldOut = false,
} = Astro.props;

const initialProducts = products;

// Server-side: which cards should be filter-hidden vs scroll-hidden
const filteredIdSet = filteredIds ? new Set(filteredIds) : null;
const initialCardsToShow = 16;

let productsWithInventory: ProductWithInventory[] = initialProducts;

if (!skipInventoryCheck && initialProducts.length > 0) {
  try {
    // Exclude gift cards — they have no inventory tracking and are always in stock
    const variationIds = initialProducts
      .filter((p) => !p.isGiftCard)
      .map((p) => p.variationId)
      .filter(Boolean);
    const inventoryMap =
      await batchInventoryService.getBatchInventoryStatus(variationIds);

    productsWithInventory = initialProducts.map((product) => {
      // Gift cards are always in stock — skip inventory lookup entirely
      const inventoryStatus = product.isGiftCard
        ? { isOutOfStock: false, hasLimitedOptions: false, totalQuantity: 99 }
        : inventoryMap.get(product.variationId) || {
            isOutOfStock: false,
            hasLimitedOptions: false,
            totalQuantity: 0,
          };
      return { ...product, inventoryStatus };
    });
  } catch (error) {
    console.error("Batch inventory check failed:", error);
    productsWithInventory = initialProducts.map((product) => ({
      ...product,
      inventoryStatus: {
        isOutOfStock: false,
        hasLimitedOptions: false,
        totalQuantity: 0,
      },
    }));
  }
}

// Remove sold-out products entirely when requested (e.g. Sale page)
const displayProducts = hideSoldOut
  ? productsWithInventory.filter((p) => !p.inventoryStatus?.isOutOfStock)
  : productsWithInventory;
---

<style>
  /* Animation timing tokens live in global.css :root */

  /* SMOOTH FILTERING: Prevent layout shifts with transitions */
  .product-card-wrapper {
    min-height: 280px; /* Minimum card height */
    transform: translate3d(0, 0, 0); /* GPU acceleration */

    /* Bidirectional transitions for entry AND exit */
    transition:
      opacity var(--card-transition-duration) ease,
      transform var(--card-transition-duration) ease;

    /* Stagger delay only applies when entering (via --animation-order) */
    transition-delay:
      calc(var(--animation-order, 0) * var(--product-stagger-delay)),
      calc(var(--animation-order, 0) * var(--product-stagger-delay));
  }

  /* Exit state */
  .product-card-wrapper.opacity-0 {
    opacity: 0;
    transform: scale(0.95) translate3d(0, 10px, 0);
    /* Fast exit (150ms) ensures animation completes before the page swap */
    transition-duration: 0.15s, 0.15s;
    transition-delay: 0s, 0s;
  }

  /* Entry state */
  .product-card-wrapper.opacity-100 {
    opacity: 1;
    transform: scale(1) translate3d(0, 0, 0);
    /* Delay is inherited from base rule for staggered entrance */
  }

  /* Temporary will-change during animation only */
  .product-card-wrapper.animating {
    will-change: opacity, transform;
  }

  .product-card-wrapper:not(.animating) {
    will-change: auto;
  }

  /* MOBILE INFINITE SCROLL: Better spacing and loading states */
  @media (max-width: 1023px) {
    #infinite-scroll-trigger {
      margin: 1rem 0;
    }
  }

  /* PHASE 5: Stable loading states to prevent layout shifts */
  #filter-loading-overlay {
    contain: layout style paint; /* Full containment for overlay */
  }

  #no-results {
    contain: layout; /* Prevent shifts in no-results state */
  }

  #infinite-scroll-trigger {
    contain: layout; /* Prevent shifts during scroll loading */
  }
</style>

<div
  id="filterable-product-grid"
  role="feed"
  aria-label="Product listings"
  aria-busy="false"
  class="product-grid grid xs:grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-6 gap-1 transition-all duration-300"
  data-category-path={categoryPath}
  data-product-count={displayProducts.length}
  data-slug-to-id={JSON.stringify(slugToIdMap)}
>
  {
    displayProducts.map((product, index) => {
      // Cards are either filter-hidden (doesn't match URL filters) or scroll-hidden (beyond initial batch).
      // When filteredIdSet is null (no active filters), use scroll-hiding.
      // When filteredIdSet is set (active filters), filter-hide non-matching cards; show all matching.
      const isFilterHidden =
        filteredIdSet !== null && !filteredIdSet.has(product.id);
      const isScrollHidden =
        filteredIdSet === null && index >= initialCardsToShow;
      const shouldHide = isFilterHidden || isScrollHidden;

      return (
        <article
          role="article"
          class="product-card-wrapper grid opacity-0"
          aria-labelledby={`product-title-${product.id}`}
          aria-describedby={`product-price-${product.id}`}
          aria-posinset={index + 1}
          aria-setsize={productsWithInventory.length}
          tabindex="-1"
          data-product-id={product.id}
          data-brand={product.brand || ""}
          data-initial-index={index}
          data-categories={JSON.stringify(product.categories || [])}
          data-out-of-stock={
            product.inventoryStatus?.isOutOfStock ? "true" : "false"
          }
          data-on-sale={
            product.variations?.some((v) => v.saleInfo) ? "true" : "false"
          }
          data-filter-hidden={isFilterHidden ? "true" : undefined}
          style={shouldHide ? "display: none;" : ""}
        >
          <ProductCard
            product={product}
            priority={index < 8}
            index={index}
            inventoryStatus={product.inventoryStatus}
            skipInventoryCheck={!!product.inventoryStatus}
          />
        </article>
      );
    })
  }

</div>

<!-- Infinite Scroll Trigger — lives OUTSIDE the product grid so its appearance
     doesn't expand the grid height while in the viewport (CLS fix).
     When the total product count exceeds the initial batch (16), we know at render
     time that infinite scroll WILL be needed. We use visibility:hidden instead of
     display:none so the 80px space is reserved from the start — no layout shift
     when JS makes the spinner visible. For pages with ≤16 products, display:none
     is correct (infinite scroll never activates; JS sets display:none anyway). -->
<div
  id="infinite-scroll-trigger"
  class="h-20 flex items-center justify-center"
  style={displayProducts.length > initialCardsToShow ? "visibility: hidden;" : "display: none;"}
>
  <div class="flex items-center space-x-3">
    <div
      class="animate-spin rounded-full h-5 w-5 border-2 border-ui-accent border-t-transparent"
    >
    </div>
    <span class="text-(--content-body) font-medium"
      >Loading more products...</span
    >
  </div>
</div>

<!-- Load More Button (Progressive Enhancement Fallback) -->
<div
  id="load-more-container"
  class="flex items-center justify-center py-8"
  style="display: none;"
>

<!-- Enhanced Loading Overlay -->
<div
  id="filter-loading-overlay"
  class="fixed inset-0 bg-(--surface-primary)/60 z-40 flex items-center justify-center"
  style="display: none;"
>
  <div
    class="bg-(--surface-secondary) rounded-lg p-6 shadow-lg flex items-center space-x-3"
  >
    <div
      class="animate-spin rounded-full h-5 w-5 border-2 border-ui-accent border-t-transparent"
    >
    </div>
    <span class="text-(--content-body) font-medium">Applying filters...</span>
  </div>
</div>

<!-- Product Grid Loading Skeleton -->
<div
  id="product-grid-skeleton"
  class="hidden grid-cols-2 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-6 gap-1"
>
  {
    Array.from({ length: 12 }, (_, i) => (
      <ProductCardSkeleton priority={i < 8} />
    ))
  }
</div>

<!-- No Results State (for client-side mode only) -->
<div
  id="no-results"
  class="hidden flex-col justify-center items-center col-span-full py-16 text-center"
>
  <div class="text-center">
    <div class="text-6xl mb-4 opacity-20">🔍</div>
    <h2 class="text-2xl font-display font-bold text-(--content-heading) mb-2">
      No products found
    </h2>
    <p class="text-(--content-meta) mb-6 max-w-md mx-auto">
      Try adjusting your filters or browse all products.
    </p>
    <a
      href={categoryPath}
      class="font-sans font-semibold text-sm text-center lg:text-base py-2 px-3 lg:py-2 lg:px-4 border-2 rounded-sm text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 outline-0 focus-visible:ring focus-visible:ring-offset-2 focus-visible:ring-(--ui-button-ring) transition-all ease-in-out duration-300"
    >
      Clear Filters
    </a>
  </div>
</div>

<script>
  // Check for reduced motion preference
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  // Module-level responsive columns calculation (used by both scroll and filter systems)
  function getCardsPerRowCurrent(): number {
    const w = window.innerWidth;
    if (w >= 1536) return 6; // 2xl:grid-cols-6
    if (w >= 1280) return 4; // xl:grid-cols-4
    if (w >= 1024) return 3; // lg:grid-cols-3
    return 2;
  }

  // PHASE 5: Properly parse animation timing from CSS custom properties
  function getAnimationTiming() {
    const style = getComputedStyle(document.documentElement);

    // Parse duration (handles "0.3s", "300ms", etc.)
    const durationStr = style
      .getPropertyValue("--card-transition-duration")
      .trim();
    let duration = 300; // default
    if (durationStr.includes("ms")) {
      duration = parseInt(durationStr.replace("ms", ""));
    } else if (durationStr.includes("s")) {
      duration = parseFloat(durationStr.replace("s", "")) * 1000;
    }

    // Parse stagger delay (handles "50ms", "0ms", etc.)
    const staggerStr = style.getPropertyValue("--product-stagger-delay").trim();
    const staggerDelay = parseInt(staggerStr.replace("ms", "")) || 0;

    // Parse grid entrance delay (mobile: 250ms, desktop: 0ms)
    const entranceDelayStr = style
      .getPropertyValue("--grid-entrance-delay")
      .trim();
    const entranceDelay = parseInt(entranceDelayStr.replace("ms", "")) || 0;

    return {
      duration: duration || 300,
      staggerDelay: staggerDelay,
      entranceDelay: entranceDelay,
    };
  }

  // Animation configuration
  let ANIMATION_CONFIG = getAnimationTiming();

  // Initial page load animations - animate first 16 cards immediately
  function initializePageLoadAnimations() {
    // Only animate first 16 cards on page load
    const cards = document.querySelectorAll(".product-card-wrapper.opacity-0");
    const initialCards = Array.from(cards).filter((card) => {
      const htmlCard = card as HTMLElement;
      const index = parseInt(htmlCard.dataset.initialIndex || "0");
      return htmlCard.style.display !== "none" && index < 16;
    });

    if (!initialCards.length) return;

    // Skip animations if reduced motion preferred
    if (prefersReducedMotion) {
      initialCards.forEach((card) => {
        const htmlCard = card as HTMLElement;
        htmlCard.classList.remove("opacity-0");
        htmlCard.classList.add("opacity-100");
      });
      return;
    }

    const cardsPerRow = getCardsPerRowCurrent();

    // Force a synchronous style recalculation before changing classes.
    // astro:page-load fires inside the view transition callback, meaning the DOM
    // swap and this class change could happen in the same rendering frame.
    // Without a forced reflow, the browser batches opacity-0 and opacity-100
    // together and skips the CSS transition. Reading offsetHeight forces the
    // browser to commit the current opacity:0 as the "before-change" value,
    // so the 0→1 transition fires correctly.
    void document.getElementById("filterable-product-grid")?.offsetHeight;

    initialCards.forEach((card) => {
      const htmlCard = card as HTMLElement;
      const index = parseInt(htmlCard.dataset.initialIndex || "0");
      const cardInRow = index % cardsPerRow;

      // Stagger within each row: each column offset by one stagger unit
      const animationOrder = cardInRow;

      // Set CSS custom property for animation delay
      htmlCard.style.setProperty(
        "--animation-order",
        animationOrder.toString(),
      );

      // Add animating class for temporary will-change
      htmlCard.classList.add("animating");

      // Trigger CSS animation immediately
      htmlCard.classList.remove("opacity-0");
      htmlCard.classList.add("opacity-100");

      // Remove will-change after animation completes
      const duration = ANIMATION_CONFIG.duration;
      const totalAnimationTime =
        duration + animationOrder * ANIMATION_CONFIG.staggerDelay;

      const timeout = setTimeout(() => {
        htmlCard.classList.remove("animating");
      }, totalAnimationTime);
      animationTimeouts.push(timeout);
    });
  }

  // SIMPLE: Initialize on page load using unified coordinator
  document.addEventListener("astro:page-load", () => {
    if (isInitialized) return;
    isInitialized = true;

    const grid = document.getElementById("filterable-product-grid");
    if (grid) {
      grid.style.opacity = "1";
    }

    // On mobile, defer card entrance until after the nav close animation (400ms)
    // has had a head start. Desktop entrance delay is 0ms (no-op timeout).
    const entranceDelay = ANIMATION_CONFIG.entranceDelay;
    if (entranceDelay > 0) {
      setTimeout(() => initializePageLoadAnimations(), entranceDelay);
    } else {
      initializePageLoadAnimations();
    }
    initializeInfiniteScroll();
  });

  // Fallback for non-Astro navigation
  document.addEventListener("DOMContentLoaded", () => {
    if (isInitialized) return;
    isInitialized = true;

    const grid = document.getElementById("filterable-product-grid");
    if (grid) {
      grid.style.opacity = "1";
    }

    initializePageLoadAnimations();
    initializeInfiniteScroll();
  });

  // BACK TO BASICS: Simple infinite scroll without complex logic
  function initializeInfiniteScroll() {
    const grid = document.getElementById("filterable-product-grid");
    const trigger = document.getElementById("infinite-scroll-trigger");

    if (!grid || !trigger) {
      return;
    }

    // Create ARIA live region for screen reader announcements
    liveRegion = document.createElement("div");
    liveRegion.setAttribute("role", "status");
    liveRegion.setAttribute("aria-live", "polite");
    liveRegion.setAttribute("aria-atomic", "true");
    liveRegion.className = "sr-only";
    liveRegion.style.position = "absolute";
    liveRegion.style.left = "-10000px";
    liveRegion.style.width = "1px";
    liveRegion.style.height = "1px";
    liveRegion.style.overflow = "hidden";
    document.body.appendChild(liveRegion);

    function announceToScreenReader(message: string) {
      if (liveRegion) {
        liveRegion.textContent = message;
        // Clear after announcement
        setTimeout(() => {
          if (liveRegion) liveRegion.textContent = "";
        }, 1000);
      }
    }

    const allCards = Array.from(grid.querySelectorAll(".product-card-wrapper"));
    // Only scroll-manage cards that aren't filter-hidden (those are handled by applyClientFilters)
    const scrollPool = allCards.filter(
      (c) => (c as HTMLElement).dataset.filterHidden !== "true",
    );

    // Progressive enhancement check
    const supportsIntersectionObserver = "IntersectionObserver" in window;
    const loadMoreContainer = document.getElementById("load-more-container");
    const loadMoreButton = document.getElementById("load-more-button");

    // Check if we should use accessible mode (no IntersectionObserver)
    // DEV ONLY: Support ?test-button=1 for testing button mode
    const urlParams = new URLSearchParams(window.location.search);
    const forceButtonMode = urlParams.has("test-button") && import.meta.env.DEV;
    const useAccessibleMode = !supportsIntersectionObserver || forceButtonMode;

    if (forceButtonMode) {
      // Button mode for testing
    }

    // Adaptive batch size calculation based on viewport
    function calculateAdaptiveBatchSize() {
      const viewportHeight = window.innerHeight;
      const viewportWidth = window.innerWidth;
      const minCardHeight = 280; // From CSS min-height
      const cardsPerRow = getCardsPerRowCurrent();

      // Calculate how many rows fit in viewport
      const visibleRows = Math.ceil(viewportHeight / minCardHeight);

      // Buffer: 1.5x viewport for smooth scrolling
      const bufferRows = Math.ceil(visibleRows * 1.5);
      const totalRows = visibleRows + bufferRows;

      // Calculate total items
      let batchSize = totalRows * cardsPerRow;

      // Apply device-specific constraints
      if (viewportWidth < 768) {
        // Mobile: CRITICAL LCP FIX - Reduce to 4 products for faster initial paint
        // This prevents network congestion and improves LCP from 11.3s to ~4.5s
        batchSize = 4;
      } else if (viewportWidth < 1440) {
        // Desktop: balanced approach
        batchSize = Math.max(Math.min(batchSize, 36), 18);
      } else {
        // Ultra-wide/4K: ensure scrollability cSpell:ignore scrollability
        batchSize = Math.max(Math.min(batchSize, 60), 30);
      }

      return batchSize;
    }

    const cardsPerRow = getCardsPerRowCurrent();

    // visibleCount must match what SSR showed (initialCardsToShow=16) so JS never
    // hides products that the server already rendered visible. The old approach of
    // using calculateAdaptiveBatchSize() (which returned 4 on mobile) caused a
    // layout collapse that registered as CLS 0.066 on every category page.
    // SSR is the source of truth for the initial visible set; adaptive sizing
    // only applies to subsequent loadMore batches.
    let visibleCount = 16; // matches initialCardsToShow constant in SSR

    // Create animation observer for both modes (infinite scroll and button)
    // MUST be created BEFORE checking if infinite scroll is needed
    cardAnimationObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const card = entry.target as HTMLElement;
            const index = parseInt(card.dataset.initialIndex || "0");

            // Skip animations if reduced motion preferred
            if (prefersReducedMotion) {
              card.classList.remove("opacity-0");
              card.classList.add("opacity-100");
              if (cardAnimationObserver) cardAnimationObserver.unobserve(card);
              return;
            }

            const cardsPerRow = getCardsPerRowCurrent();
            const cardInRow = index % cardsPerRow;
            const animationOrder = cardInRow;

            card.style.setProperty(
              "--animation-order",
              animationOrder.toString(),
            );
            card.classList.add("animating");
            card.classList.remove("opacity-0");
            card.classList.add("opacity-100");

            const duration = ANIMATION_CONFIG.duration;
            const totalAnimationTime =
              duration + animationOrder * ANIMATION_CONFIG.staggerDelay;

            const timeout = setTimeout(() => {
              card.classList.remove("animating");
            }, totalAnimationTime);
            animationTimeouts.push(timeout);

            if (cardAnimationObserver) cardAnimationObserver.unobserve(card);
          }
        });
      },
      { threshold: 0.1, rootMargin: "200px" },
    );

    // Add scroll-pool cards 16+ to observer
    scrollPool.forEach((card, index) => {
      if (index >= 16) {
        const htmlCard = card as HTMLElement;
        if (htmlCard.style.display !== "none" && cardAnimationObserver) {
          cardAnimationObserver.observe(htmlCard);
        }
      }
    });

    // Fallback for stuck cards
    const fallbackTimeout = setTimeout(() => {
      const stuckCards = document.querySelectorAll(
        ".product-card-wrapper.opacity-0",
      );
      stuckCards.forEach((card) => {
        const htmlCard = card as HTMLElement;
        if (htmlCard.style.display !== "none") {
          htmlCard.style.setProperty("--animation-order", "0");
          htmlCard.classList.remove("opacity-0");
          htmlCard.classList.add("opacity-100");
        }
      });
    }, 2000);
    animationTimeouts.push(fallbackTimeout);

    // Check if infinite scroll is needed
    if (scrollPool.length <= visibleCount) {
      trigger.style.display = "none";
      if (loadMoreContainer) loadMoreContainer.style.display = "none";
      return;
    }

    // Function to load more cards
    function loadMoreCards() {
      // Use fixed increment for infinite scroll (not adaptive)
      // Adaptive sizing is only for initial load
      const cardsToAdd = cardsPerRow * 2;
      const newVisibleCount = Math.min(
        visibleCount + cardsToAdd,
        scrollPool.length,
      );

      // Show the new cards
      for (let i = visibleCount; i < newVisibleCount; i++) {
        if (scrollPool[i]) {
          const card = scrollPool[i] as HTMLElement;
          card.style.display = "";
          card.classList.remove("opacity-100");
          card.classList.add("opacity-0");

          // Add to animation observer for smooth animations (both modes)
          if (cardAnimationObserver) {
            cardAnimationObserver.observe(card);
          } else {
            // Fallback immediate display
            card.classList.remove("opacity-0");
            card.classList.add("opacity-100");
          }
        }
      }

      visibleCount = newVisibleCount;

      // Announce to screen readers
      announceToScreenReader(
        `Loaded ${cardsToAdd} more products. ${visibleCount} of ${scrollPool.length} total products shown.`,
      );

      // Update grid aria-busy state
      if (grid) grid.setAttribute("aria-busy", "false");

      // Hide controls when done, or force re-evaluation if more remain
      if (visibleCount >= scrollPool.length) {
        if (trigger) trigger.style.display = "none";
        if (loadMoreContainer) loadMoreContainer.style.display = "none";
        announceToScreenReader(`All ${scrollPool.length} products loaded.`);
      } else if (loadMoreObserver && trigger) {
        // IntersectionObserver only fires on transitions. If the trigger stays
        // within the intersection zone after a batch loads (common when the batch
        // doesn't push the trigger far enough below the fold + rootMargin), the
        // observer never re-fires and the spinner hangs. Force re-evaluation by
        // temporarily unobserving and re-observing the trigger.
        loadMoreObserver.unobserve(trigger);
        requestAnimationFrame(() => {
          if (loadMoreObserver && trigger && visibleCount < allCards.length) {
            loadMoreObserver.observe(trigger);
          }
        });
      }
    }

    // Use Load More button for accessible mode
    if (useAccessibleMode) {
      if (loadMoreContainer && loadMoreButton) {
        loadMoreContainer.style.display = "flex";
        trigger.style.display = "none";

        loadMoreButton.addEventListener("click", () => {
          if (grid) grid.setAttribute("aria-busy", "true");
          loadMoreButton.textContent = "Loading...";
          loadMoreButton.setAttribute("disabled", "true");

          // Small delay to show loading state (track timeout)
          const buttonTimeout = setTimeout(() => {
            loadMoreCards();
            loadMoreButton.textContent = "Load More Products";
            loadMoreButton.removeAttribute("disabled");
          }, 100);
          animationTimeouts.push(buttonTimeout);
        });
      }
      return;
    }

    // Standard infinite scroll mode.
    // If SSR set visibility:hidden (products > 16), reveal via visibility — no layout shift
    // because the 80px space was already reserved. If SSR set display:none (≤16 products
    // but JS recalculated a smaller batch), fall back to display:flex.
    if (trigger.style.visibility === "hidden") {
      trigger.style.visibility = "visible";
    } else {
      trigger.style.display = "flex";
    }
    if (loadMoreContainer) loadMoreContainer.style.display = "none";

    // PHASE 5: Debounced load more to prevent rapid-fire loading
    let isLoading = false;
    let loadTimeout: ReturnType<typeof setTimeout> | null = null;

    // SIMPLE: Basic intersection observer for loading more cards
    loadMoreObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (
            entry.isIntersecting &&
            visibleCount < scrollPool.length &&
            !isLoading
          ) {
            // Debounce to prevent rapid loading
            if (loadTimeout) {
              clearTimeout(loadTimeout);
              const index = animationTimeouts.indexOf(loadTimeout);
              if (index > -1) animationTimeouts.splice(index, 1);
            }

            loadTimeout = setTimeout(() => {
              try {
                isLoading = true;
                if (grid) grid.setAttribute("aria-busy", "true");

                loadMoreCards();
              } finally {
                // Ensure isLoading gets reset even if loadMoreCards throws
                isLoading = false;
              }
            }, 100); // 100ms debounce delay
            animationTimeouts.push(loadTimeout);
          }
        });
      },
      { threshold: 0.1, rootMargin: "200px" },
    );

    if (loadMoreObserver && trigger) loadMoreObserver.observe(trigger);
  }

  // Debounced resize handler for responsive animations
  let resizeTimeout: ReturnType<typeof setTimeout>;
  function handleResize() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      // Recalculate animation config on resize
      const newConfig = getAnimationTiming();
      ANIMATION_CONFIG.staggerDelay = newConfig.staggerDelay;
      ANIMATION_CONFIG.duration = newConfig.duration;
    }, 250); // Debounce 250ms
  }

  window.addEventListener("resize", handleResize);

  // Store observers for cleanup
  let cardAnimationObserver: IntersectionObserver | null = null;
  let loadMoreObserver: IntersectionObserver | null = null;
  let liveRegion: HTMLElement | null = null;
  let animationTimeouts: ReturnType<typeof setTimeout>[] = [];
  let isInitialized = false;

  // ── Client-side filtering ───────────────────────────────────────────────────

  async function applyClientFilters(
    brands: string[],
    categorySlugs: string[],
    availability: boolean,
    onSale: boolean = false,
  ) {
    const grid = document.getElementById("filterable-product-grid");
    if (!grid) return;

    const allCards = Array.from(
      grid.querySelectorAll<HTMLElement>(".product-card-wrapper"),
    );
    const slugToId = JSON.parse(grid.dataset.slugToId || "{}") as Record<
      string,
      string
    >;
    const categoryIds = categorySlugs.map((s) => slugToId[s] ?? s);
    const hasFilters =
      brands.length > 0 || categorySlugs.length > 0 || availability || onSale;

    const trigger = document.getElementById("infinite-scroll-trigger");
    const loadMoreContainer = document.getElementById("load-more-container");

    // Disconnect load-more observer — filters bypass infinite scroll
    if (loadMoreObserver) {
      loadMoreObserver.disconnect();
      loadMoreObserver = null;
    }

    if (!hasFilters) {
      // Reset: clear filter-hidden markers, re-animate, re-init infinite scroll
      allCards.forEach((card) => {
        card.removeAttribute("data-filter-hidden");
        card.classList.remove("opacity-100");
        card.classList.add("opacity-0");
        card.style.display = "";
      });

      cleanupObserversAndTimeouts();
      isInitialized = false;

      if (trigger) trigger.style.display = "";
      if (loadMoreContainer) loadMoreContainer.style.display = "none";

      const noResults = document.getElementById("no-results");
      if (noResults) noResults.style.display = "none";

      initializeInfiniteScroll();
      initializePageLoadAnimations();

      window.dispatchEvent(
        new CustomEvent("filterresult", {
          detail: { count: allCards.length, total: allCards.length },
        }),
      );
      return;
    }

    // Classify cards
    const matchingCards: HTMLElement[] = [];
    const nonMatchingCards: HTMLElement[] = [];

    allCards.forEach((card) => {
      const cardBrand = card.dataset.brand || "";
      const cardCategories = JSON.parse(
        card.dataset.categories || "[]",
      ) as string[];
      const isOutOfStock = card.dataset.outOfStock === "true";
      const isOnSale = card.dataset.onSale === "true";

      let matches = true;
      if (brands.length > 0 && !brands.includes(cardBrand)) matches = false;
      if (
        categoryIds.length > 0 &&
        !categoryIds.some((id) => cardCategories.includes(id))
      )
        matches = false;
      if (availability && isOutOfStock) matches = false;
      if (onSale && !isOnSale) matches = false;

      if (matches) matchingCards.push(card);
      else nonMatchingCards.push(card);
    });

    // Mark filter-hidden state
    nonMatchingCards.forEach((c) =>
      c.setAttribute("data-filter-hidden", "true"),
    );
    matchingCards.forEach((c) => c.removeAttribute("data-filter-hidden"));

    // Filters bypass infinite scroll — hide trigger
    if (trigger) trigger.style.display = "none";
    if (loadMoreContainer) loadMoreContainer.style.display = "none";

    // Exit phase: fade out ALL currently visible cards simultaneously.
    // This includes matching cards that were already visible — they will
    // re-enter with the full stagger after the exit completes.
    const currentlyVisible = allCards.filter((c) => c.style.display !== "none");
    currentlyVisible.forEach((card) => {
      card.classList.add("animating");
      card.classList.remove("opacity-100");
      card.classList.add("opacity-0");
    });

    const exitDuration = prefersReducedMotion ? 0 : 150;
    await new Promise<void>((resolve) => setTimeout(resolve, exitDuration));

    // After exit: hide non-matching, reset animating class on all
    nonMatchingCards.forEach((card) => {
      card.style.display = "none";
    });
    currentlyVisible.forEach((card) => card.classList.remove("animating"));

    // Re-create animation observer for matching cards below the fold
    if (cardAnimationObserver) {
      cardAnimationObserver.disconnect();
      cardAnimationObserver = null;
    }
    cardAnimationObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const card = entry.target as HTMLElement;
            card.classList.remove("opacity-0");
            card.classList.add("opacity-100");
            card.classList.remove("animating");
            if (cardAnimationObserver) cardAnimationObserver.unobserve(card);
          }
        });
      },
      { threshold: 0.1, rootMargin: "200px" },
    );

    // Enter phase: ALL matching cards animate in with column-based stagger.
    // Every card is at opacity-0 at this point (either from the exit above,
    // or from being scroll/filter-hidden before this filter was applied).
    const cardsPerRow = getCardsPerRowCurrent();

    matchingCards.forEach((card, visibleIndex) => {
      card.style.display = "";
      const col = visibleIndex % cardsPerRow;
      card.style.setProperty("--animation-order", col.toString());
      card.classList.add("animating");

      const rect = card.getBoundingClientRect();
      const isNearFold = rect.top < window.innerHeight + 300;

      if (prefersReducedMotion || isNearFold) {
        card.classList.remove("opacity-0");
        card.classList.add("opacity-100");
        const totalTime =
          ANIMATION_CONFIG.duration + col * ANIMATION_CONFIG.staggerDelay;
        const t = setTimeout(
          () => card.classList.remove("animating"),
          totalTime,
        );
        animationTimeouts.push(t);
      } else {
        if (cardAnimationObserver) cardAnimationObserver.observe(card);
      }
    });

    // No results state
    const noResults = document.getElementById("no-results");
    if (noResults) {
      noResults.style.display = matchingCards.length === 0 ? "flex" : "none";
    }

    window.dispatchEvent(
      new CustomEvent("filterresult", {
        detail: { count: matchingCards.length, total: allCards.length },
      }),
    );
  }

  // ── Filter + history event listeners (registered once per script load) ──────

  window.addEventListener("filterchange", (e: Event) => {
    const evt = e as CustomEvent<{
      brands: string[];
      categories: string[];
      availability: boolean;
      onSale?: boolean;
    }>;
    applyClientFilters(
      evt.detail.brands,
      evt.detail.categories,
      evt.detail.availability,
      evt.detail.onSale ?? false,
    );
  });

  window.addEventListener("popstate", () => {
    const params = new URLSearchParams(window.location.search);
    const brands = params.getAll("brands");
    const categories = params.getAll("categories");
    const availability = params.get("availability") === "true";
    const onSale = params.get("onSale") === "true";
    window.dispatchEvent(
      new CustomEvent("filterchange", {
        detail: { brands, categories, availability, onSale },
      }),
    );
  });

  function cleanupObserversAndTimeouts() {
    // Clean up observers to prevent memory leaks
    if (cardAnimationObserver) {
      cardAnimationObserver.disconnect();
      cardAnimationObserver = null;
    }
    if (loadMoreObserver) {
      loadMoreObserver.disconnect();
      loadMoreObserver = null;
    }

    // Clear all pending timeouts
    animationTimeouts.forEach((timeout) => clearTimeout(timeout));
    animationTimeouts = [];
  }

  // Cleanup on navigation
  document.addEventListener("astro:before-swap", () => {
    window.removeEventListener("resize", handleResize);
    clearTimeout(resizeTimeout);

    cleanupObserversAndTimeouts();

    // Clean up live region
    if (liveRegion && liveRegion.parentNode) {
      liveRegion.parentNode.removeChild(liveRegion);
      liveRegion = null;
    }

    // Reset initialization flag
    isInitialized = false;
  });

  // Handle page visibility changes to prevent stale animations
  // Only runs after extended idle periods (5+ minutes)
  let hiddenTime = 0;
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      // Track when page was hidden
      hiddenTime = Date.now();
    } else {
      // Page is visible again - only reset if hidden for more than 5 minutes
      const idleDuration = Date.now() - hiddenTime;
      if (hiddenTime > 0 && idleDuration > 300000 && isInitialized) {
        // 5 minutes
        cleanupObserversAndTimeouts();
        isInitialized = false;

        // Reinitialize animations with fresh state
        const grid = document.getElementById("filterable-product-grid");
        if (grid) {
          initializePageLoadAnimations();
          initializeInfiniteScroll();
        }
      }
    }
  });

  // Handle page show event (back/forward cache)
  window.addEventListener("pageshow", (event) => {
    if (event.persisted && isInitialized) {
      // Page loaded from bfcache - reset everything cSpell:ignore bfcache
      cleanupObserversAndTimeouts();
      isInitialized = false;

      const grid = document.getElementById("filterable-product-grid");
      if (grid) {
        initializePageLoadAnimations();
        initializeInfiniteScroll();
      }
    }
  });
</script>
