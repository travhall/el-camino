---
// src/components/CartFooter.astro
// Minimal footer for the cart/checkout funnel — no address, social, or logo.
// Keeps the user focused on completing their purchase.
import ThemeToggle from "./ThemeToggle.astro";
import { getLegalPages } from "@/lib/wordpress/api";
import type { WordPressPage } from "@/lib/wordpress/types";
import { siteConfig } from "@/lib/site-config";

const currentYear = new Date().getFullYear();

let footerPages: WordPressPage[] = [];
try {
    footerPages = await getLegalPages();
} catch {
    // Silently skip legal links if WordPress is unavailable
}
---

<!-- Pre-fetched legal pages for the policy modal — read by showPolicyModal() -->
<script
    id="legal-pages-data"
    type="application/json"
    set:html={JSON.stringify(
        footerPages.map((p) => ({
            slug: p.slug,
            title: p.title,
            content: p.content,
        })),
    )}
/>

<footer
    class="p-4 pb-40 md:pb-4 w-full bg-(--surface-secondary) border-4 border-(--border-secondary) border-t-0 z-0"
>
    <div
        class="flex flex-col-reverse md:flex-row justify-between items-center gap-4 py-2"
    >
        <div
            class="flex flex-col-reverse md:flex-row gap-4 md:gap-6 items-center w-full"
        >
            <small class="block text-sm self-start md:self-auto">
                &copy;{currentYear}
                {siteConfig.name}, all rights reserved
            </small>
            {
                footerPages.map((page) => (
                    <button
                        type="button"
                        data-policy-slug={page.slug}
                        class="policy-modal-trigger text-sm font-semibold self-start md:self-auto relative text-(--content-heading) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all cursor-pointer"
                    >
                        {page.title.rendered}
                    </button>
                ))
            }
        </div>
        <div class="self-end -mb-10 md:mb-0">
            <ThemeToggle />
        </div>
    </div>
</footer>

<script>
    function setupPolicyTriggers() {
        document
            .querySelectorAll<HTMLButtonElement>(".policy-modal-trigger")
            .forEach((btn) => {
                if (btn.getAttribute("data-policy-initialized") === "true")
                    return;
                btn.setAttribute("data-policy-initialized", "true");
                btn.addEventListener("click", () => {
                    const slug = btn.dataset.policySlug;
                    if (slug && typeof window.showPolicyModal === "function") {
                        window.showPolicyModal(slug);
                    }
                });
            });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupPolicyTriggers);
    } else {
        setupPolicyTriggers();
    }

    document.addEventListener("astro:page-load", setupPolicyTriggers);
</script>
