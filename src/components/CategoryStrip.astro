---
// src/components/CategoryStrip.astro
// Horizontal filmstrip — top-tier categories followed by their subcategories.
// Flattens the full hierarchy so the strip has enough cards to earn horizontal scroll.
// Image fetching covers both tiers (same Square CDN pattern as Sidebar.astro).
import { fetchCategoryHierarchyWithProducts } from "@/lib/square/categoryUtils";
import { squareClient } from "@/lib/square/client";
import {
  EL_CAMINO_LOGO_DATA_URI,
  EL_CAMINO_LOADER_DATA_URI,
} from "@/lib/constants/assets";
import { Icon } from "astro-icon/components";
import { toNetlifyImageCDN } from "@/lib/image/enhanced-optimizer";

interface Props {
  title?: string;
}

const { title = "Shop by Category" } = Astro.props;

// Full hierarchy, already filtered to categories that have products
const hierarchy = await fetchCategoryHierarchyWithProducts();

// Flatten: each top-tier category followed immediately by its subcategories.
// parentName is set on subcategory entries so the card can show the family label.
interface FlatCategory {
  id: string;
  name: string;
  url: string;
  parentName?: string;
}

const flatCategories: FlatCategory[] = [];

for (const item of hierarchy) {
  flatCategories.push({
    id: item.category.id,
    name: item.category.name,
    url: `/category/${item.category.slug}`,
    parentName: undefined,
  });
  for (const sub of item.subcategories) {
    flatCategories.push({
      id: sub.id,
      name: sub.name,
      url: `/category/${sub.slug}`,
      parentName: item.category.name,
    });
  }
}

// Fetch Square CDN image URLs for every entry — top-tier and sub alike.
// Sequential loop matches Sidebar.astro; the cache absorbs repeat calls
// if Sidebar has already resolved the same IDs in this request.
const categoryImageUrls: Record<string, string> = {};

for (const cat of flatCategories) {
  if (!cat.id) continue;
  try {
    const { result } = await squareClient.catalogApi.retrieveCatalogObject(
      cat.id,
      true,
    );
    const imageObjects = (result.relatedObjects ?? []).filter(
      (obj) => obj.type === "IMAGE",
    );
    if (imageObjects.length > 0 && imageObjects[0].imageData?.url) {
      categoryImageUrls[cat.id] = imageObjects[0].imageData.url;
    }
  } catch {
    // fail silently — card falls back to logo placeholder
  }
}

---

<section class="py-8 bg-(--surface-primary)">
  <!-- Header -->
  <div class="flex items-end justify-between mb-6 lg:mb-8 px-4 sm:px-6 lg:px-8">
    <div>
      <p class="text-xs uppercase tracking-widest text-(--content-meta)">
        What We Carry
      </p>
      <h2
        class="text-2xl lg:text-3xl font-display font-bold text-(--content-heading) leading-none"
      >
        {title}
      </h2>
    </div>
  </div>

  <!-- Horizontal filmstrip -->
  <div
    class="overflow-x-auto pb-4 scrollbar-hide"
    role="region"
    aria-label="Shop categories"
  >
    <div class="flex gap-3 lg:gap-4 px-4 sm:px-6 lg:px-8">
      {
        flatCategories.map((cat, index) => {
          const rawImageUrl = categoryImageUrls[cat.id] ?? "";
          const imageUrl = rawImageUrl ? toNetlifyImageCDN(rawImageUrl, 600, { height: 600 }) : "";
          const placeholderId = `cat-strip-placeholder-${cat.id}`;
          const isSubcategory = !!cat.parentName;

          return (
            <a
              href={cat.url}
              data-astro-prefetch="viewport"
              class:list={[
                "group relative flex-none overflow-hidden rounded-sm bg-(--surface-primary) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--content-link)",
                // Subcategory cards are narrower — creates a natural visual rhythm
                // and echoes the brand/product hierarchy in RelatedProducts
                isSubcategory ? "w-36 sm:w-44 lg:w-52" : "w-44 sm:w-52 lg:w-60",
              ]}
            >
              {/* Image — relative container keeps skeleton within bounds */}
              <div class="relative aspect-square overflow-hidden">
                {imageUrl && (
                  <div
                    class="loading-skeleton loading-image absolute inset-0 w-full h-full"
                    id={placeholderId}
                    aria-hidden="true"
                  >
                    <div
                      class="absolute inset-0 flex items-center justify-center"
                      style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat; opacity: 0.7;`}
                    />
                  </div>
                )}

                {imageUrl ? (
                  <img
                    src={imageUrl}
                    alt=""
                    aria-hidden="true"
                    class="w-full h-full object-cover opacity-0 transition-all duration-500 group-hover:scale-105"
                    loading={index < 4 ? "eager" : "lazy"}
                    width="600"
                    height="600"
                    onload={`this.style.opacity='1'; document.getElementById('${placeholderId}')?.remove()`}
                    onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; this.style.opacity='0.3'; this.classList.remove('object-cover'); this.classList.add('object-contain','p-8'); document.getElementById('${placeholderId}')?.remove()`}
                  />
                ) : (
                  <img
                    src={EL_CAMINO_LOGO_DATA_URI}
                    alt=""
                    aria-hidden="true"
                    class="w-full h-full object-contain opacity-20"
                    loading={index < 4 ? "eager" : "lazy"}
                    width="600"
                    height="600"
                  />
                )}
              </div>

              {/* Gradient overlay */}
              <div class="absolute inset-0 bg-linear-to-t from-black/85 via-black/20 to-transparent group-hover:from-black/90 transition-all duration-200" />

              {/* Text — parent label above name mirrors RelatedProducts brand/title pattern */}
              <div class="absolute inset-x-0 bottom-0 p-3 lg:p-4">
                {cat.parentName && (
                  <p class="text-xs uppercase tracking-widest font-bold text-white/60 mb-1 leading-none truncate">
                    {cat.parentName}
                  </p>
                )}
                <p class="text-xl lg:text-2xl font-display font-bold text-white leading-tight group-hover:text-(--color-elco-sweet-tea-300) transition-colors duration-200 line-clamp-2">
                  {cat.name}
                </p>
              </div>
            </a>
          );
        })
      }

      <!-- "See all" terminal card -->
      <a
        href="/shop/all"
        class="group relative flex-none w-32 sm:w-36 overflow-hidden rounded-sm bg-(--surface-primary) border-2 border-(--border-primary) hover:border-(--color-elco-sweet-tea-300) transition-colors duration-200 flex flex-col items-center justify-center gap-3 p-4 text-center focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--content-link)"
        aria-label="See all categories"
      >
        <Icon
          name="uil:arrow-right"
          class="w-8 h-8 text-(--content-meta) group-hover:text-(--color-elco-sweet-tea-400) transition-colors"
          aria-hidden="true"
        />
        <p
          class="text-xs font-bold uppercase tracking-widest text-(--content-meta) group-hover:text-(--content-heading) transition-colors leading-snug"
        >
          All Categories
        </p>
      </a>
    </div>
  </div>
</section>
