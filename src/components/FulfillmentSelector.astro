---
import { Icon } from "astro-icon/components";
import {
  FREE_SHIPPING_THRESHOLD_DOLLARS,
  FLAT_RATE_SHIPPING_DOLLARS,
} from "@/lib/config/shipping";

interface Props {
  subtotal: number;
  hasGiftCard?: boolean;
}

const { subtotal, hasGiftCard = false } = Astro.props;

const FREE_SHIPPING_THRESHOLD = Math.round(
  FREE_SHIPPING_THRESHOLD_DOLLARS * 100,
);
const FLAT_RATE_SHIPPING = Math.round(FLAT_RATE_SHIPPING_DOLLARS * 100);

function formatMoney(cents: number): string {
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
  }).format(cents / 100);
}

const subtotalCents = Math.round(subtotal * 100);
const shippingLabel =
  subtotalCents >= FREE_SHIPPING_THRESHOLD
    ? "FREE"
    : formatMoney(FLAT_RATE_SHIPPING);
const remainingForFree =
  subtotalCents < FREE_SHIPPING_THRESHOLD
    ? FREE_SHIPPING_THRESHOLD - subtotalCents
    : 0;
const progressPct = Math.min(
  (subtotalCents / FREE_SHIPPING_THRESHOLD) * 100,
  100,
);
---

<div data-component="fulfillment-selector">
  <fieldset class="min-w-0 w-full">
    <legend class="sr-only">Choose Fulfillment Method</legend>

    <!-- Summary chip: shown after collapse, hidden by default -->
    <div
      id="fulfillment-summary-chip"
      class="hidden mb-3 items-center justify-between border border-(--border-primary) bg-(--surface-primary) px-4 py-3"
      role="status"
      aria-live="polite"
    >
      <div class="flex flex-col gap-0.5 min-w-0 pr-3">
        <span
          id="fulfillment-summary-label"
          class="text-sm font-semibold text-(--content-heading)"></span>
        <span
          id="fulfillment-summary-detail"
          class="text-sm text-(--content-meta) truncate"></span>
      </div>
      <button
        id="fulfillment-expand-btn"
        type="button"
        class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded border-2 border-(--surface-tertiary) text-(--content-body) hover:bg-(--surface-secondary) transition-all cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-expanded="false"
        aria-controls="fulfillment-form-panel"
      >
        Edit
      </button>
    </div>

    <!-- Hidden radio inputs -->
    <input
      type="radio"
      name="fulfillment"
      id="fulfillment-shipping"
      value="shipping"
      class="sr-only"
    />
    <input
      type="radio"
      name="fulfillment"
      id="fulfillment-pickup"
      value="pickup"
      class="sr-only"
    />

    <!-- Tab row -->
    <div
      id="fulfillment-tab-row"
      class="grid grid-cols-2 gap-1 p-1 bg-(--surface-secondary)"
    >
      <button
        type="button"
        data-tab="shipping"
        class="tab-btn flex flex-row items-center justify-center gap-2 rounded px-4 py-3 text-sm font-semibold text-(--content-meta) border-2 border-(--surface-tertiary) hover:bg-(--surface-tertiary) hover:text-(--content-body) cursor-pointer transition-all ease-in-out duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-pressed="false"
      >
        <Icon name="uil:ship" class="w-5 h-5 shrink-0" />
        <span>Ship to Me</span>
        <span class="text-xs font-normal opacity-75" data-shipping-cost-label
          >{shippingLabel}</span
        >
      </button>

      <button
        type="button"
        data-tab="pickup"
        class="tab-btn flex flex-row items-center justify-center gap-2 rounded px-4 py-3 text-sm font-semibold text-(--content-meta) border-2 border-(--surface-tertiary) hover:bg-(--surface-tertiary) hover:text-(--content-body) cursor-pointer transition-all ease-in-out duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-pressed="false"
      >
        <Icon name="uil:store" class="w-5 h-5 shrink-0" />
        <span>Store Pick Up</span>
        <span class="text-xs font-normal opacity-75">FREE</span>
      </button>
    </div>

    <!-- Free shipping progress tracker (hidden until shipping tab is active) -->
    <div
      id="free-shipping-tracker"
      class="hidden px-4 py-3 text-sm font-medium text-(--content-body)"
      style="background-color: var(--free-shipping-bar-bg);"
    >
      <div class="flex items-center justify-between">
        <div>
          Add{" "}
          <span
            id="free-shipping-remaining"
            class="font-bold text-(--content-heading)"
            >{formatMoney(remainingForFree)}</span
          >{" "}
          more for free shipping!
        </div>
        <a
          href="/shop/all"
          class="self-end font-sans font-semibold text-xs lg:text-sm focus-visible:ring-2 outline-0 focus-visible:ring-offset-2 focus-visible:ring-offset-(--surface-primary) inline-flex items-center justify-center py-1 px-2 text-(--content-emphasis) bg-none border-none focus-visible:ring-(--ui-button-ring) underline underline-offset-1 decoration-(--content-emphasis)/0 hover:decoration-(--content-emphasis)/80 hover:underline-offset-4 transition-all ease-in-out duration-300"
          >Continue Shopping</a
        >
      </div>
      <div
        class="mt-2 h-3 w-full rounded-full"
        style="background-color: var(--free-shipping-bar-track);"
      >
        <div
          id="free-shipping-progress"
          class="h-3 rounded-full transition-all"
          style={`width: ${progressPct}%; background-color: var(--free-shipping-bar);`}
        >
        </div>
      </div>
    </div>
    <div
      id="free-shipping-earned"
      class="hidden px-4 py-3 text-sm font-medium text-(--content-heading)"
      style="background-color: var(--free-shipping-bar-bg);"
    >
      <div class="flex items-center gap-1">
        <Icon name="uil:check-circle" class="w-5 h-5 shrink-0" />
        You've earned free shipping!
      </div>
    </div>

    <!-- Form panel -->
    <div
      id="fulfillment-form-panel"
      class="hidden space-y-5 border-4 border-t-0 border-(--border-primary) p-4 lg:p-8 xl:px-12"
    >
      <!-- Shipping form -->
      <div data-shipping-form class="hidden space-y-5">
        {
          hasGiftCard && (
            <p
              id="gift-card-shipping-disclaimer"
              class="text-xs text-(--content-meta) border border-(--border-primary) border-t-0 bg-(--surface-secondary) px-3 py-2 rounded-sm italic"
            >
              Physical gift cards are shipped at your own risk. El Camino is not
              responsible for cards lost or stolen in transit. Consider picking
              up in-store for guaranteed delivery.
            </p>
          )
        }
        {
          !hasGiftCard && (
            <p
              id="gift-card-shipping-disclaimer"
              class="hidden text-xs text-(--content-meta) border border-(--border-primary) border-t-0 bg-(--surface-secondary) px-3 py-2 rounded-sm italic"
            >
              Physical gift cards are shipped at your own risk. El Camino is not
              responsible for cards lost or stolen in transit. Consider picking
              up in-store for guaranteed delivery.
            </p>
          )
        }

        <div class="grid grid-cols-2 gap-x-4 gap-y-5">
          <div class="elco-field-float col-span-2 sm:col-span-1">
            <input
              type="text"
              id="shipping-first-name"
              name="shipping-first-name"
              autocomplete="given-name"
              placeholder=" "
            />
            <label for="shipping-first-name"
              >First Name <em class="text-(--content-emphasis)">— required</em
              ></label
            >
          </div>
          <div class="elco-field-float col-span-2 sm:col-span-1">
            <input
              type="text"
              id="shipping-last-name"
              name="shipping-last-name"
              autocomplete="family-name"
              placeholder=" "
            />
            <label for="shipping-last-name"
              >Last Name <em class="text-(--content-emphasis)">— required</em
              ></label
            >
          </div>
          <div class="elco-field-float col-span-2 sm:col-span-1">
            <input
              type="email"
              id="shipping-email"
              name="shipping-email"
              autocomplete="email"
              placeholder=" "
            />
            <label for="shipping-email"
              >Email <em class="text-(--content-emphasis)">— required</em
              ></label
            >
          </div>
          <div class="elco-field-float col-span-2 sm:col-span-1">
            <input
              type="tel"
              id="shipping-phone"
              name="shipping-phone"
              autocomplete="tel"
              maxlength="14"
              pattern={"\\(\\d{3}\\) \\d{3}-\\d{4}"}
              inputmode="numeric"
              placeholder=" "
            />
            <label for="shipping-phone"
              >Phone <em class="text-(--content-emphasis)">— required</em
              ></label
            >
          </div>
          <div class="elco-field-float col-span-2">
            <input
              type="text"
              id="shipping-address"
              name="shipping-address"
              autocomplete="street-address"
              placeholder=" "
            />
            <label for="shipping-address"
              >Street Address <em class="text-(--content-emphasis)"
                >— required</em
              ></label
            >
          </div>
          <div class="elco-field-float col-span-2">
            <input
              type="text"
              id="shipping-address2"
              name="shipping-address2"
              autocomplete="address-line2"
              placeholder=" "
            />
            <label for="shipping-address2"
              >Apt, Suite, Unit <em class="text-(--content-emphasis)"
                >— optional</em
              ></label
            >
          </div>
        </div>

        <div class="grid grid-cols-6 gap-x-4 gap-y-5">
          <div class="elco-field-float col-span-3">
            <input
              type="text"
              id="shipping-city"
              name="shipping-city"
              autocomplete="address-level2"
              placeholder=" "
            />
            <label for="shipping-city"
              >City <em class="text-(--content-emphasis)">— required</em></label
            >
          </div>
          <div class="elco-field-float col-span-1">
            <select
              id="shipping-state"
              name="shipping-state"
              autocomplete="address-level1"
            >
              <option value=""></option>
              <option value="AL">AL</option>
              <option value="AK">AK</option>
              <option value="AZ">AZ</option>
              <option value="AR">AR</option>
              <option value="CA">CA</option>
              <option value="CO">CO</option>
              <option value="CT">CT</option>
              <option value="DE">DE</option>
              <option value="FL">FL</option>
              <option value="GA">GA</option>
              <option value="HI">HI</option>
              <option value="ID">ID</option>
              <option value="IL">IL</option>
              <option value="IN">IN</option>
              <option value="IA">IA</option>
              <option value="KS">KS</option>
              <option value="KY">KY</option>
              <option value="LA">LA</option>
              <option value="ME">ME</option>
              <option value="MD">MD</option>
              <option value="MA">MA</option>
              <option value="MI">MI</option>
              <option value="MN">MN</option>
              <option value="MS">MS</option>
              <option value="MO">MO</option>
              <option value="MT">MT</option>
              <option value="NE">NE</option>
              <option value="NV">NV</option>
              <option value="NH">NH</option>
              <option value="NJ">NJ</option>
              <option value="NM">NM</option>
              <option value="NY">NY</option>
              <option value="NC">NC</option>
              <option value="ND">ND</option>
              <option value="OH">OH</option>
              <option value="OK">OK</option>
              <option value="OR">OR</option>
              <option value="PA">PA</option>
              <option value="RI">RI</option>
              <option value="SC">SC</option>
              <option value="SD">SD</option>
              <option value="TN">TN</option>
              <option value="TX">TX</option>
              <option value="UT">UT</option>
              <option value="VT">VT</option>
              <option value="VA">VA</option>
              <option value="WA">WA</option>
              <option value="WV">WV</option>
              <option value="WI">WI</option>
              <option value="WY">WY</option>
            </select>
            <label for="shipping-state"
              >State <em class="text-(--content-emphasis)">— required</em
              ></label
            >
          </div>
          <div class="elco-field-float col-span-2">
            <input
              type="text"
              id="shipping-zip"
              name="shipping-zip"
              autocomplete="postal-code"
              inputmode="numeric"
              maxlength="5"
              pattern="[0-9]{5}"
              placeholder=" "
            />
            <label for="shipping-zip"
              >ZIP <em class="text-(--content-emphasis)">— required</em></label
            >
          </div>
        </div>

        <div class="elco-field-float">
          <textarea
            id="shipping-instructions"
            name="shipping-instructions"
            rows="2"
            placeholder=" "></textarea>
          <label for="shipping-instructions"
            >Delivery instructions <em class="text-(--content-emphasis)"
              >— optional</em
            ></label
          >
        </div>
      </div>

      <!-- Pick up form -->
      <div data-pickup-form class="hidden space-y-5">
        <p class="text-sm text-(--content-meta)">
          Pick up your order at <strong>El Camino Skate Shop</strong> — we'll email
          you when it's ready.
        </p>

        <div class="elco-field-float">
          <input
            type="text"
            id="pickup-name"
            name="pickup-name"
            autocomplete="name"
            placeholder=" "
          />
          <label for="pickup-name"
            >Full Name <em class="text-(--content-emphasis)">— required</em
            ></label
          >
        </div>

        <div class="elco-field-float">
          <input
            type="email"
            id="pickup-email"
            name="pickup-email"
            autocomplete="email"
            placeholder=" "
          />
          <label for="pickup-email"
            >Email <em class="text-(--content-emphasis)">— required</em></label
          >
        </div>

        <div class="elco-field-float">
          <input
            type="tel"
            id="pickup-phone"
            name="pickup-phone"
            autocomplete="tel"
            maxlength="14"
            pattern={"\\(\\d{3}\\) \\d{3}-\\d{4}"}
            inputmode="numeric"
            placeholder=" "
          />
          <label for="pickup-phone"
            >Phone <em class="text-(--content-emphasis)">— required</em></label
          >
        </div>

        <div class="elco-field-float">
          <textarea
            id="pickup-notes"
            name="pickup-notes"
            rows="2"
            placeholder=" "></textarea>
          <label for="pickup-notes"
            >Pick up notes <em class="text-(--content-emphasis)">— optional</em
            ></label
          >
        </div>
      </div>

      <!-- Confirm button: shown after a method is selected -->
      <button
        id="fulfillment-done-btn"
        type="button"
        class="hidden w-full mt-4 py-3 px-4 text-sm font-semibold rounded-sm text-(--ui-button-text) bg-(--ui-button-surface) border-2 border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 transition-all cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-label="Confirm fulfillment method and save details"
      >
        Confirm
      </button>
    </div>
  </fieldset>
</div>

<script>
  import { cart } from "@/lib/cart";
  import { initFloatSelects } from "@/lib/ui/floatFields";

  const FREE_SHIPPING_THRESHOLD = 75;
  const FLAT_RATE_SHIPPING = 5.99;

  declare global {
    interface Window {
      updateOrderSummaryOnFulfillmentChange?: (
        method: string,
        formData: Record<string, string>,
        formIsValid: boolean,
        shouldRecalculate?: boolean,
      ) => void;
      elco_expandFulfillmentForm?: () => void;
    }
  }

  function initFulfillmentSelector() {
    const selector = document.querySelector(
      '[data-component="fulfillment-selector"]',
    );
    if (!selector) return;

    const shippingRadio = selector.querySelector<HTMLInputElement>(
      "#fulfillment-shipping",
    );
    const pickupRadio = selector.querySelector<HTMLInputElement>(
      "#fulfillment-pickup",
    );
    const formPanel = selector.querySelector<HTMLElement>(
      "#fulfillment-form-panel",
    );
    const shippingForm = selector.querySelector<HTMLElement>(
      "[data-shipping-form]",
    );
    const pickupForm =
      selector.querySelector<HTMLElement>("[data-pickup-form]");
    const tabs = selector.querySelectorAll<HTMLButtonElement>("[data-tab]");
    const summaryChip = selector.querySelector<HTMLElement>(
      "#fulfillment-summary-chip",
    );
    const summaryLabel = selector.querySelector<HTMLElement>(
      "#fulfillment-summary-label",
    );
    const summaryDetail = selector.querySelector<HTMLElement>(
      "#fulfillment-summary-detail",
    );
    const expandBtn = selector.querySelector<HTMLButtonElement>(
      "#fulfillment-expand-btn",
    );
    const doneBtn = selector.querySelector<HTMLButtonElement>(
      "#fulfillment-done-btn",
    );
    const tabRow = selector.querySelector<HTMLElement>("#fulfillment-tab-row");

    function getSummaryLabel(method: "shipping" | "pickup"): string {
      if (method === "shipping") {
        const costLabel = selector?.querySelector<HTMLElement>(
          "[data-shipping-cost-label]",
        );
        const cost = costLabel?.textContent?.trim() || "$5.99";
        return `Ship to Me — ${cost}`;
      }
      return "Store Pick Up — FREE";
    }

    function collapseForm(method: "shipping" | "pickup") {
      formPanel?.classList.add("hidden");
      formPanel?.setAttribute("aria-hidden", "true");
      tabRow?.classList.add("hidden");
      doneBtn?.classList.add("hidden");
      selector
        ?.querySelector<HTMLElement>("#free-shipping-tracker")
        ?.classList.add("hidden");
      selector
        ?.querySelector<HTMLElement>("#free-shipping-earned")
        ?.classList.add("hidden");
      if (summaryLabel) summaryLabel.textContent = getSummaryLabel(method);

      if (summaryDetail) {
        if (method === "shipping") {
          const firstName =
            (document.getElementById("shipping-first-name") as HTMLInputElement)
              ?.value ?? "";
          const lastName =
            (document.getElementById("shipping-last-name") as HTMLInputElement)
              ?.value ?? "";
          const address =
            (document.getElementById("shipping-address") as HTMLInputElement)
              ?.value ?? "";
          const address2 =
            (document.getElementById("shipping-address2") as HTMLInputElement)
              ?.value ?? "";
          const city =
            (document.getElementById("shipping-city") as HTMLInputElement)
              ?.value ?? "";
          const state =
            (document.getElementById("shipping-state") as HTMLSelectElement)
              ?.value ?? "";
          const zip =
            (document.getElementById("shipping-zip") as HTMLInputElement)
              ?.value ?? "";
          const name = [firstName, lastName].filter(Boolean).join(" ");
          const street = [address, address2].filter(Boolean).join(", ");
          const cityLine = [city, state, zip].filter(Boolean).join(" ");
          summaryDetail.textContent = [
            name,
            [street, cityLine].filter(Boolean).join(", "),
          ]
            .filter(Boolean)
            .join(" · ");
        } else {
          const name =
            (document.getElementById("pickup-name") as HTMLInputElement)
              ?.value ?? "";
          const email =
            (document.getElementById("pickup-email") as HTMLInputElement)
              ?.value ?? "";
          summaryDetail.textContent = [name, email].filter(Boolean).join(" · ");
        }
      }

      summaryChip?.classList.remove("hidden");
      summaryChip?.classList.add("flex");
      expandBtn?.setAttribute("aria-expanded", "false");

      if (typeof window.updateOrderSummaryOnFulfillmentChange === "function") {
        window.updateOrderSummaryOnFulfillmentChange(
          method,
          getFormData(method),
          true,
          true,
        );
      }
    }

    function expandForm() {
      formPanel?.classList.remove("hidden");
      formPanel?.removeAttribute("aria-hidden");
      tabRow?.classList.remove("hidden");
      summaryChip?.classList.add("hidden");
      summaryChip?.classList.remove("flex");
      expandBtn?.setAttribute("aria-expanded", "true");
      const checkedRadio = selector?.querySelector<HTMLInputElement>(
        'input[name="fulfillment"]:checked',
      );
      if (checkedRadio) doneBtn?.classList.remove("hidden");

      // Restore free shipping tracker if shipping is the active method
      // (collapseForm hides it; expandForm must bring it back)
      updateFreeShippingTracker(cart.getTotal());

      // Notify cart that form is now open/unconfirmed — disable CTA
      if (
        checkedRadio &&
        typeof window.updateOrderSummaryOnFulfillmentChange === "function"
      ) {
        const m = checkedRadio.value as "shipping" | "pickup";
        window.updateOrderSummaryOnFulfillmentChange(
          m,
          getFormData(m),
          false,
          false,
        );
      }
    }

    // Expose expandForm so cart.astro can call it when "Edit" is clicked from Step 2
    window.elco_expandFulfillmentForm = expandForm;

    function getFormData(
      method: "shipping" | "pickup",
    ): Record<string, string> {
      const form = method === "shipping" ? shippingForm : pickupForm;
      const data: Record<string, string> = { method };
      form
        ?.querySelectorAll<
          HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
        >("input, select, textarea")
        .forEach((el) => {
          if (el.id) data[el.id] = el.value;
        });
      return data;
    }

    function saveForm(confirmed = false) {
      const checkedRadio = selector?.querySelector<HTMLInputElement>(
        'input[name="fulfillment"]:checked',
      );
      if (!checkedRadio) return;
      const method = checkedRadio.value as "shipping" | "pickup";
      const data = getFormData(method);
      data._method = method;
      data._confirmed = String(confirmed);
      sessionStorage.setItem("fulfillment-form", JSON.stringify(data));
    }

    function checkFormValidity(method: "shipping" | "pickup"): boolean {
      const form = method === "shipping" ? shippingForm : pickupForm;
      const requiredFields = form?.querySelectorAll<
        HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
      >("[required]");
      if (!requiredFields || requiredFields.length === 0) return false;
      let allValid = true;
      requiredFields.forEach((field) => {
        if (!field.validity.valid) allValid = false;
      });
      return allValid;
    }

    function notifyValidity() {
      const checkedRadio = selector?.querySelector<HTMLInputElement>(
        'input[name="fulfillment"]:checked',
      );
      if (!checkedRadio) return;
      const m = checkedRadio.value as "shipping" | "pickup";
      if (typeof window.updateOrderSummaryOnFulfillmentChange === "function") {
        // Form panel is open — keep CTA disabled; only collapseForm() enables it
        window.updateOrderSummaryOnFulfillmentChange(
          m,
          getFormData(m),
          false,
          false,
        );
      }
    }

    function setRequiredFields(method: "shipping" | "pickup") {
      selector
        ?.querySelectorAll<
          HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
        >("[data-shipping-form] input, [data-shipping-form] select, [data-pickup-form] input")
        .forEach((el) => el.removeAttribute("required"));

      if (method === "shipping") {
        [
          "shipping-first-name",
          "shipping-last-name",
          "shipping-email",
          "shipping-phone",
          "shipping-address",
          "shipping-city",
          "shipping-state",
          "shipping-zip",
        ].forEach((id) => {
          selector?.querySelector(`#${id}`)?.setAttribute("required", "");
        });
      } else {
        ["pickup-name", "pickup-email", "pickup-phone"].forEach((id) => {
          selector?.querySelector(`#${id}`)?.setAttribute("required", "");
        });
      }
    }

    function updateFreeShippingTracker(subtotal: number) {
      const tracker = selector?.querySelector<HTMLElement>(
        "#free-shipping-tracker",
      );
      const remaining = selector?.querySelector<HTMLElement>(
        "#free-shipping-remaining",
      );
      const progress = selector?.querySelector<HTMLElement>(
        "#free-shipping-progress",
      );
      const earned = selector?.querySelector<HTMLElement>(
        "#free-shipping-earned",
      );
      const costLabel = selector?.querySelector<HTMLElement>(
        "[data-shipping-cost-label]",
      );

      // Tracker only appears when shipping tab is active AND form is expanded (not collapsed to chip)
      if (!shippingRadio?.checked || formPanel?.classList.contains("hidden")) {
        tracker?.classList.add("hidden");
        earned?.classList.add("hidden");
        return;
      }

      if (subtotal >= FREE_SHIPPING_THRESHOLD) {
        tracker?.classList.add("hidden");
        earned?.classList.remove("hidden");
        if (costLabel) costLabel.textContent = "FREE";
      } else {
        tracker?.classList.remove("hidden");
        earned?.classList.add("hidden");
        const remainingAmt = FREE_SHIPPING_THRESHOLD - subtotal;
        if (remaining) {
          remaining.textContent = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
          }).format(remainingAmt);
        }
        if (progress) {
          progress.style.width = `${Math.min((subtotal / FREE_SHIPPING_THRESHOLD) * 100, 100)}%`;
        }
        if (costLabel) {
          costLabel.textContent = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
          }).format(FLAT_RATE_SHIPPING);
        }
      }
    }

    function handleTabClick(
      method: "shipping" | "pickup",
      triggerUpdate = true,
    ) {
      if (method === "shipping" && shippingRadio) shippingRadio.checked = true;
      if (method === "pickup" && pickupRadio) pickupRadio.checked = true;

      tabs.forEach((tab) => {
        tab.setAttribute("aria-pressed", String(tab.dataset.tab === method));
      });

      formPanel?.classList.remove("hidden");
      formPanel?.removeAttribute("aria-hidden");
      summaryChip?.classList.add("hidden");
      summaryChip?.classList.remove("flex");

      if (doneBtn) {
        doneBtn.classList.remove("hidden");
        doneBtn.textContent =
          method === "shipping"
            ? "Confirm : Ship to Me"
            : "Confirm : Store Pick Up";
        doneBtn.setAttribute(
          "aria-label",
          method === "shipping"
            ? "Confirm Ship to Me and save details"
            : "Confirm Store Pick Up and save details",
        );
      }

      if (summaryLabel && summaryChip) {
        summaryLabel.textContent = getSummaryLabel(method);
      }

      if (method === "shipping") {
        shippingForm?.classList.remove("hidden");
        pickupForm?.classList.add("hidden");
        // Show free shipping tracker for shipping method
        updateFreeShippingTracker(cart.getTotal());
      } else {
        pickupForm?.classList.remove("hidden");
        shippingForm?.classList.add("hidden");
        // Hide free shipping tracker for pickup
        selector
          ?.querySelector<HTMLElement>("#free-shipping-tracker")
          ?.classList.add("hidden");
        selector
          ?.querySelector<HTMLElement>("#free-shipping-earned")
          ?.classList.add("hidden");
      }

      setRequiredFields(method);

      if (
        triggerUpdate &&
        typeof window.updateOrderSummaryOnFulfillmentChange === "function"
      ) {
        // Form panel is open during a tab click — always unconfirmed, pass false
        window.updateOrderSummaryOnFulfillmentChange(
          method,
          getFormData(method),
          false,
          true,
        );
      }
    }

    // Done button — validate then collapse
    doneBtn?.addEventListener("click", () => {
      const checkedRadio = selector?.querySelector<HTMLInputElement>(
        'input[name="fulfillment"]:checked',
      );
      if (!checkedRadio) return;
      const method = checkedRadio.value as "shipping" | "pickup";
      const activeForm = method === "shipping" ? shippingForm : pickupForm;
      const requiredFields = activeForm?.querySelectorAll<
        HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
      >("[required]");
      let firstInvalid:
        | HTMLInputElement
        | HTMLSelectElement
        | HTMLTextAreaElement
        | null = null;
      requiredFields?.forEach((field) => {
        if (!field.validity.valid && !firstInvalid) firstInvalid = field;
      });
      if (firstInvalid) {
        (firstInvalid as HTMLInputElement).reportValidity();
        (firstInvalid as HTMLInputElement).scrollIntoView({
          behavior: "smooth",
          block: "center",
        });
        return;
      }
      saveForm(true);
      collapseForm(method);
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    expandBtn?.addEventListener("click", expandForm);

    function restoreForm() {
      const raw = sessionStorage.getItem("fulfillment-form");
      if (!raw) return;
      try {
        const data = JSON.parse(raw) as Record<string, string>;
        const method = data._method as "shipping" | "pickup";
        if (method === "shipping" || method === "pickup") {
          handleTabClick(method, false);
          const form = method === "shipping" ? shippingForm : pickupForm;
          form
            ?.querySelectorAll<
              HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
            >("input, select, textarea")
            .forEach((el) => {
              if (el.id && data[el.id] !== undefined) el.value = data[el.id];
            });

          initFloatSelects(selector as Element);

          const requiredFields = form?.querySelectorAll<
            HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
          >("[required]");
          // Only collapse to chip if the user had previously clicked Confirm
          const wasConfirmed = data._confirmed === "true";
          if (wasConfirmed) collapseForm(method);
        }
      } catch {
        sessionStorage.removeItem("fulfillment-form");
      }
    }

    // Wire up tab clicks
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const method = tab.dataset.tab as "shipping" | "pickup";
        handleTabClick(method);
        saveForm();
      });
    });

    // Phone masking
    function maskPhone(value: string): string {
      let d = value.replace(/\D/g, "").slice(0, 11);
      if (d.length === 11 && d.startsWith("1")) d = d.slice(1);
      d = d.slice(0, 10);
      if (d.length <= 3) return d.length ? `(${d}` : "";
      if (d.length <= 6) return `(${d.slice(0, 3)}) ${d.slice(3)}`;
      return `(${d.slice(0, 3)}) ${d.slice(3, 6)}-${d.slice(6)}`;
    }
    ["shipping-phone", "pickup-phone"].forEach((id) => {
      const el = selector.querySelector<HTMLInputElement>(`#${id}`);
      if (!el) return;
      const applyMask = () => {
        const masked = maskPhone(el.value);
        el.value = masked;
        el.setSelectionRange(masked.length, masked.length);
      };
      el.addEventListener("input", applyMask);
      el.addEventListener("change", applyMask);
    });

    // ZIP: digits only + Zippopotam.us auto-fill cSpell:ignore Zippopotam.us
    const zipInput = selector.querySelector<HTMLInputElement>("#shipping-zip");
    const cityInput =
      selector.querySelector<HTMLInputElement>("#shipping-city");
    const stateSelect =
      selector.querySelector<HTMLSelectElement>("#shipping-state");

    zipInput?.addEventListener("input", () => {
      zipInput.value = zipInput.value.replace(/\D/g, "").slice(0, 5);
    });
    zipInput?.addEventListener("blur", async () => {
      const zip = zipInput.value;
      if (zip.length !== 5) return;
      try {
        const res = await fetch(`https://api.zippopotam.us/us/${zip}`);
        if (!res.ok) return;
        const data = (await res.json()) as {
          places: Array<{ "place name": string; "state abbreviation": string }>;
        };
        const place = data.places?.[0];
        if (!place) return;
        if (cityInput && !cityInput.value)
          cityInput.value = place["place name"];
        if (stateSelect && !stateSelect.value) {
          stateSelect.value = place["state abbreviation"];
          initFloatSelects(selector as Element);
        }
        saveForm();
        notifyValidity();
      } catch {
        /* silent */
      }
    });

    selector
      .querySelectorAll<
        HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
      >("input, select, textarea")
      .forEach((el) => {
        el.addEventListener("change", () => {
          saveForm();
          notifyValidity();
        });
        el.addEventListener("input", () => {
          saveForm();
          notifyValidity();
        });
      });

    function syncCart() {
      updateFreeShippingTracker(cart.getTotal());
    }
    syncCart();
    restoreForm();
    // If nothing was restored, open shipping tab by default
    if (!shippingRadio?.checked && !pickupRadio?.checked) {
      handleTabClick("shipping", false);
    }
    initFloatSelects(selector as Element);
    window.addEventListener("cartUpdated", syncCart);
  }

  document.addEventListener("astro:page-load", initFulfillmentSelector);

  let fulfillmentSelectorReady = false;
  document.addEventListener("astro:page-load", () => {
    fulfillmentSelectorReady = true;
  });

  // cSpell:ignore giftcard
  document.addEventListener("cart:giftcard", (e: Event) => {
    const { hasGiftCard } = (e as CustomEvent).detail as {
      hasGiftCard: boolean;
    };
    const disclaimer = document.getElementById("gift-card-shipping-disclaimer");
    if (disclaimer) disclaimer.classList.toggle("hidden", !hasGiftCard);
    if (hasGiftCard && fulfillmentSelectorReady) {
      const hasSavedForm = !!sessionStorage.getItem("fulfillment-form");
      const anySelected = document.querySelector<HTMLButtonElement>(
        '[data-tab][aria-pressed="true"]',
      );
      if (!hasSavedForm && !anySelected) {
        document
          .querySelector<HTMLButtonElement>('[data-tab="pickup"]')
          ?.focus();
      }
    }
  });
</script>

<style>
  .tab-btn[aria-pressed="true"] {
    background-color: var(--surface-primary);
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    color: var(--content-heading);
    border-top-color: var(--content-emphasis);
  }
  .tab-btn[aria-pressed="true"]:hover {
    background-color: var(--surface-primary);
    color: var(--content-heading);
  }
</style>
