---
interface Props {
  subtotal: number;
}

const { subtotal } = Astro.props;

const FREE_SHIPPING_THRESHOLD = 7500; // $75.00 in cents
const FLAT_RATE_SHIPPING = 599; // $5.99 in cents

function formatMoney(cents: number): string {
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
  }).format(cents / 100);
}

const subtotalCents = Math.round(subtotal * 100);
const shippingLabel =
  subtotalCents >= FREE_SHIPPING_THRESHOLD
    ? "FREE"
    : formatMoney(FLAT_RATE_SHIPPING);
const remainingForFree =
  subtotalCents < FREE_SHIPPING_THRESHOLD
    ? FREE_SHIPPING_THRESHOLD - subtotalCents
    : 0;
const progressPct = Math.min(
  (subtotalCents / FREE_SHIPPING_THRESHOLD) * 100,
  100,
);
---

<div data-component="fulfillment-selector" class="space-y-4 p-4">
  <fieldset>
    <legend class="text-sm font-semibold text-(--content-heading) mb-3">
      Choose Fulfillment Method <span class="text-red-500">*</span>
    </legend>

    <!-- Hidden radio inputs -->
    <input
      type="radio"
      name="fulfillment"
      id="fulfillment-shipping"
      value="shipping"
      class="sr-only"
    />
    <input
      type="radio"
      name="fulfillment"
      id="fulfillment-pickup"
      value="pickup"
      class="sr-only"
    />

    <!-- Tab row -->
    <div class="grid grid-cols-2 gap-2 mb-4">
      <button
        type="button"
        data-tab="shipping"
        class="tab-btn flex flex-row items-center justify-center gap-2 rounded-lg border-2 border-(--border-primary) bg-(--surface-primary) px-4 py-3 text-sm font-medium text-(--content-body) transition-all hover:border-(--content-emphasis) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-pressed="false"
      >
        <span class="text-lg leading-none">📦</span>
        <span>Ship to Me</span>
        <span
          class="text-xs font-normal text-(--content-meta)"
          data-shipping-cost-label>{shippingLabel}</span
        >
      </button>

      <button
        type="button"
        data-tab="pickup"
        class="tab-btn flex flex-row items-center justify-center gap-2 rounded-lg border-2 border-(--border-primary) bg-(--surface-primary) px-4 py-3 text-sm font-medium text-(--content-body) transition-all hover:border-(--content-emphasis) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-pressed="false"
      >
        <span class="text-lg leading-none">🏪</span>
        <span>Store Pickup</span>
        <span class="text-xs font-normal text-(--content-meta)">FREE</span>
      </button>
    </div>

    <!-- Free shipping progress tracker -->
    <div
      id="free-shipping-tracker"
      class={`mb-4 rounded-md bg-(--surface-secondary) px-3 py-2 text-xs text-(--content-meta)${remainingForFree <= 0 ? " hidden" : ""}`}
    >
      Add{" "}
      <span id="free-shipping-remaining">{formatMoney(remainingForFree)}</span>{
        " "
      }
      more for free shipping!
      <div class="mt-1.5 h-1.5 w-full rounded-full bg-(--border-primary)">
        <div
          id="free-shipping-progress"
          class="h-1.5 rounded-full bg-(--content-emphasis) transition-all"
          style={`width: ${progressPct}%`}
        >
        </div>
      </div>
    </div>
    <div
      id="free-shipping-earned"
      class={`mb-4 rounded-md bg-(--surface-secondary) px-3 py-2 text-xs text-(--content-emphasis) font-medium${subtotalCents < FREE_SHIPPING_THRESHOLD ? " hidden" : ""}`}
    >
      🎉 You've earned free shipping!
    </div>

    <!-- Form panel (shown below tabs, full width) -->
    <div
      id="fulfillment-form-panel"
      class="hidden space-y-4 rounded-lg border border-(--border-primary) bg-(--surface-secondary) p-4"
    >
      <!-- Shipping form -->
      <div data-shipping-form class="hidden space-y-3">
        <p class="text-sm font-medium text-(--content-heading)">
          Shipping Details
        </p>

        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2 sm:col-span-1">
            <label
              for="shipping-first-name"
              class="block text-xs font-medium text-(--content-meta) mb-1"
            >
              First Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="shipping-first-name"
              name="shipping-first-name"
              required
              autocomplete="given-name"
              class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
              placeholder="First name"
            />
          </div>
          <div class="col-span-2 sm:col-span-1">
            <label
              for="shipping-last-name"
              class="block text-xs font-medium text-(--content-meta) mb-1"
            >
              Last Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="shipping-last-name"
              name="shipping-last-name"
              required
              autocomplete="family-name"
              class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
              placeholder="Last name"
            />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2 sm:col-span-1">
            <label
              for="shipping-email"
              class="block text-xs font-medium text-(--content-meta) mb-1"
            >
              Email <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="shipping-email"
              name="shipping-email"
              required
              autocomplete="email"
              class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
              placeholder="you@example.com"
            />
          </div>
          <div class="col-span-2 sm:col-span-1">
            <label
              for="shipping-phone"
              class="block text-xs font-medium text-(--content-meta) mb-1"
            >
              Phone <span class="text-red-500">*</span>
            </label>
            <input
              type="tel"
              id="shipping-phone"
              name="shipping-phone"
              required
              autocomplete="tel"
              class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
              placeholder="(555) 555-5555"
            />
          </div>
        </div>

        <div>
          <label
            for="shipping-address"
            class="block text-xs font-medium text-(--content-meta) mb-1"
          >
            Street Address <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="shipping-address"
            name="shipping-address"
            required
            autocomplete="street-address"
            class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
            placeholder="123 Main St"
          />
        </div>

        <div>
          <label
            for="shipping-address2"
            class="block text-xs font-medium text-(--content-meta) mb-1"
          >
            Apt, Suite, Unit (Optional)
          </label>
          <input
            type="text"
            id="shipping-address2"
            name="shipping-address2"
            autocomplete="address-line2"
            class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
            placeholder="Apt 4B"
          />
        </div>

        <div class="grid grid-cols-6 gap-3">
          <div class="col-span-3">
            <label
              for="shipping-city"
              class="block text-xs font-medium text-(--content-meta) mb-1"
            >
              City <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="shipping-city"
              name="shipping-city"
              required
              autocomplete="address-level2"
              class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
              placeholder="City"
            />
          </div>
          <div class="col-span-1">
            <label
              for="shipping-state"
              class="block text-xs font-medium text-(--content-meta) mb-1"
            >
              State <span class="text-red-500">*</span>
            </label>
            <select
              id="shipping-state"
              name="shipping-state"
              required
              autocomplete="address-level1"
              class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-2 py-2 text-sm text-(--content-body) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
            >
              <option value="">—</option>
              <option value="AL">AL</option>
              <option value="AK">AK</option>
              <option value="AZ">AZ</option>
              <option value="AR">AR</option>
              <option value="CA">CA</option>
              <option value="CO">CO</option>
              <option value="CT">CT</option>
              <option value="DE">DE</option>
              <option value="FL">FL</option>
              <option value="GA">GA</option>
              <option value="HI">HI</option>
              <option value="ID">ID</option>
              <option value="IL">IL</option>
              <option value="IN">IN</option>
              <option value="IA">IA</option>
              <option value="KS">KS</option>
              <option value="KY">KY</option>
              <option value="LA">LA</option>
              <option value="ME">ME</option>
              <option value="MD">MD</option>
              <option value="MA">MA</option>
              <option value="MI">MI</option>
              <option value="MN">MN</option>
              <option value="MS">MS</option>
              <option value="MO">MO</option>
              <option value="MT">MT</option>
              <option value="NE">NE</option>
              <option value="NV">NV</option>
              <option value="NH">NH</option>
              <option value="NJ">NJ</option>
              <option value="NM">NM</option>
              <option value="NY">NY</option>
              <option value="NC">NC</option>
              <option value="ND">ND</option>
              <option value="OH">OH</option>
              <option value="OK">OK</option>
              <option value="OR">OR</option>
              <option value="PA">PA</option>
              <option value="RI">RI</option>
              <option value="SC">SC</option>
              <option value="SD">SD</option>
              <option value="TN">TN</option>
              <option value="TX">TX</option>
              <option value="UT">UT</option>
              <option value="VT">VT</option>
              <option value="VA">VA</option>
              <option value="WA">WA</option>
              <option value="WV">WV</option>
              <option value="WI">WI</option>
              <option value="WY">WY</option>
            </select>
          </div>
          <div class="col-span-2">
            <label
              for="shipping-zip"
              class="block text-xs font-medium text-(--content-meta) mb-1"
            >
              ZIP <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="shipping-zip"
              name="shipping-zip"
              required
              autocomplete="postal-code"
              inputmode="numeric"
              maxlength="10"
              class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
              placeholder="54901"
            />
          </div>
        </div>

        <div>
          <label
            for="shipping-instructions"
            class="block text-xs font-medium text-(--content-meta) mb-1"
          >
            Delivery Instructions (Optional)
          </label>
          <textarea
            id="shipping-instructions"
            name="shipping-instructions"
            rows="2"
            class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis) resize-none"
            placeholder="Leave at door, ring bell, etc."></textarea>
        </div>
      </div>

      <!-- Pickup form -->
      <div data-pickup-form class="hidden space-y-3">
        <p class="text-sm font-medium text-(--content-heading)">
          Pickup Information
        </p>
        <p class="text-xs text-(--content-meta)">
          Pick up your order at <strong>El Camino Skate Shop</strong> — we'll email
          you when it's ready.
        </p>

        <div>
          <label
            for="pickup-name"
            class="block text-xs font-medium text-(--content-meta) mb-1"
          >
            Full Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="pickup-name"
            name="pickup-name"
            required
            autocomplete="name"
            class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
            placeholder="Your name"
          />
        </div>

        <div>
          <label
            for="pickup-email"
            class="block text-xs font-medium text-(--content-meta) mb-1"
          >
            Email <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="pickup-email"
            name="pickup-email"
            required
            autocomplete="email"
            class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label
            for="pickup-phone"
            class="block text-xs font-medium text-(--content-meta) mb-1"
          >
            Phone <span class="text-red-500">*</span>
          </label>
          <input
            type="tel"
            id="pickup-phone"
            name="pickup-phone"
            required
            autocomplete="tel"
            class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis)"
            placeholder="(555) 555-5555"
          />
        </div>

        <div>
          <label
            for="pickup-notes"
            class="block text-xs font-medium text-(--content-meta) mb-1"
          >
            Pickup Notes (Optional)
          </label>
          <textarea
            id="pickup-notes"
            name="pickup-notes"
            rows="2"
            class="w-full rounded-md border border-(--border-primary) bg-(--surface-primary) px-3 py-2 text-sm text-(--content-body) placeholder:text-(--content-meta) focus:border-(--content-emphasis) focus:outline-none focus:ring-1 focus:ring-(--content-emphasis) resize-none"
            placeholder="Any special instructions for pickup"></textarea>
        </div>
      </div>
    </div>
  </fieldset>
</div>

<script>
  import { cart } from "@/lib/cart";

  const FREE_SHIPPING_THRESHOLD = 75; // $75.00 in dollars (cart stores prices in dollars)
  const FLAT_RATE_SHIPPING = 5.99; // $5.99 in dollars

  declare global {
    interface Window {
      updateOrderSummaryOnFulfillmentChange?: (
        method: string,
        formData: Record<string, string>,
      ) => void;
    }
  }

  function initFulfillmentSelector() {
    const selector = document.querySelector(
      '[data-component="fulfillment-selector"]',
    );
    if (!selector) return;

    const shippingRadio = selector.querySelector<HTMLInputElement>(
      "#fulfillment-shipping",
    );
    const pickupRadio = selector.querySelector<HTMLInputElement>(
      "#fulfillment-pickup",
    );
    const formPanel = selector.querySelector<HTMLElement>(
      "#fulfillment-form-panel",
    );
    const shippingForm = selector.querySelector<HTMLElement>(
      "[data-shipping-form]",
    );
    const pickupForm =
      selector.querySelector<HTMLElement>("[data-pickup-form]");
    const tabs = selector.querySelectorAll<HTMLButtonElement>("[data-tab]");

    function getFormData(
      method: "shipping" | "pickup",
    ): Record<string, string> {
      const form = method === "shipping" ? shippingForm : pickupForm;
      const data: Record<string, string> = { method };
      form
        ?.querySelectorAll<
          HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
        >("input, select, textarea")
        .forEach((el) => {
          if (el.id) data[el.id] = el.value;
        });
      return data;
    }

    function saveForm() {
      const checkedRadio = selector?.querySelector<HTMLInputElement>(
        'input[name="fulfillment"]:checked',
      );
      if (!checkedRadio) return;
      const method = checkedRadio.value as "shipping" | "pickup";
      const data = getFormData(method);
      data._method = method;
      sessionStorage.setItem("fulfillment-form", JSON.stringify(data));
    }

    function restoreForm() {
      const raw = sessionStorage.getItem("fulfillment-form");
      if (!raw) return;
      try {
        const data = JSON.parse(raw) as Record<string, string>;
        const method = data._method as "shipping" | "pickup";
        if (method === "shipping" || method === "pickup") {
          handleTabClick(method, false);
          const form = method === "shipping" ? shippingForm : pickupForm;
          form
            ?.querySelectorAll<
              HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
            >("input, select, textarea")
            .forEach((el) => {
              if (el.id && data[el.id] !== undefined) el.value = data[el.id];
            });
        }
      } catch {
        sessionStorage.removeItem("fulfillment-form");
      }
    }

    function setRequiredFields(method: "shipping" | "pickup") {
      // Remove required from all fields first
      selector
        ?.querySelectorAll<
          HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
        >("[data-shipping-form] input, [data-shipping-form] select, [data-pickup-form] input")
        .forEach((el) => el.removeAttribute("required"));

      // Add required to the active form's required fields
      if (method === "shipping") {
        [
          "shipping-first-name",
          "shipping-last-name",
          "shipping-email",
          "shipping-phone",
          "shipping-address",
          "shipping-city",
          "shipping-state",
          "shipping-zip",
        ].forEach((id) => {
          selector?.querySelector(`#${id}`)?.setAttribute("required", "");
        });
      } else {
        ["pickup-name", "pickup-email", "pickup-phone"].forEach((id) => {
          selector?.querySelector(`#${id}`)?.setAttribute("required", "");
        });
      }
    }

    function updateFreeShippingTracker(subtotal: number) {
      const tracker = selector?.querySelector<HTMLElement>(
        "#free-shipping-tracker",
      );
      const remaining = selector?.querySelector<HTMLElement>(
        "#free-shipping-remaining",
      );
      const progress = selector?.querySelector<HTMLElement>(
        "#free-shipping-progress",
      );
      const earned = selector?.querySelector<HTMLElement>(
        "#free-shipping-earned",
      );
      const costLabel = selector?.querySelector<HTMLElement>(
        "[data-shipping-cost-label]",
      );

      if (subtotal >= FREE_SHIPPING_THRESHOLD) {
        tracker?.classList.add("hidden");
        earned?.classList.remove("hidden");
        if (costLabel) costLabel.textContent = "FREE";
      } else {
        tracker?.classList.remove("hidden");
        earned?.classList.add("hidden");
        const remainingAmt = FREE_SHIPPING_THRESHOLD - subtotal;
        if (remaining) {
          remaining.textContent = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
          }).format(remainingAmt);
        }
        if (progress) {
          progress.style.width = `${Math.min((subtotal / FREE_SHIPPING_THRESHOLD) * 100, 100)}%`;
        }
        if (costLabel) {
          costLabel.textContent = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
          }).format(FLAT_RATE_SHIPPING);
        }
      }
    }

    function handleTabClick(
      method: "shipping" | "pickup",
      triggerUpdate = true,
    ) {
      // Update radio inputs
      if (method === "shipping" && shippingRadio) shippingRadio.checked = true;
      if (method === "pickup" && pickupRadio) pickupRadio.checked = true;

      // Update tab button styles
      tabs.forEach((tab) => {
        const isActive = tab.dataset.tab === method;
        tab.setAttribute("aria-pressed", String(isActive));
        if (isActive) {
          tab.classList.remove(
            "border-(--border-primary)",
            "bg-(--surface-primary)",
          );
          tab.classList.add(
            "border-(--content-emphasis)",
            "bg-(--surface-secondary)",
          );
        } else {
          tab.classList.remove(
            "border-(--content-emphasis)",
            "bg-(--surface-secondary)",
          );
          tab.classList.add(
            "border-(--border-primary)",
            "bg-(--surface-primary)",
          );
        }
      });

      // Show form panel
      formPanel?.classList.remove("hidden");

      // Show correct form
      if (method === "shipping") {
        shippingForm?.classList.remove("hidden");
        pickupForm?.classList.add("hidden");
      } else {
        pickupForm?.classList.remove("hidden");
        shippingForm?.classList.add("hidden");
      }

      // Manage required fields
      setRequiredFields(method);

      if (
        triggerUpdate &&
        typeof window.updateOrderSummaryOnFulfillmentChange === "function"
      ) {
        window.updateOrderSummaryOnFulfillmentChange(
          method,
          getFormData(method),
        );
      }
    }

    // Wire up tab clicks
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const method = tab.dataset.tab as "shipping" | "pickup";
        handleTabClick(method);
        saveForm();
      });
    });

    // Save on form field changes
    selector
      .querySelectorAll<
        HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
      >("input, select, textarea")
      .forEach((el) => {
        el.addEventListener("change", saveForm);
        el.addEventListener("input", saveForm);
      });

    // Sync free shipping tracker with live cart subtotal
    function syncCart() {
      const subtotalVal = cart.getTotal();
      updateFreeShippingTracker(subtotalVal);
    }

    syncCart();
    restoreForm();

    // Listen for cart updates (event fires on window as "cartUpdated")
    window.addEventListener("cartUpdated", syncCart);
  }

  document.addEventListener("astro:page-load", initFulfillmentSelector);
</script>
