---
interface Props {
  subtotal: number;
}

const { subtotal } = Astro.props;

const FREE_SHIPPING_THRESHOLD = 7500; // $75.00 in cents
const FLAT_RATE_SHIPPING = 599; // $5.99 in cents

function formatMoney(cents: number): string {
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
  }).format(cents / 100);
}

const subtotalCents = Math.round(subtotal * 100);
const shippingLabel =
  subtotalCents >= FREE_SHIPPING_THRESHOLD
    ? "FREE"
    : formatMoney(FLAT_RATE_SHIPPING);
const remainingForFree =
  subtotalCents < FREE_SHIPPING_THRESHOLD
    ? FREE_SHIPPING_THRESHOLD - subtotalCents
    : 0;
const progressPct = Math.min(
  (subtotalCents / FREE_SHIPPING_THRESHOLD) * 100,
  100,
);
---

<div data-component="fulfillment-selector">
  <fieldset>
    <legend class="text-sm font-semibold text-(--content-heading) p-2">
      Choose Fulfillment Method <span class="text-(--content-emphasis) italic">
        - required</span
      >
    </legend>

    <!-- Summary chip: shown after collapse (mobile), hidden on desktop -->
    <div
      id="fulfillment-summary-chip"
      class="hidden mb-3 items-center justify-between border border-(--border-primary) bg-(--surface-primary) px-4 py-3"
      role="status"
      aria-live="polite"
    >
      <span
        id="fulfillment-summary-label"
        class="text-sm font-semibold text-(--content-heading)"
      >
        📦 Ship to Me
      </span>
      <button
        id="fulfillment-expand-btn"
        type="button"
        class="text-xs text-(--content-emphasis) underline underline-offset-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-expanded="false"
        aria-controls="fulfillment-form-panel"
      >
        Edit
      </button>
    </div>

    <!-- Hidden radio inputs -->
    <input
      type="radio"
      name="fulfillment"
      id="fulfillment-shipping"
      value="shipping"
      class="sr-only"
    />
    <input
      type="radio"
      name="fulfillment"
      id="fulfillment-pickup"
      value="pickup"
      class="sr-only"
    />

    <!-- Tab row — segmented control track -->
    <div
      id="fulfillment-tab-row"
      class="grid grid-cols-2 gap-1 p-1 bg-(--surface-secondary)"
    >
      <button
        type="button"
        data-tab="shipping"
        class="tab-btn flex flex-row items-center justify-center gap-2 rounded px-4 py-3 text-sm font-semibold text-(--content-meta) hover:bg-(--surface-tertiary) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-pressed="false"
      >
        <span class="text-lg leading-none">📦</span>
        <span>Ship to Me</span>
        <span class="text-xs font-normal opacity-75" data-shipping-cost-label
          >{shippingLabel}</span
        >
      </button>

      <button
        type="button"
        data-tab="pickup"
        class="tab-btn flex flex-row items-center justify-center gap-2 rounded px-4 py-3 text-sm font-semibold text-(--content-meta) hover:bg-(--surface-tertiary) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--content-emphasis)"
        aria-pressed="false"
      >
        <span class="text-lg leading-none">🏪</span>
        <span>Store Pickup</span>
        <span class="text-xs font-normal opacity-75">FREE</span>
      </button>
    </div>

    <!-- Free shipping progress tracker -->
    <div
      id="free-shipping-tracker"
      class={`px-4 py-3 text-sm font-medium text-(--content-body)${remainingForFree <= 0 ? " hidden" : ""}`}
      style="background-color: var(--free-shipping-bar-bg);"
    >
      Add{" "}
      <span
        id="free-shipping-remaining"
        class="font-bold text-(--content-heading)"
        >{formatMoney(remainingForFree)}</span
      >{" "}
      more for free shipping!
      <div
        class="mt-2 h-3 w-full rounded-full"
        style="background-color: var(--free-shipping-bar-track);"
      >
        <div
          id="free-shipping-progress"
          class="h-3 rounded-full transition-all"
          style={`width: ${progressPct}%; background-color: var(--free-shipping-bar);`}
        >
        </div>
      </div>
    </div>
    <div
      id="free-shipping-earned"
      class={`mb-4  px-4 py-3 text-sm font-medium text-(--content-heading)${subtotalCents < FREE_SHIPPING_THRESHOLD ? " hidden" : ""}`}
      style="background-color: var(--free-shipping-bar-bg);"
    >
      🎉 You've earned free shipping!
    </div>

    <!-- Form panel (shown below tabs, full width) -->
    <div
      id="fulfillment-form-panel"
      class="hidden space-y-4 border border-(--border-primary) bg-(--surface-secondary) p-4"
    >
      <!-- Shipping form -->
      <div data-shipping-form class="hidden space-y-3">
        <p class="text-sm font-medium text-(--content-heading)">
          Shipping Details
        </p>

        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2 sm:col-span-1">
            <label
