---
/**
 * Admin Layout - Following established site patterns
 * File: src/layouts/AdminLayout.astro
 */
import { SEOMetadata } from "astro-seo-metadata";
import AdminHeader from "@/components/admin/AdminHeader.astro";
import "@/styles/global.css";
import AdminFooter from "@/components/admin/AdminFooter.astro";

// Auth guard — redirect to login if session cookie is absent, expired, or tampered.
// Middleware also enforces this for /admin/*; this layout-level check is a defense
// in depth in case a route slips past the middleware matcher.
const secret = process.env.ADMIN_SECRET;
if (secret) {
  const { ADMIN_COOKIE_NAME, verifySessionToken } = await import("@/lib/admin/auth");
  const token = Astro.cookies.get(ADMIN_COOKIE_NAME)?.value;
  if (!verifySessionToken(secret, token)) {
    const from = encodeURIComponent(Astro.url.pathname);
    return Astro.redirect(`/admin/login?from=${from}`);
  }
}

interface Props {
  title: string;
  activeSection?: string;
  description?: string;
}

const {
  title,
  activeSection: _activeSection = "",
  description = "",
} = Astro.props;

const adminTitle = `${title} - El Camino Admin`;
const adminDescription =
  description || "El Camino Skate Shop administration tools";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{adminTitle}</title>
    <meta name="description" content={adminDescription} />
    <meta name="robots" content="noindex, nofollow" />

    <script nonce={Astro.locals.nonce} is:inline>
      (function () {
        const storedTheme = localStorage.getItem("theme");
        const systemPrefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const theme = storedTheme ?? (systemPrefersDark ? "dark" : "light");
        document.documentElement.classList.add(theme);
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <SEOMetadata
      title={adminTitle}
      description={adminDescription}
      canonicalUrl={Astro.url.toString()}
      type="website"
    />
  </head>

  <body>
    <!-- Admin Header with Logo and Navigation -->
    <AdminHeader />

    <!-- Page Header -->
    <div class="my-6 p-3">
      <h1 class="text-4xl font-bold text-(--content-heading) mb-4">
        {title}
      </h1>
      {
        description && (
          <p class="text-lg text-(--content-body) max-w-2xl">{description}</p>
        )
      }
    </div>

    <!-- Main Content -->
    <main
      class="p-1 lg:p-4 relative min-h-[calc(100vh-100px)]"
      id="main-content"
    >
      <!-- Page Content -->
      <slot />
    </main>
    <AdminFooter />

    <!-- Page-level panels (rendered outside main to avoid stacking context issues) -->
    <slot name="panels" />
  </body>
</html>

<style>
  /* Consistent entry animation for all admin pages */
  main {
    animation: fadeInUp 0.4s ease-out both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
    }
  }

  /* Respect reduced-motion preferences */
  @media (prefers-reduced-motion: reduce) {
    main {
      animation: none;
    }
  }
</style>

<style is:global>
  /* CWV badge — shared across all admin performance pages */
  .cwv-badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    letter-spacing: 0.05em;
  }

  .cwv-good {
    background-color: var(--color-state-success-surface);
    color: var(--color-state-success-text);
  }

  .cwv-needs-improvement {
    background-color: var(--color-state-warning-surface);
    color: var(--color-state-warning-text);
  }

  .cwv-poor {
    background-color: var(--color-state-error-surface);
    color: var(--color-state-error-text);
  }

  .cwv-unknown {
    background-color: var(--surface-tertiary);
    color: var(--content-meta);
  }
</style>
