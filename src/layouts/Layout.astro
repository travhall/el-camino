---
import { getSiteContext } from "@/lib/siteContext";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import QuickView from "@/components/QuickView.astro";
import MiniCart from "@/components/MiniCart.astro";
import Modal from "@/components/Modal.astro";
import Notification from "@/components/Notification.astro";
import BaseHead from "@/components/BaseHead.astro";
import { detectDeviceFromUA } from "@/utils/device";

interface Props {
  title: string;
  structuredData?: object;
  activeCategory?: string;
}

const { title, structuredData, activeCategory } = Astro.props;

// Device detection for conditional component loading
const userAgent = Astro.request.headers.get("user-agent") || "";
const deviceInfo = detectDeviceFromUA(userAgent);
const isDesktop = deviceInfo.isDesktop;

// Hydrate the per-request site context. Footer/Nav read from this same
// memoized bundle, so the 6 blob reads happen in one parallel batch instead
// of cascading serially through each child component.
const siteCtx = await getSiteContext(Astro.locals);
const orgSchema = siteCtx.structured;

// Get current path for context-aware prefetching
const currentPath = Astro.url.pathname;
const isHighTrafficPage = ["/", "/the-shop", "/news"].includes(currentPath);
---

<!doctype html>
<html lang="en">
  <BaseHead
    title={title}
    structuredData={structuredData}
    orgSchema={orgSchema}
    currentPath={currentPath}
    isHighTrafficPage={isHighTrafficPage}
  />
  <slot name="head" />

  <body
    class="bg-(--surface-primary) text-(--content-body) grid grid-rows-[auto_1fr_auto] min-h-screen relative overflow-x-hidden"
    data-active-category={activeCategory || ""}
  >
    <!-- Navigation progress bar: visible feedback during view transitions -->
    <div id="nav-progress" transition:persist="nav-progress" aria-hidden="true">
    </div>

    <Header activeCategory={activeCategory} />
    <main
      class="bg-(--surface-primary) text-(--content-body) border-b-4 border-(--border-secondary) z-10 relative overflow-x-clip w-full max-w-full min-w-0"
      id="main-content"
      tabindex="-1"
    >
      <slot />
    </main>
    <Footer />

    <!-- Desktop-only features -->
    {
      isDesktop && (
        <>
          <QuickView />
          <MiniCart />
        </>
      )
    }

    <Notification />
    <Modal />
    <div id="portal-root"></div>

    <!-- Global cleanup for news view parameters -->
    <script>
      document.addEventListener("astro:page-load", () => {
        // Clean view parameters from non-news forms
        const cleanNonNewsForms = () => {
          const forms = document.querySelectorAll("form");
          forms.forEach((form) => {
            const action = form.getAttribute("action") || "";
            const isNewsForm =
              !action ||
              action.startsWith("/news") ||
              window.location.pathname.startsWith("/news");

            if (!isNewsForm) {
              const viewInputs = form.querySelectorAll('input[name="view"]');
              viewInputs.forEach((input) => input.remove());
            }
          });
        };

        // Clean immediately and after any dynamic content loads
        cleanNonNewsForms();
        setTimeout(cleanNonNewsForms, 100);
      });

      // Clean view parameter from URLs when navigating away from news
      document.addEventListener("astro:before-swap", (e) => {
        if (
          window.location.pathname.startsWith("/news") &&
          e.to &&
          !e.to.pathname.startsWith("/news")
        ) {
          const currentParams = new URLSearchParams(window.location.search);
          if (currentParams.has("view")) {
            currentParams.delete("view");
            const cleanUrl =
              e.to.pathname +
              (currentParams.toString() ? "?" + currentParams.toString() : "");
            window.history.replaceState({}, "", cleanUrl);
          }
        }
      });
    </script>

    <!-- Navigation progress bar styles & controller -->
    <style is:global>
      #nav-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0%;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        background: var(--content-emphasis);
        transition: none;
        will-change: width, opacity;
      }
    </style>
    <script>
      document.addEventListener("astro:before-preparation", () => {
        const bar = document.getElementById("nav-progress");
        if (!bar) return;
        // Reset and animate to 80% over ~3 s (slow crawl — gives sense of progress)
        bar.style.transition = "none";
        bar.style.width = "0%";
        bar.style.opacity = "1";
        // Force reflow so the reset takes effect before the animation starts
        bar.getBoundingClientRect();
        bar.style.transition =
          "width 3s cubic-bezier(0.05, 0.5, 0.1, 1), opacity 0.1s ease";
        bar.style.width = "80%";
      });

      document.addEventListener("astro:after-preparation", () => {
        // Page data is ready — bump toward 95% while swap is pending
        const bar = document.getElementById("nav-progress");
        if (!bar) return;
        bar.style.transition = "width 0.2s ease";
        bar.style.width = "95%";
      });

      document.addEventListener("astro:page-load", () => {
        // Page rendered — snap to 100% then fade out
        const bar = document.getElementById("nav-progress");
        if (!bar) return;
        bar.style.transition = "width 0.15s ease";
        bar.style.width = "100%";
        setTimeout(() => {
          bar.style.transition = "opacity 0.3s ease";
          bar.style.opacity = "0";
          setTimeout(() => {
            bar.style.transition = "none";
            bar.style.width = "0%";
          }, 300);
        }, 100);
      });
    </script>

    <!-- PHASE 1: Device Detection & Conditional Loading -->
    <script src="../scripts/initDeviceDetection.ts"></script>

    <!-- Performance Monitoring & Runtime Optimizations -->
    <script src="../scripts/layout-client.ts"></script>

    <!-- Image shimmer: attaches load/error handlers via data-shimmer-* attributes -->
    <script src="../scripts/imageShimmer.ts"></script>
  </body>
</html>
