---
// src/pages/order-confirmation.astro
import Layout from "@/layouts/Layout.astro";
import { squareClient } from "@/lib/square/client";
import { MoneyUtils } from "@/lib/square/money";
import type { Order } from "square/legacy";
import type { SquareMoneyObject } from "@/lib/square/types";
import { Image } from "astro:assets";
import { EL_CAMINO_LOGO_DATA_URI } from "@/lib/constants/assets";
import { siteConfig } from "@/lib/site-config";
import { getContactInfo } from "@/lib/contactInfo";

// Track line item additional info
type LineItemInfo = {
  image?: string;
  variationName?: string;
  catalogPriceMoney?: SquareMoneyObject; // Regular catalog price (to detect sale items)
};
type LineItemDetails = Record<string, LineItemInfo>;

const contact = await getContactInfo();
let orderId = Astro.url.searchParams.get("orderId");
const transactionId = Astro.url.searchParams.get("transactionId");

// Primary fallback: read the orderId from the cookie we set in create-checkout.
// This is the most reliable mechanism because cookies travel automatically with
// every browser request — no JavaScript needed, no race conditions.
// Square's sandbox (and legacy production API) does not append orderId to the
// redirect URL, so the URL param alone cannot be trusted.
if (!orderId) {
  const cookieHeader = Astro.request.headers.get("cookie") ?? "";
  const match = cookieHeader.match(/(?:^|;\s*)square-pending-orderId=([^;]+)/);
  if (match?.[1]) {
    orderId = match[1];
    // Clear the cookie now that we've consumed it so a later visit to this page
    // (e.g. a browser back-navigation) doesn't pull up a stale order.
    Astro.response.headers.set(
      "Set-Cookie",
      "square-pending-orderId=; Path=/; Max-Age=0; SameSite=Lax; HttpOnly",
    );
  }
}

// Secondary fallback: Square sometimes appends transactionId (payment ID) to
// the redirect URL even when orderId is absent. Resolve it via the Payments API.
if (!orderId && transactionId) {
  try {
    const { result: paymentResult } =
      await squareClient.paymentsApi.getPayment(transactionId);
    orderId = paymentResult.payment?.orderId ?? null;
  } catch {
    // fall through to the client-side sessionStorage head script
  }
}

let orderDetails: Order | null = null;
let lineItemDetails: LineItemDetails = {};
let error: string | null = null;

if (!orderId) {
  error = "Order ID not provided";
} else {
  try {
    // Retrieve the basic order
    const { result } = await squareClient.ordersApi.retrieveOrder(orderId);

    if (!result.order) {
      throw new Error("Order not found in Square response");
    }

    orderDetails = result.order;

    // Guard: only show confirmation for paid orders.
    //
    // Square payment-link orders stay in OPEN state permanently — OPEN means
    // "payment received, awaiting merchant fulfillment." Orders only reach
    // COMPLETED when the merchant marks them fulfilled. Checking for COMPLETED
    // would always block confirmation pages for pickup/shipping orders.
    //
    // The correct signal that payment was received is the presence of tenders
    // (Square's term for payment records attached to an order). If tenders
    // exist the customer has paid; if not, no payment has been captured yet.
    //
    // One retry handles the rare case where Square redirects before the tender
    // has been written to the order.
    const hasTenders = (orderDetails.tenders?.length ?? 0) > 0;
    if (!hasTenders) {
      await new Promise((resolve) => setTimeout(resolve, 1500));
      const { result: retryResult } =
        await squareClient.ordersApi.retrieveOrder(orderId);
      if (retryResult.order) orderDetails = retryResult.order;
    }

    if ((orderDetails.tenders?.length ?? 0) === 0) {
      if (orderDetails.state === "CANCELED") {
        error =
          "This order was canceled. If you believe this is an error, please contact us.";
      } else {
        error =
          "Payment not confirmed. If you believe this is an error, please contact us.";
      }
      orderDetails = null;
    }

    // Batch fetch catalog details only for confirmed orders
    if (orderDetails?.lineItems?.length) {
      const catalogIds = orderDetails.lineItems
        .filter((item) => item.catalogObjectId)
        .map((item) => item.catalogObjectId as string);

      if (catalogIds.length > 0) {
        try {
          const { result: batchResult } =
            await squareClient.catalogApi.batchRetrieveCatalogObjects({
              objectIds: catalogIds,
              includeRelatedObjects: true,
            });

          const objectMap: Record<string, any> = {};
          batchResult.objects?.forEach((obj) => {
            objectMap[obj.id] = obj;
          });
          batchResult.relatedObjects?.forEach((obj) => {
            objectMap[obj.id] = obj;
          });

          for (const item of orderDetails.lineItems) {
            if (!item.catalogObjectId || !item.uid) continue;
            const itemKey = item.uid;
            lineItemDetails[itemKey] = {};

            const variation = objectMap[item.catalogObjectId];
            if (!variation || variation.type !== "ITEM_VARIATION") continue;

            if (variation.itemVariationData?.name) {
              lineItemDetails[itemKey].variationName =
                variation.itemVariationData.name;
            }

            // Store catalog price for sale detection
            if (variation.itemVariationData?.priceMoney) {
              lineItemDetails[itemKey].catalogPriceMoney =
                variation.itemVariationData.priceMoney;
            }

            // Check variation image first
            const variationImageId = variation.itemVariationData?.imageIds?.[0];
            if (
              variationImageId &&
              objectMap[variationImageId]?.imageData?.url
            ) {
              lineItemDetails[itemKey].image =
                objectMap[variationImageId].imageData.url;
              continue;
            }

            // Fall back to parent item image
            const parentId = variation.itemVariationData?.itemId;
            if (parentId) {
              const parent = objectMap[parentId];
              const parentImageId = parent?.itemData?.imageIds?.[0];
              if (parentImageId && objectMap[parentImageId]?.imageData?.url) {
                lineItemDetails[itemKey].image =
                  objectMap[parentImageId].imageData.url;
              }
            }
          }
        } catch (batchError) {
          console.error("Error batch fetching catalog objects:", batchError);
        }
      }
    }

    // console.log("Order retrieved successfully:", orderDetails.id);
  } catch (e) {
    error = e instanceof Error ? e.message : "Failed to load order";
    console.error("Order retrieval error:", { error: e, orderId });
  }
}

function formatMoney(money: SquareMoneyObject | undefined | null): string {
  if (!money) return "$0.00";
  return MoneyUtils.format(money);
}

// Format the pre-tax total for a line item (totalMoney minus its tax portion).
function formatLineItemPreTax(
  item: NonNullable<Order["lineItems"]>[number],
): string {
  const total = Number(item.totalMoney?.amount ?? 0);
  const tax = Number(item.totalTaxMoney?.amount ?? 0);
  return MoneyUtils.format({ amount: total - tax, currency: "USD" });
}

// Returns true if the line item was purchased at a sale price (base price
// was overridden below the catalog's regular price at checkout time).
function isSaleItem(
  item: NonNullable<Order["lineItems"]>[number],
  details: LineItemInfo,
): boolean {
  const catalogAmount = Number(details.catalogPriceMoney?.amount ?? 0);
  const baseAmount = Number(item.basePriceMoney?.amount ?? 0);
  return catalogAmount > 0 && baseAmount > 0 && baseAmount < catalogAmount;
}

// ── Fulfillment data ────────────────────────────────────────────────────────
const fulfillment = orderDetails?.fulfillments?.[0] ?? null;
const isPickup = fulfillment?.type === "PICKUP";
const isShipment = fulfillment?.type === "SHIPMENT";

// Pickup specifics
const pickupDetails = fulfillment?.pickupDetails ?? null;
const pickupRecipient = pickupDetails?.recipient ?? null;
const pickupNoteRaw = pickupDetails?.note ?? "";
const customerNotesMatch = pickupNoteRaw.match(/Customer Notes:\s*(.+)$/s);
const customerNotes = customerNotesMatch?.[1]?.trim() ?? null;
const pickupAt = pickupDetails?.pickupAt
  ? new Date(pickupDetails.pickupAt)
  : null;
const pickupReadyText = pickupAt
  ? pickupAt.toLocaleString("en-US", {
      timeZone: "America/Chicago",
      weekday: "short",
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
      timeZoneName: "short",
    })
  : null;

// Shipment specifics
const shipmentDetails = fulfillment?.shipmentDetails ?? null;
const shipRecipient = shipmentDetails?.recipient ?? null;
const shipAddress = shipRecipient?.address ?? null;
const shipAddressLines = shipAddress
  ? [
      shipAddress.addressLine1,
      shipAddress.addressLine2,
      `${shipAddress.locality}, ${shipAddress.administrativeDistrictLevel1} ${shipAddress.postalCode}`,
    ]
      .filter(Boolean)
      .join("\n")
  : null;

// Contact email shown as "confirmation sent to"
const contactEmail = isPickup
  ? (pickupRecipient?.emailAddress ?? null)
  : (shipRecipient?.emailAddress ?? null);

// Separate the "Shipping" custom line item from product items
const shippingLineItem =
  orderDetails?.lineItems?.find(
    (item) => item.name === "Shipping" && !item.catalogObjectId,
  ) ?? null;
const productLineItems =
  orderDetails?.lineItems?.filter(
    (item) => !(item.name === "Shipping" && !item.catalogObjectId),
  ) ?? [];

// Order-level totals
const hasDiscount = Number(orderDetails?.totalDiscountMoney?.amount ?? 0) > 0;
const hasTax = Number(orderDetails?.totalTaxMoney?.amount ?? 0) > 0;
const hasFreeShipping = shippingLineItem === null && isShipment;

// Short human-friendly order reference (last 8 chars, matches email template)
const shortId = orderDetails?.id
  ? `#${orderDetails.id.slice(-8).toUpperCase()}`
  : "";

// Get the title and content from the page
const pageTitle = orderDetails?.id ? `Order ${shortId}` : "Order Confirmation";
const fullTitle = `${pageTitle} | El Camino`;
---

<Layout title={fullTitle}>
  <script nonce={Astro.locals.nonce} is:inline slot="head">
    // If orderId is missing from the URL (Square's legacy API doesn't always
    // append it), check sessionStorage for the one stored before the Square
    // hand-off. Runs in <head> to redirect before the page is painted.
    (function () {
      var params = new URLSearchParams(window.location.search);
      if (!params.get("orderId")) {
        var stored = sessionStorage.getItem("square-pending-orderId");
        if (stored) {
          params.set("orderId", stored);
          window.location.replace(
            window.location.pathname + "?" + params.toString(),
          );
        }
      }
    })();
  </script>
  <section class="max-w-2xl mx-auto px-4 py-16">
    {
      error ? (
        <div class="text-center">
          <h1 class="font-display font-black text-6xl lg:text-7xl xl:text-8xl 2xl:text-9xl leading-[0.8] text-(--content-heading) my-4 lg:my-0">
            Oops! Something went wrong
          </h1>
          <p class="text-(--content-body) mb-8">{error}</p>
          <a
            href="/"
            class="inline-block bg-(--ui-button-surface) text-(--ui-button-text) border-(--ui-button-border) hover:bg-(--ui-button-surface)/80 font-sans font-semibold transition-all duration-300 border-2 rounded-sm text-lg py-2 px-4"
          >
            Return to Home
          </a>
        </div>
      ) : !orderDetails ? (
        <div class="text-center">
          <h1 class="font-display font-black text-6xl lg:text-7xl xl:text-8xl 2xl:text-9xl leading-[0.8] text-(--content-heading) my-4 lg:my-0">
            Order Not Found
          </h1>
          <p class="text-(--content-body) mb-4">
            We couldn't locate your order details. If you completed payment,
            please check your email for a confirmation or contact us.
          </p>
          <a
            href="/"
            class="inline-block bg-(--ui-button-surface) text-(--ui-button-text) border-(--ui-button-border) hover:bg-(--ui-button-surface)/80 font-sans font-semibold transition-all duration-300 border-2 rounded-sm text-lg py-2 px-4"
          >
            Return to Home
          </a>
        </div>
      ) : (
        <div data-order-id={orderDetails.id}>
          {/* ── Header ─────────────────────────────────────────────────── */}
          <div class="text-center mb-8">
            <h1 class="font-display font-black text-6xl lg:text-7xl xl:text-8xl 2xl:text-9xl leading-[0.8] text-(--content-heading) my-4 lg:my-0">
              Thank You!
            </h1>
            <p class="text-(--content-body) mt-3">
              Your order has been confirmed.
            </p>
            <p class="font-mono text-sm font-semibold text-(--content-emphasis) mt-1">
              Order {shortId}
            </p>
            {contactEmail && (
              <p class="text-xs text-(--content-meta) mt-1">
                Confirmation sent to {contactEmail}
              </p>
            )}
          </div>

          {/* ── Order Summary ───────────────────────────────────────────── */}
          <div class="order-summary bg-(--surface-secondary) rounded-lg p-6 mb-6">
            <h2 class="font-display text-2xl mb-4 text-(--content-heading)">
              Order Summary
            </h2>

            {/* Product line items */}
            <div>
              {productLineItems.map((item) => {
                const details = (item.uid && lineItemDetails[item.uid]) || {};
                const onSale = item.uid ? isSaleItem(item, details) : false;
                return (
                  <div class="flex items-center py-4 border-b border-(--surface-tertiary)">
                    {/* Item image */}
                    <div class="w-16 h-16 mr-4 bg-(--surface-tertiary) rounded overflow-hidden shrink-0">
                      {item.uid && lineItemDetails[item.uid]?.image ? (
                        <Image
                          src={lineItemDetails[item.uid].image!}
                          alt={item.name || "Product"}
                          width={64}
                          height={64}
                          format="avif"
                          quality={85}
                          class="w-full h-full object-cover"
                          loading="lazy"
                        />
                      ) : (
                        <img
                          src={EL_CAMINO_LOGO_DATA_URI}
                          alt={item.name || "Product"}
                          class="w-full h-full object-contain p-2"
                          loading="lazy"
                        />
                      )}
                    </div>

                    {/* Item details */}
                    <div class="flex-1 flex justify-between gap-4 text-(--content-body)">
                      <div>
                        <div class="font-medium">{item.name}</div>
                        {item.uid &&
                          lineItemDetails[item.uid]?.variationName && (
                            <div class="text-sm text-(--content-meta)">
                              {lineItemDetails[item.uid].variationName}
                            </div>
                          )}
                        <div class="text-xs text-(--content-meta) mt-0.5">
                          Qty: {item.quantity}
                        </div>
                      </div>
                      <div class="text-right shrink-0">
                        <span class="font-display font-bold text-2xl self-center block">
                          {formatLineItemPreTax(item)}
                        </span>
                        {onSale && (
                          <span class="text-xs text-(--content-meta) line-through block">
                            {formatMoney({
                              amount:
                                Number(details.catalogPriceMoney?.amount ?? 0) *
                                Number(item.quantity ?? 1),
                              currency: "USD",
                            })}
                          </span>
                        )}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>

            {/* Totals breakdown */}
            <div class="pt-4 space-y-2 text-(--content-body)">
              {/* Shipping line item */}
              {shippingLineItem && (
                <div class="flex justify-between text-sm">
                  <span class="text-(--content-meta)">Shipping</span>
                  <span>{formatMoney(shippingLineItem.totalMoney)}</span>
                </div>
              )}
              {hasFreeShipping && (
                <div class="flex justify-between text-sm">
                  <span class="text-(--content-meta)">Shipping</span>
                  <span class="text-green-700 dark:text-green-400">Free</span>
                </div>
              )}

              {/* Discounts */}
              {hasDiscount && (
                <div class="flex justify-between text-sm">
                  <span class="text-(--content-meta)">Discounts</span>
                  <span class="text-green-700 dark:text-green-400">
                    &minus;{formatMoney(orderDetails.totalDiscountMoney)}
                  </span>
                </div>
              )}

              {/* Tax */}
              {hasTax && (
                <div class="flex justify-between text-sm">
                  <span class="text-(--content-meta)">Tax</span>
                  <span>{formatMoney(orderDetails.totalTaxMoney)}</span>
                </div>
              )}

              {/* Total */}
              <div class="flex justify-between font-bold text-(--content-emphasis) border-t border-(--surface-tertiary) pt-3 mt-1">
                <span>Total</span>
                <span class="font-display font-bold text-3xl">
                  {formatMoney(orderDetails.totalMoney)}
                </span>
              </div>
            </div>
          </div>

          {/* ── Fulfillment Details ─────────────────────────────────────── */}
          {(isPickup || isShipment) && (
            <div class="bg-(--surface-secondary) rounded-lg p-6 mb-6">
              {isPickup ? (
                <>
                  <h2 class="font-display text-2xl mb-4 text-(--content-heading)">
                    In-Store Pick Up
                  </h2>
                  <div class="space-y-3 text-(--content-body)">
                    <div>
                      <p class="text-xs uppercase tracking-wider text-(--content-meta) mb-1">
                        Location
                      </p>
                      <p class="font-medium">{contact.name}</p>
                      <p class="text-sm text-(--content-meta)">
                        {`${contact.street}, ${contact.city}, ${contact.state} ${contact.zip}`}
                      </p>
                      <p class="text-sm text-(--content-meta)">
                        {contact.phone}
                      </p>
                    </div>

                    {pickupReadyText && (
                      <div>
                        <p class="text-xs uppercase tracking-wider text-(--content-meta) mb-1">
                          Ready By
                        </p>
                        <p class="font-medium">{pickupReadyText}</p>
                        <p class="text-sm text-(--content-meta)">
                          We'll reach out if anything changes.
                        </p>
                      </div>
                    )}

                    {!pickupReadyText && (
                      <p class="text-sm text-(--content-meta)">
                        We'll reach out when your order is ready for pickup.
                      </p>
                    )}

                    {customerNotes && (
                      <div class="bg-(--surface-tertiary) rounded p-3">
                        <p class="text-xs uppercase tracking-wider text-(--content-meta) mb-1">
                          Your Note
                        </p>
                        <p class="text-sm italic">{customerNotes}</p>
                      </div>
                    )}
                  </div>
                </>
              ) : (
                <>
                  <h2 class="font-display text-2xl mb-4 text-(--content-heading)">
                    Shipping To
                  </h2>
                  <div class="space-y-3 text-(--content-body)">
                    <div>
                      {shipRecipient?.displayName && (
                        <p class="font-medium">{shipRecipient.displayName}</p>
                      )}
                      {shipAddressLines ? (
                        shipAddressLines
                          .split("\n")
                          .map((line) => (
                            <p class="text-sm text-(--content-meta)">{line}</p>
                          ))
                      ) : (
                        <p class="text-sm text-(--content-meta)">
                          Address on file
                        </p>
                      )}
                    </div>
                    <p class="text-sm text-(--content-meta)">
                      Estimated delivery: 5&ndash;7 business days. We'll email
                      you with tracking when your order ships.
                    </p>
                  </div>
                </>
              )}
            </div>
          )}

          {/* ── Footer ─────────────────────────────────────────────────── */}
          <div class="mt-2 text-center">
            <a
              href="/shop/all"
              class="inline-block bg-(--ui-button-surface) text-(--ui-button-text) border-(--ui-button-border) hover:bg-(--ui-button-surface)/80 font-sans font-semibold transition-all duration-300 border-2 rounded-sm text-lg py-2 px-4"
            >
              Continue Shopping
            </a>
          </div>
        </div>
      )
    }
  </section>
</Layout>

<script>
  import { cart } from "@/lib/cart";
  import { EL_CAMINO_LOGO_DATA_URI } from "@/lib/constants/assets";

  // Clear cart when order is confirmed — guarded so back-navigation doesn't re-clear
  document.addEventListener("astro:page-load", () => {
    const orderElement = document.querySelector("[data-order-id]");
    if (orderElement) {
      const orderId = orderElement.getAttribute("data-order-id");
      const storageKey = `cart-cleared-${orderId}`;
      if (orderId && !sessionStorage.getItem(storageKey)) {
        sessionStorage.setItem(storageKey, "1");
        sessionStorage.removeItem("square-pending-orderId");
        cart.clear();
      }
    }
  });

  // Client-side fallback for failed images
  document.addEventListener("astro:page-load", () => {
    const images = document.querySelectorAll("img[src*='square']");

    images.forEach((img) => {
      img.addEventListener("error", function (this: HTMLImageElement) {
        this.src = EL_CAMINO_LOGO_DATA_URI;
        this.alt = "Product image not available";
      });
    });
  });
</script>
