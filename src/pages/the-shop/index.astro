---
// src/pages/the-shop/index.astro
import Layout from "@/layouts/Layout.astro";
import { siteConfig } from "@/lib/site-config";
import Button from "@/components/Button.astro";
import { Icon } from "astro-icon/components";
import {
  EL_CAMINO_LOGO_DATA_URI,
  EL_CAMINO_LOADER_DATA_URI,
} from "@/lib/constants/assets";
import { getShopHours } from "@/lib/shopHours";
import { getContactInfo } from "@/lib/contactInfo";
import { getSocialLinks } from "@/lib/socialLinks";
import CategoryStrip from "@/components/CategoryStrip.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import OpenStatusBadge from "@/components/OpenStatusBadge.astro";
import { getPosts, getPostsByCategory } from "@/lib/wordpress/api";
import {
  extractEmbeddedData,
  generateFallbackContent,
} from "@/lib/wordpress/types";

const shopHours = await getShopHours();
const contact = await getContactInfo();
const social = await getSocialLinks();

// Fetch "Shop News" category posts, fall back to most recent posts if empty
const shopNewsPosts = await getPostsByCategory("shop-news");
const fallbackPosts = shopNewsPosts.length === 0 ? await getPosts() : [];
const newsToShow = (shopNewsPosts.length > 0 ? shopNewsPosts : fallbackPosts)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
---

<Layout title="The Shop | El Camino">
  <section class="p-1 pb-0 flex flex-col gap-1">
    <header
      class="flex flex-col-reverse lg:flex-row-reverse items-start lg:items-center gap-4 lg:gap-8"
    >
      <div class="basis-1/2 p-4 md:p-12 my-8 w-full">
        <div class="max-w-lg mx-auto">
          <div class="flex flex-row items-center">
            <h1
              class="font-display font-black text-6xl lg:text-7xl xl:text-8xl 2xl:text-9xl leading-none text-(--content-heading) text-balance mb-2"
            >
              The Shop
            </h1>
            <OpenStatusBadge class="self-start" />
          </div>
          <p
            class="font-semibold text-sm uppercase tracking-wide text-(--content-meta) mb-3"
          >
            Eau Claire's skater-owned skate shop — downtown since 2023
          </p>
          <p class="text-pretty mb-4">
            More than a skate shop. We're here to build and uplift our
            community, friends, and fellow skaters in the Chippewa Valley. {
              siteConfig.tagline
            }.
          </p>
          <div class="flex flex-row flex-wrap items-center gap-3 mt-8">
            <Button variant="primary" href="#our-story">Read Our Story</Button>
            <Button variant="outline" href="/shop/all">Shop Now</Button>
          </div>
        </div>
      </div>

      <div
        class="aspect-square border-4 border-(--surface-secondary) overflow-hidden bg-(--surface-secondary) relative basis-1/2 self-center w-full"
      >
        <div class="relative w-full h-full">
          <div
            class="loading-skeleton absolute inset-0 animate-pulse bg-linear-to-r from-gray-200 via-gray-100 to-gray-200"
            id="article-hero-placeholder"
          >
            <div
              class="absolute inset-0 flex items-center justify-center opacity-70"
              style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat;`}
            >
            </div>
          </div>

          <picture>
            <source
              srcset="/.netlify/images?url=/the-shop-01.png&fm=avif&w=1200&q=75"
              type="image/avif"
            />
            <source
              srcset="/.netlify/images?url=/the-shop-01.png&fm=webp&w=1200&q=75"
              type="image/webp"
            />
            <img
              src="/the-shop-01.png"
              alt="El Camino Skate Shop storefront"
              class="w-full h-full object-cover opacity-0 transition-opacity duration-300"
              loading="eager"
              fetchpriority="high"
              width="1200"
              height="1200"
              onload="this.style.opacity='0.9'; document.getElementById('article-hero-placeholder')?.remove()"
              onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; this.classList.add('opacity-100'); document.getElementById('article-hero-placeholder')?.remove()`}
            />
          </picture>
        </div>
      </div>
    </header>

    <!-- OUR STORY -->
    <div
      class="bg-(--surface-secondary) flex flex-col-reverse lg:flex-row items-start lg:items-center relative"
    >
      <div id="our-story" class="absolute h-16 -top-16" aria-hidden="true">
      </div>

      <div class="relative lg:basis-1/2 px-4 lg:p-8 xl:p-12 my-8">
        <div class="w-full md:max-w-lg mx-auto">
          <h2
            class="flex flex-col-reverse font-display font-black leading-none text-4xl md:text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl text-(--content-heading) text-balance mb-2"
          >
            Our Story
          </h2>
          <div class="space-y-4 text-pretty">
            <blockquote class="text-pretty text-(--content-meta)">
              "It was all a dream, I used to read Big Brother magazine."
            </blockquote>
            <p>
              It started with a 1979 Chevy El Camino and a simple idea: sell
              skate products out the back, pop-up style. Bring gear that wasn't
              available around Eau Claire to the people who needed it. After
              talking to folks in the industry, they all said the same thing:
              "Cool idea, but... you NEED a storefront."
            </p>
            <p>So that's what we did.</p>
            <p>
              Now the mission is clearer than ever: keep growing the skateboard
              scene in and around the Chippewa Valley. Whether you've never
              stepped on a board, a seasoned vet, or you're dusting yours off
              after years, this place is for you.
            </p>
          </div>
          <div class="flex flex-row flex-wrap items-center gap-3 mt-8">
            <Button variant="primary" href="#contact">Come Say Hi</Button>
            <Button variant="outline" href="/shop/all">Shop Now</Button>
          </div>
        </div>
      </div>

      <div
        class="grid grid-cols-2 grid-rows-2 gap-1 basis-1/2 aspect-video lg:aspect-square self-center w-full p-1"
      >
        <!-- Image 1: full-width top row -->
        <div
          class="col-span-2 relative overflow-hidden bg-(--surface-secondary)"
        >
          <div
            class="loading-skeleton absolute inset-0 animate-pulse bg-linear-to-r from-gray-200 via-gray-100 to-gray-200"
            id="story-placeholder-1"
          >
            <div
              class="absolute inset-0 flex items-center justify-center opacity-70"
              style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat;`}
            >
            </div>
          </div>
          <picture>
            <source
              srcset="/.netlify/images?url=/the-shop-02.png&fm=avif&w=1200&q=75"
              type="image/avif"
            />
            <source
              srcset="/.netlify/images?url=/the-shop-02.png&fm=webp&w=1200&q=75"
              type="image/webp"
            />
            <img
              src="/the-shop-02.png"
              alt="El Camino owners inside the shop"
              class="w-full h-full object-cover opacity-0 transition-opacity duration-300"
              loading="lazy"
              width="1200"
              height="600"
              onload="this.style.opacity='0.9'; document.getElementById('story-placeholder-1')?.remove()"
              onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; this.classList.add('opacity-100', 'error'); document.getElementById('story-placeholder-1')?.remove()`}
            />
          </picture>
        </div>

        <!-- Image 2: bottom-left -->
        <div class="relative overflow-hidden bg-(--surface-secondary)">
          <div
            class="loading-skeleton absolute inset-0 animate-pulse bg-linear-to-r from-gray-200 via-gray-100 to-gray-200"
            id="story-placeholder-2"
          >
            <div
              class="absolute inset-0 flex items-center justify-center opacity-70"
              style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat;`}
            >
            </div>
          </div>
          <picture>
            <source
              srcset="/.netlify/images?url=/the-shop-03.png&fm=avif&w=800&q=75"
              type="image/avif"
            />
            <source
              srcset="/.netlify/images?url=/the-shop-03.png&fm=webp&w=800&q=75"
              type="image/webp"
            />
            <img
              src="/the-shop-03.png"
              alt="El Camino shop interior with apparel"
              class="w-full h-full object-cover opacity-0 transition-opacity duration-300"
              loading="lazy"
              width="600"
              height="600"
              onload="this.style.opacity='0.9'; document.getElementById('story-placeholder-2')?.remove()"
              onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; this.classList.add('opacity-100', 'error'); document.getElementById('story-placeholder-2')?.remove()`}
            />
          </picture>
        </div>

        <!-- Image 3: bottom-right -->
        <div class="relative overflow-hidden bg-(--surface-secondary)">
          <div
            class="loading-skeleton absolute inset-0 animate-pulse bg-linear-to-r from-gray-200 via-gray-100 to-gray-200"
            id="story-placeholder-3"
          >
            <div
              class="absolute inset-0 flex items-center justify-center opacity-70"
              style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat;`}
            >
            </div>
          </div>
          <picture>
            <source
              srcset="/.netlify/images?url=/the-shop-04.png&fm=avif&w=800&q=75"
              type="image/avif"
            />
            <source
              srcset="/.netlify/images?url=/the-shop-04.png&fm=webp&w=800&q=75"
              type="image/webp"
            />
            <img
              src="/the-shop-04.png"
              alt="Skate decks on display at El Camino"
              class="w-full h-full object-cover opacity-0 transition-opacity duration-300"
              loading="lazy"
              width="800"
              height="450"
              onload="this.style.opacity='0.9'; document.getElementById('story-placeholder-3')?.remove()"
              onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; this.classList.add('opacity-100', 'error'); document.getElementById('story-placeholder-3')?.remove()`}
            />
          </picture>
        </div>
      </div>
    </div>

    <!-- CATEGORY STRIP -->
    <CategoryStrip title="Shop by Category" />

    <!-- CONTACT -->
    <div
      class="bg-(--surface-secondary) flex flex-col lg:flex-row-reverse items-stretch relative"
    >
      <div id="contact" class="absolute h-16 -top-16" aria-hidden="true"></div>
      <div class="relative w-full lg:basis-1/2 px-4 py-8 lg:p-8 xl:p-12 my-8">
        <div class="w-full max-w-xl mx-auto">
          <h2
            class="flex flex-col-reverse font-display font-black text-4xl leading-none md:text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl text-(--content-heading) text-balance mb-2"
          >
            Visit El Camino
          </h2>

          <div class="grid gap-6 mt-6 w-full">
            <div class="flex flex-col sm:flex-row justify-between gap-6">
              <!-- ADDRESS -->
              <div
                class="sm:basis-1/2 sm:border-r-2 border-(--border-primary) sm:pr-6"
              >
                <h3
                  class="font-semibold font-display text-xl text-(--content-emphasis) mb-1"
                >
                  Address
                </h3>
                <p>
                  {contact.street}<br />
                  {contact.city}, {contact.state}
                  {contact.zip}
                </p>
                <a
                  href={`https://maps.google.com/?q=${encodeURIComponent(`${contact.street}, ${contact.city}, ${contact.state} ${contact.zip}`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-(--content-body) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all block mt-3"
                >
                  Get Directions
                </a>
              </div>

              <!-- CONTACT -->
              <div class="sm:basis-1/2">
                <h3
                  class="font-semibold font-display text-xl text-(--content-emphasis) mb-1"
                >
                  Get in Touch
                </h3>
                <a
                  href={`tel:${contact.phoneRaw}`}
                  class="relative font-semibold text-(--content-body) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all block"
                >
                  {contact.phone}
                </a>
                <a
                  href={`mailto:${contact.email}`}
                  class="relative font-semibold text-(--content-body) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all block"
                >
                  {contact.email}
                </a>

                <div class="flex gap-2 mt-3">
                  {
                    social.map((social) => (
                      <a
                        href={social.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-(--content-heading) hover:text-(--content-emphasis) transition-colors"
                        aria-label={`Visit us on ${social.platform}`}
                      >
                        <Icon
                          name={social.icon}
                          class="w-6 h-auto"
                          aria-hidden="true"
                        />
                      </a>
                    ))
                  }
                </div>
              </div>
            </div>

            <div>
              <div class="flex items-center justify-between mb-2">
                <h3
                  class="font-semibold font-display text-xl text-(--content-emphasis)"
                >
                  Store Hours
                </h3>
                <OpenStatusBadge />
              </div>
              <!-- Shown by JS when an admin override is active for today -->
              <p
                id="hours-override-notice"
                class="hidden text-xs text-(--content-meta) italic mb-3 -mt-1"
              >
              </p>
              <div class="space-y-1" id="store-hours-list">
                {
                  shopHours.map((day) => (
                    <div
                      class="flex justify-between items-center border-b-2 border-(--border-tertiary) last-of-type:border-b-0 py-2"
                      data-day={day.day}
                      data-is-open={day.isOpen ? "true" : "false"}
                    >
                      <span
                        class={`flex items-center gap-1.5 ${!day.isOpen ? "text-(--content-meta) opacity-40" : ""}`}
                      >
                        <span
                          class="day-dot hidden w-1.5 h-1.5 rounded-full bg-(--ui-accent) shrink-0"
                          aria-hidden="true"
                        />
                        {day.day}
                        <span class="today-label hidden text-xs text-(--content-meta) font-normal">
                          (today)
                        </span>
                      </span>
                      <span
                        class={
                          !day.isOpen ? "text-(--content-meta) opacity-40" : ""
                        }
                      >
                        {day.hours}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>

            <script>
              {
                const now = new Date();
                const todayName = new Intl.DateTimeFormat("en-US", {
                  weekday: "long",
                }).format(now);

                // Highlight today's row
                const rows = document.querySelectorAll<HTMLElement>(
                  "#store-hours-list [data-day]",
                );
                rows.forEach((row) => {
                  if (row.dataset.day !== todayName) return;
                  row.classList.add(
                    "-mx-2",
                    "px-2",
                    "rounded-xs",
                    "bg-(--surface-tertiary)/30",
                  );
                  const [daySpan, hoursSpan] = Array.from(
                    row.children,
                  ) as HTMLElement[];
                  [daySpan, hoursSpan].forEach((s) => {
                    s.classList.remove("text-(--content-meta)", "opacity-40");
                    s.classList.add(
                      "text-(--content-emphasis)",
                      "font-semibold",
                    );
                  });
                  row
                    .querySelector<HTMLElement>(".day-dot")
                    ?.classList.remove("hidden");
                  row
                    .querySelector<HTMLElement>(".today-label")
                    ?.classList.remove("hidden");
                });
              }
            </script>

            <script>
              // Show a contextual notice when an admin override changes today's status.
              (async () => {
                const notice = document.getElementById("hours-override-notice");
                if (!notice) return;

                const now = new Date();
                const todayStr = [
                  now.getFullYear(),
                  String(now.getMonth() + 1).padStart(2, "0"),
                  String(now.getDate()).padStart(2, "0"),
                ].join("-");
                const monthDay = todayStr.slice(5); // "MM-DD"

                try {
                  const res = await fetch("/api/shop-status");
                  if (!res.ok) return;
                  const override = await res.json();

                  let message: string | null = null;

                  if (override.mode !== "auto") {
                    if (!override.until || override.until >= todayStr) {
                      message =
                        override.mode === "closed"
                          ? "Closed today"
                          : "Open today — special hours";
                    }
                  } else {
                    for (const h of override.holidays ?? []) {
                      if (
                        (h.date && h.date === todayStr) ||
                        (h.recurring && h.recurring === monthDay)
                      ) {
                        message = `Closed today — ${h.label}`;
                        break;
                      }
                    }
                  }

                  if (message) {
                    notice.textContent = `* ${message}`;
                    notice.classList.remove("hidden");
                  }
                } catch {
                  // Fail silently — notice just won't appear
                }
              })();
            </script>
          </div>
        </div>
      </div>

      <div
        class="aspect-square border-4 border-(--surface-secondary) overflow-hidden bg-(--surface-secondary) relative lg:basis-1/2 self-center w-full"
      >
        <div class="relative w-full h-full">
          <div
            class="loading-skeleton absolute inset-0 animate-pulse bg-linear-to-r from-gray-200 via-gray-100 to-gray-200"
            id="location-placeholder"
          >
            <div
              class="absolute inset-0 flex items-center justify-center opacity-70"
              style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat;`}
            >
            </div>
          </div>

          <picture>
            <source
              srcset="/.netlify/images?url=/the-shop-04.png&fm=avif&w=1200&q=75"
              type="image/avif"
            />
            <source
              srcset="/.netlify/images?url=/the-shop-04.png&fm=webp&w=1200&q=75"
              type="image/webp"
            />
            <img
              src="/the-shop-04.png"
              alt="Water Street location"
              class="w-full h-full mix-blend-luminosity object-cover opacity-0 transition-opacity duration-300"
              loading="lazy"
              width="1200"
              height="1200"
              onload="this.style.opacity='0.9'; document.getElementById('location-placeholder')?.remove()"
              onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; this.classList.add('opacity-100', 'error'); document.getElementById('location-placeholder')?.remove()`}
            />
          </picture>
        </div>
      </div>
    </div>

    <!-- FROM THE SHOP (News Teasers) -->
    {
      newsToShow.length > 0 && (
        <div class="bg-(--surface-primary) px-4 sm:px-6 lg:px-8 py-8">
          <div class="flex items-end justify-between mb-6 lg:mb-8">
            <div>
              <p class="text-xs uppercase tracking-widest text-(--content-meta)">
                From the Shop
              </p>
              <h2 class="text-2xl lg:text-3xl font-display font-bold text-(--content-heading) leading-none">
                The Latest News
              </h2>
            </div>
            <a
              href="/news"
              class="px-2.5 py-1.5 text-sm border rounded-sm bg-(--surface-secondary) hover:bg-(--surface-tertiary) transition-colors text-(--ui-input-text) border-(--ui-input-border)/50 hidden sm:inline-block shrink-0 mb-0.5"
            >
              All News →
            </a>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {newsToShow.map((post) => {
              const embeddedData = extractEmbeddedData(post);
              const fallbackContent = generateFallbackContent(post);
              return (
                <ArticleCard
                  post={post}
                  variant="teaser"
                  embeddedData={embeddedData}
                  fallbackContent={fallbackContent}
                />
              );
            })}
          </div>

          <div class="sm:hidden">
            <a
              href="/news"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-(--content-link) hover:underline"
            >
              See all news →
            </a>
          </div>
        </div>
      )
    }
  </section>
</Layout>
