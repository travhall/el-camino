---
/**
 * Core Web Vitals Detailed Analysis
 * p75 field data from the Chrome UX Report API.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";

const pageTitle = "Core Web Vitals";
const pageDescription =
  "Detailed Core Web Vitals metrics from real Chrome users via the Chrome UX Report.";
---

<AdminLayout
  title={pageTitle}
  description={pageDescription}
  activeSection="core-vitals"
>
  <!-- Loading -->
  <div id="cwv-loading" class="py-12 text-center text-(--content-meta) text-sm">
    Loading field data…
  </div>

  <!-- No API key -->
  <div id="cwv-no-key" class="hidden">
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-8 text-center">
      <h2 class="text-lg font-semibold text-(--content-heading) mb-2">CrUX API key required</h2>
      <p class="text-(--content-meta) text-sm max-w-md mx-auto">
        Add a <code class="font-mono text-xs bg-(--surface-tertiary) px-1 rounded">CRUX_API_KEY</code> environment variable in your Netlify site settings to enable real field data.
      </p>
      <p class="text-xs text-(--content-meta) mt-3">
        Get a free key at <span class="font-mono">console.cloud.google.com</span> → APIs &amp; Services → Chrome UX Report API.
      </p>
    </div>
  </div>

  <!-- No data -->
  <div id="cwv-no-data" class="hidden">
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-8 text-center">
      <svg class="w-12 h-12 mx-auto mb-4 text-(--content-meta)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>
      <h2 class="text-lg font-semibold text-(--content-heading) mb-2">No field data yet</h2>
      <p class="text-(--content-meta) text-sm max-w-md mx-auto">
        Chrome UX Report data becomes available once the site receives sufficient
        real-user traffic (~1,000 visits). Check back after launch.
      </p>
    </div>
  </div>

  <!-- Data -->
  <div id="cwv-data" class="hidden">
    <!-- Current values -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-(--content-heading)">Current p75 Values</h2>
        <p class="text-sm text-(--content-meta)">Chrome UX Report · real-user field data</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- LCP -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="text-xl font-semibold text-(--content-heading)">Largest Contentful Paint</h3>
              <p class="text-sm text-(--content-meta)">75th percentile · Target: ≤ 2.5s</p>
            </div>
            <span id="lcp-badge" class="cwv-badge cwv-unknown">—</span>
          </div>
          <div class="flex items-end gap-2 mb-4">
            <span id="lcp-value" class="text-4xl font-bold text-(--content-heading)">—</span>
            <span class="text-lg text-(--content-body) mb-1">seconds</span>
          </div>
          <div class="text-sm text-(--content-meta)">
            <span id="lcp-good-pct"></span>
          </div>
        </div>

        <!-- INP -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="text-xl font-semibold text-(--content-heading)">Interaction to Next Paint</h3>
              <p class="text-sm text-(--content-meta)">75th percentile · Target: ≤ 200ms</p>
            </div>
            <span id="inp-badge" class="cwv-badge cwv-unknown">—</span>
          </div>
          <div class="flex items-end gap-2 mb-4">
            <span id="inp-value" class="text-4xl font-bold text-(--content-heading)">—</span>
            <span class="text-lg text-(--content-body) mb-1">milliseconds</span>
          </div>
          <div class="text-sm text-(--content-meta)">
            <span id="inp-good-pct"></span>
          </div>
        </div>

        <!-- CLS -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="text-xl font-semibold text-(--content-heading)">Cumulative Layout Shift</h3>
              <p class="text-sm text-(--content-meta)">75th percentile · Target: ≤ 0.1</p>
            </div>
            <span id="cls-badge" class="cwv-badge cwv-unknown">—</span>
          </div>
          <div class="flex items-end gap-2 mb-4">
            <span id="cls-value" class="text-4xl font-bold text-(--content-heading)">—</span>
            <span class="text-lg text-(--content-body) mb-1">score</span>
          </div>
          <div class="text-sm text-(--content-meta)">
            <span id="cls-good-pct"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Additional signals -->
    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-(--content-heading) mb-6">Additional Signals</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <h3 class="font-semibold text-(--content-heading) mb-1">First Contentful Paint</h3>
          <p class="text-sm text-(--content-meta) mb-4">p75 · Target: ≤ 1.8s</p>
          <div class="flex items-end gap-2">
            <span id="fcp-value" class="text-3xl font-bold text-(--content-heading)">—</span>
            <span class="text-sm text-(--content-body) mb-1">seconds</span>
          </div>
        </div>
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <h3 class="font-semibold text-(--content-heading) mb-1">Time to First Byte</h3>
          <p class="text-sm text-(--content-meta) mb-4">p75 · Target: ≤ 800ms</p>
          <div class="flex items-end gap-2">
            <span id="ttfb-value" class="text-3xl font-bold text-(--content-heading)">—</span>
            <span class="text-sm text-(--content-body) mb-1">milliseconds</span>
          </div>
        </div>
      </div>
    </section>

    <!-- General optimization guidance (static, always accurate) -->
    <section>
      <h2 class="text-2xl font-semibold text-(--content-heading) mb-6">
        Optimization Reference
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- LCP guidance -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <h3 class="text-lg font-semibold text-(--content-heading) mb-4">Improving LCP</h3>
          <div class="space-y-3 text-sm text-(--content-body)">
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Preload hero image</div>
              <div class="text-(--content-meta)">Use <code class="text-xs font-mono">fetchpriority="high"</code> on the LCP image</div>
            </div>
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Serve next-gen formats</div>
              <div class="text-(--content-meta)">AVIF/WebP via Netlify Image CDN (already configured)</div>
            </div>
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Reduce TTFB</div>
              <div class="text-(--content-meta)">Edge caching via Netlify CDN reduces server round-trip</div>
            </div>
          </div>
        </div>

        <!-- INP guidance -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <h3 class="text-lg font-semibold text-(--content-heading) mb-4">Improving INP</h3>
          <div class="space-y-3 text-sm text-(--content-body)">
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Minimize main-thread work</div>
              <div class="text-(--content-meta)">Defer or remove non-critical JavaScript</div>
            </div>
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Break up long tasks</div>
              <div class="text-(--content-meta)">Keep individual JS tasks under 50ms</div>
            </div>
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Avoid render-blocking scripts</div>
              <div class="text-(--content-meta)">Use <code class="text-xs font-mono">defer</code> or <code class="text-xs font-mono">async</code> on all non-critical scripts</div>
            </div>
          </div>
        </div>

        <!-- CLS guidance -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <h3 class="text-lg font-semibold text-(--content-heading) mb-4">Improving CLS</h3>
          <div class="space-y-3 text-sm text-(--content-body)">
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Set image dimensions</div>
              <div class="text-(--content-meta)">Always include <code class="text-xs font-mono">width</code> and <code class="text-xs font-mono">height</code> attributes</div>
            </div>
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Preload web fonts</div>
              <div class="text-(--content-meta)">Font preloading is already configured in netlify.toml</div>
            </div>
            <div class="p-3 bg-(--surface-tertiary) rounded">
              <div class="font-medium text-(--content-heading) mb-0.5">Reserve space for dynamic content</div>
              <div class="text-(--content-meta)">Use <code class="text-xs font-mono">min-height</code> on containers that load async content</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</AdminLayout>

<style>
  .cwv-badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    letter-spacing: 0.05em;
  }

  .cwv-good {
    background-color: #d1fae5;
    color: #065f46;
  }

  .cwv-needs-improvement {
    background-color: #fef3c7;
    color: #92400e;
  }

  .cwv-poor {
    background-color: #fee2e2;
    color: #991b1b;
  }

  .cwv-unknown {
    background-color: var(--surface-tertiary, #f3f4f6);
    color: var(--content-meta, #6b7280);
  }
</style>

<script>
  type CruxOk = {
    status: "ok";
    origin: string;
    lcp: number | null;
    inp: number | null;
    cls: number | null;
    fcp: number | null;
    ttfb: number | null;
    lcpGoodPercent: number | null;
    inpGoodPercent: number | null;
    clsGoodPercent: number | null;
  };

  type CruxResponse =
    | { status: "no_data"; origin: string }
    | { status: "no_key"; origin: string }
    | CruxOk;

  function badgeClass(v: number | null, good: number, poor: number): string {
    if (v === null) return "cwv-badge cwv-unknown";
    if (v <= good) return "cwv-badge cwv-good";
    if (v <= poor) return "cwv-badge cwv-needs-improvement";
    return "cwv-badge cwv-poor";
  }

  function badgeLabel(v: number | null, good: number, poor: number): string {
    if (v === null) return "No data";
    if (v <= good) return "Good";
    if (v <= poor) return "Needs Improvement";
    return "Poor";
  }

  function pctLabel(pct: number | null): string {
    if (pct === null) return "";
    return `${Math.round(pct * 100)}% of URLs rated "Good"`;
  }

  async function loadCwv() {
    const loading = document.getElementById("cwv-loading")!;
    const noKey = document.getElementById("cwv-no-key")!;
    const noData = document.getElementById("cwv-no-data")!;
    const dataView = document.getElementById("cwv-data")!;

    try {
      const res = await fetch("/api/crux-data");
      const data: CruxResponse = await res.json();

      loading.classList.add("hidden");

      if (data.status === "no_key") {
        noKey.classList.remove("hidden");
        return;
      }

      if (data.status === "no_data") {
        noData.classList.remove("hidden");
        return;
      }

      // LCP
      document.getElementById("lcp-value")!.textContent =
        data.lcp !== null ? (data.lcp / 1000).toFixed(1) : "—";
      const lcpBadge = document.getElementById("lcp-badge")!;
      lcpBadge.textContent = badgeLabel(data.lcp, 2500, 4000);
      lcpBadge.className = badgeClass(data.lcp, 2500, 4000);
      document.getElementById("lcp-good-pct")!.textContent = pctLabel(data.lcpGoodPercent);

      // INP
      document.getElementById("inp-value")!.textContent =
        data.inp !== null ? Math.round(data.inp).toString() : "—";
      const inpBadge = document.getElementById("inp-badge")!;
      inpBadge.textContent = badgeLabel(data.inp, 200, 500);
      inpBadge.className = badgeClass(data.inp, 200, 500);
      document.getElementById("inp-good-pct")!.textContent = pctLabel(data.inpGoodPercent);

      // CLS
      document.getElementById("cls-value")!.textContent =
        data.cls !== null ? data.cls.toFixed(2) : "—";
      const clsBadge = document.getElementById("cls-badge")!;
      clsBadge.textContent = badgeLabel(data.cls, 0.1, 0.25);
      clsBadge.className = badgeClass(data.cls, 0.1, 0.25);
      document.getElementById("cls-good-pct")!.textContent = pctLabel(data.clsGoodPercent);

      // FCP
      document.getElementById("fcp-value")!.textContent =
        data.fcp !== null ? (data.fcp / 1000).toFixed(1) : "—";

      // TTFB
      document.getElementById("ttfb-value")!.textContent =
        data.ttfb !== null ? Math.round(data.ttfb).toString() : "—";

      dataView.classList.remove("hidden");
    } catch {
      loading.textContent = "Could not load field data.";
    }
  }

  loadCwv();
</script>
