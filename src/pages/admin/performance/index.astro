---
/**
 * Performance Admin Overview
 * Real CWV field data from the Chrome UX Report API.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";

const pageTitle = "Performance Overview";
const pageDescription =
  "Core Web Vitals field data from real Chrome users via the Chrome UX Report.";
---

<AdminLayout
  title={pageTitle}
  description={pageDescription}
  activeSection="performance"
>
  <!-- Loading state -->
  <div id="perf-loading" class="py-12 text-center text-(--content-meta) text-sm">
    Loading field data…
  </div>

  <!-- No API key state -->
  <div id="perf-no-key" class="hidden">
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-8 text-center">
      <h2 class="text-lg font-semibold text-(--content-heading) mb-2">CrUX API key required</h2>
      <p class="text-(--content-meta) text-sm max-w-md mx-auto">
        Add a <code class="font-mono text-xs bg-(--surface-tertiary) px-1 rounded">CRUX_API_KEY</code> environment variable in your Netlify site settings to enable real field data.
      </p>
      <p class="text-xs text-(--content-meta) mt-3">
        Get a free key at <span class="font-mono">console.cloud.google.com</span> → APIs &amp; Services → Chrome UX Report API.
      </p>
    </div>
  </div>

  <!-- No data state -->
  <div id="perf-no-data" class="hidden">
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-8 text-center">
      <svg class="w-12 h-12 mx-auto mb-4 text-(--content-meta)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>
      <h2 class="text-lg font-semibold text-(--content-heading) mb-2">No field data yet</h2>
      <p class="text-(--content-meta) text-sm max-w-md mx-auto">
        Chrome UX Report data becomes available once the site receives sufficient
        real-user traffic (approximately 1,000 visits). Check back after launch.
      </p>
      <p class="text-xs text-(--content-meta) mt-3">
        Origin: <span id="no-data-origin" class="font-mono"></span>
      </p>
    </div>
  </div>

  <!-- Data view -->
  <div id="perf-data" class="hidden">
    <!-- Core Web Vitals -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-(--content-heading)">
          Core Web Vitals
        </h2>
        <p class="text-sm text-(--content-meta)">p75 field data · Chrome UX Report</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- LCP -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-(--content-heading)">Largest Contentful Paint</h3>
              <p class="text-sm text-(--content-meta)">Loading performance</p>
            </div>
            <span id="lcp-badge" class="cwv-badge">—</span>
          </div>
          <div class="mb-4">
            <div class="flex items-end gap-2 mb-1">
              <span id="lcp-value" class="text-3xl font-bold text-(--content-heading)">—</span>
              <span class="text-sm text-(--content-body) mb-1">seconds</span>
            </div>
            <div class="text-sm text-(--content-meta)">Target: ≤ 2.5s</div>
          </div>
          <div class="text-sm text-(--content-meta)">
            <span id="lcp-good-pct"></span>
          </div>
        </div>

        <!-- INP -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-(--content-heading)">Interaction to Next Paint</h3>
              <p class="text-sm text-(--content-meta)">Responsiveness</p>
            </div>
            <span id="inp-badge" class="cwv-badge">—</span>
          </div>
          <div class="mb-4">
            <div class="flex items-end gap-2 mb-1">
              <span id="inp-value" class="text-3xl font-bold text-(--content-heading)">—</span>
              <span class="text-sm text-(--content-body) mb-1">milliseconds</span>
            </div>
            <div class="text-sm text-(--content-meta)">Target: ≤ 200ms</div>
          </div>
          <div class="text-sm text-(--content-meta)">
            <span id="inp-good-pct"></span>
          </div>
        </div>

        <!-- CLS -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-(--content-heading)">Cumulative Layout Shift</h3>
              <p class="text-sm text-(--content-meta)">Visual stability</p>
            </div>
            <span id="cls-badge" class="cwv-badge">—</span>
          </div>
          <div class="mb-4">
            <div class="flex items-end gap-2 mb-1">
              <span id="cls-value" class="text-3xl font-bold text-(--content-heading)">—</span>
              <span class="text-sm text-(--content-body) mb-1">score</span>
            </div>
            <div class="text-sm text-(--content-meta)">Target: ≤ 0.1</div>
          </div>
          <div class="text-sm text-(--content-meta)">
            <span id="cls-good-pct"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Additional signals -->
    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-(--content-heading) mb-6">
        Additional Signals
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- FCP -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <h3 class="font-semibold text-(--content-heading) mb-1">First Contentful Paint</h3>
          <p class="text-sm text-(--content-meta) mb-4">Time until first content is rendered</p>
          <div class="flex items-end gap-2">
            <span id="fcp-value" class="text-3xl font-bold text-(--content-heading)">—</span>
            <span class="text-sm text-(--content-body) mb-1">seconds</span>
          </div>
          <div class="text-sm text-(--content-meta) mt-1">Target: ≤ 1.8s</div>
        </div>

        <!-- TTFB -->
        <div class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)">
          <h3 class="font-semibold text-(--content-heading) mb-1">Time to First Byte</h3>
          <p class="text-sm text-(--content-meta) mb-4">Server response time</p>
          <div class="flex items-end gap-2">
            <span id="ttfb-value" class="text-3xl font-bold text-(--content-heading)">—</span>
            <span class="text-sm text-(--content-body) mb-1">milliseconds</span>
          </div>
          <div class="text-sm text-(--content-meta) mt-1">Target: ≤ 800ms</div>
        </div>
      </div>
    </section>

    <!-- Link to detailed view -->
    <div class="flex gap-4">
      <a href="/admin/performance/core-vitals"
        class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-4">
        Detailed CWV Analysis →
      </a>
    </div>
  </div>
</AdminLayout>

<style>
  .cwv-badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    letter-spacing: 0.05em;
  }

  .cwv-good {
    background-color: #d1fae5;
    color: #065f46;
  }

  .cwv-needs-improvement {
    background-color: #fef3c7;
    color: #92400e;
  }

  .cwv-poor {
    background-color: #fee2e2;
    color: #991b1b;
  }

  .cwv-unknown {
    background-color: var(--surface-tertiary, #f3f4f6);
    color: var(--content-meta, #6b7280);
  }
</style>

<script>
  type CruxOk = {
    status: "ok";
    origin: string;
    lcp: number | null;
    inp: number | null;
    cls: number | null;
    fcp: number | null;
    ttfb: number | null;
    lcpGoodPercent: number | null;
    inpGoodPercent: number | null;
    clsGoodPercent: number | null;
  };

  type CruxResponse =
    | { status: "no_data"; origin: string }
    | { status: "no_key"; origin: string }
    | CruxOk;

  function badgeClass(value: number | null, good: number, poor: number): string {
    if (value === null) return "cwv-badge cwv-unknown";
    if (value <= good) return "cwv-badge cwv-good";
    if (value <= poor) return "cwv-badge cwv-needs-improvement";
    return "cwv-badge cwv-poor";
  }

  function badgeLabel(value: number | null, good: number, poor: number): string {
    if (value === null) return "No data";
    if (value <= good) return "Good";
    if (value <= poor) return "Needs Improvement";
    return "Poor";
  }

  function pctLabel(pct: number | null): string {
    if (pct === null) return "";
    return `${Math.round(pct * 100)}% of URLs in "Good" range`;
  }

  async function loadPerf() {
    const loading = document.getElementById("perf-loading")!;
    const noKey = document.getElementById("perf-no-key")!;
    const noData = document.getElementById("perf-no-data")!;
    const dataView = document.getElementById("perf-data")!;

    try {
      const res = await fetch("/api/crux-data");
      const data: CruxResponse = await res.json();

      loading.classList.add("hidden");

      if (data.status === "no_key") {
        noKey.classList.remove("hidden");
        return;
      }

      if (data.status === "no_data") {
        const originEl = document.getElementById("no-data-origin");
        if (originEl) originEl.textContent = data.origin;
        noData.classList.remove("hidden");
        return;
      }

      // LCP
      const lcpEl = document.getElementById("lcp-value")!;
      const lcpBadge = document.getElementById("lcp-badge")!;
      lcpEl.textContent = data.lcp !== null ? (data.lcp / 1000).toFixed(1) : "—";
      lcpBadge.textContent = badgeLabel(data.lcp, 2500, 4000);
      lcpBadge.className = badgeClass(data.lcp, 2500, 4000);
      document.getElementById("lcp-good-pct")!.textContent = pctLabel(data.lcpGoodPercent);

      // INP
      const inpEl = document.getElementById("inp-value")!;
      const inpBadge = document.getElementById("inp-badge")!;
      inpEl.textContent = data.inp !== null ? Math.round(data.inp).toString() : "—";
      inpBadge.textContent = badgeLabel(data.inp, 200, 500);
      inpBadge.className = badgeClass(data.inp, 200, 500);
      document.getElementById("inp-good-pct")!.textContent = pctLabel(data.inpGoodPercent);

      // CLS
      const clsEl = document.getElementById("cls-value")!;
      const clsBadge = document.getElementById("cls-badge")!;
      clsEl.textContent = data.cls !== null ? data.cls.toFixed(2) : "—";
      clsBadge.textContent = badgeLabel(data.cls, 0.1, 0.25);
      clsBadge.className = badgeClass(data.cls, 0.1, 0.25);
      document.getElementById("cls-good-pct")!.textContent = pctLabel(data.clsGoodPercent);

      // FCP
      const fcpEl = document.getElementById("fcp-value")!;
      fcpEl.textContent = data.fcp !== null ? (data.fcp / 1000).toFixed(1) : "—";

      // TTFB
      const ttfbEl = document.getElementById("ttfb-value")!;
      ttfbEl.textContent = data.ttfb !== null ? Math.round(data.ttfb).toString() : "—";

      dataView.classList.remove("hidden");
    } catch {
      loading.textContent = "Could not load field data.";
    }
  }

  loadPerf();
</script>
