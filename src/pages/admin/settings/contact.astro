---
// src/pages/admin/settings/contact.astro
// Admin UI for editing shop contact information.

import AdminLayout from "@/layouts/AdminLayout.astro";
import { getContactInfo } from "@/lib/contactInfo";

const saved = Astro.url.searchParams.has("saved");
const contact = await getContactInfo();

const INPUT_CLASS =
  "w-full border border-(--border-primary) bg-(--surface-primary) text-(--content-body) rounded-sm px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-(--content-body)/30 focus:ring-offset-1";
const BTN_CLASS =
  "font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap";
---

<AdminLayout
  title="Contact Info"
  description="Update the shop's name, address, phone number, and email. Changes appear in the site footer immediately."
>
  {saved && (
    <div role="status" class="saved-banner mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800">
      Contact info saved successfully.
    </div>
  )}

  <form
    method="POST"
    action="/api/admin/contact"
    class="border border-(--border-primary) border-l-4 border-l-violet-500 rounded-sm overflow-hidden"
  >
    <!-- Header -->
    <div class="flex flex-wrap items-center gap-3 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
      <p class="text-base font-semibold text-(--content-heading)">Shop Details</p>
      <p class="text-sm text-(--content-meta)">Displayed in the site footer.</p>
    </div>

    <!-- Fields -->
    <div class="divide-y divide-(--border-primary)">
      <!-- Business name -->
      <div class="flex flex-wrap items-center gap-4 px-4 py-3.5">
        <label class="w-36 shrink-0 text-sm font-semibold text-(--content-heading)" for="contact-name">
          Business name
        </label>
        <input
          id="contact-name"
          type="text"
          name="name"
          value={contact.name}
          autocomplete="organization"
          class={INPUT_CLASS}
          required
        />
      </div>

      <!-- Street -->
      <div class="flex flex-wrap items-center gap-4 px-4 py-3.5">
        <label class="w-36 shrink-0 text-sm font-semibold text-(--content-heading)" for="contact-street">
          Street
        </label>
        <input
          id="contact-street"
          type="text"
          name="street"
          value={contact.street}
          autocomplete="street-address"
          class={INPUT_CLASS}
          required
        />
      </div>

      <!-- City / State / ZIP -->
      <div class="flex flex-wrap items-center gap-4 px-4 py-3.5">
        <span class="w-36 shrink-0 text-sm font-semibold text-(--content-heading)">City / State / ZIP</span>
        <div class="flex flex-wrap gap-2 flex-1 min-w-0">
          <input
            type="text"
            name="city"
            value={contact.city}
            placeholder="City"
            autocomplete="address-level2"
            class={`${INPUT_CLASS} flex-1 min-w-[8rem]`}
            required
          />
          <input
            type="text"
            name="state"
            value={contact.state}
            placeholder="State"
            autocomplete="address-level1"
            maxlength="2"
            class={`${INPUT_CLASS} w-16`}
            required
          />
          <input
            type="text"
            name="zip"
            value={contact.zip}
            placeholder="ZIP"
            autocomplete="postal-code"
            maxlength="10"
            class={`${INPUT_CLASS} w-24`}
            required
          />
        </div>
      </div>

      <!-- Phone -->
      <div class="flex flex-wrap items-center gap-4 px-4 py-3.5">
        <label class="w-36 shrink-0 text-sm font-semibold text-(--content-heading)" for="contact-phone">
          Phone
        </label>
        <input
          id="contact-phone"
          type="tel"
          name="phone"
          value={contact.phone}
          placeholder="(715) 912-1169"
          autocomplete="tel"
          class={INPUT_CLASS}
          required
        />
      </div>

      <!-- Email -->
      <div class="flex flex-wrap items-center gap-4 px-4 py-3.5">
        <label class="w-36 shrink-0 text-sm font-semibold text-(--content-heading)" for="contact-email">
          Email
        </label>
        <input
          id="contact-email"
          type="email"
          name="email"
          value={contact.email}
          autocomplete="email"
          class={INPUT_CLASS}
          required
        />
      </div>
    </div>

    <!-- Footer actions -->
    <div class="flex items-center justify-end px-4 py-3 bg-(--surface-primary) border-t border-(--border-primary)">
      <button type="submit" class={BTN_CLASS}>Save Contact Info</button>
    </div>
  </form>
</AdminLayout>

<script>
  const banner = document.querySelector<HTMLElement>(".saved-banner");
  if (banner) {
    setTimeout(() => {
      banner.style.transition = "opacity 0.5s ease";
      banner.style.opacity = "0";
      setTimeout(() => banner.remove(), 500);
      const url = new URL(window.location.href);
      url.searchParams.delete("saved");
      history.replaceState(null, "", url.toString());
    }, 4000);
  }
</script>
