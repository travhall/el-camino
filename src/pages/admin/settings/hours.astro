---
// src/pages/admin/settings/hours.astro
// Admin UI for editing the regular weekly business hours schedule.

import AdminLayout from "@/layouts/AdminLayout.astro";
import { getShopHoursRaw, DAYS_OF_WEEK, formatTime } from "@/lib/shopHours";

const saved = Astro.url.searchParams.has("saved");
const entries = await getShopHoursRaw();

// Map to a lookup for easy template access
const byDay = Object.fromEntries(entries.map((e) => [e.day, e]));

const INPUT_CLASS =
  "border border-(--border-primary) bg-(--surface-primary) text-(--content-body) rounded-sm px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-(--content-body)/30 focus:ring-offset-1 disabled:opacity-40 disabled:cursor-not-allowed";
const BTN_CLASS =
  "font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap";
---

<AdminLayout
  title="Business Hours"
  description="Set the regular weekly schedule. The open/closed badge and hours table update instantly."
>
  {saved && (
    <div role="status" class="saved-banner mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800">
      Hours saved successfully.
    </div>
  )}

  <div class="border border-(--border-primary) border-l-4 border-l-violet-500 rounded-sm overflow-hidden">
    <!-- Header -->
    <div class="flex flex-wrap items-center gap-3 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
      <p class="text-base font-semibold text-(--content-heading)">Weekly Schedule</p>
      <p class="text-sm text-(--content-meta)">
        Changes take effect immediately — no rebuild required.
      </p>
    </div>

    <!-- Form -->
    <form method="POST" action="/api/admin/hours" class="divide-y divide-(--border-primary)">
      {DAYS_OF_WEEK.map((day) => {
        const entry = byDay[day] ?? { day, isOpen: false, open: "", close: "" };
        return (
          <div
            class="hours-row flex flex-wrap items-center gap-4 px-4 py-3.5"
            data-day={day}
          >
            <!-- Day label -->
            <span class="w-28 shrink-0 text-sm font-semibold text-(--content-heading)">
              {day}
            </span>

            <!-- Open toggle -->
            <label class="flex items-center gap-2 cursor-pointer select-none shrink-0">
              <input
                type="checkbox"
                name={`isOpen_${day}`}
                class="hours-toggle w-4 h-4 accent-(--content-heading) cursor-pointer"
                checked={entry.isOpen}
                aria-label={`${day} is open`}
              />
              <span class="text-sm text-(--content-body)">Open</span>
            </label>

            <!-- Time range -->
            <div class="hours-times flex items-center gap-2 flex-wrap" aria-label={`${day} hours`}>
              <label class="flex items-center gap-1.5">
                <span class="text-xs text-(--content-meta) shrink-0">Opens</span>
                <input
                  type="time"
                  name={`open_${day}`}
                  value={entry.open || "11:00"}
                  disabled={!entry.isOpen}
                  class={INPUT_CLASS}
                  aria-label={`${day} opening time`}
                />
              </label>
              <span class="text-(--content-meta) text-sm">–</span>
              <label class="flex items-center gap-1.5">
                <span class="text-xs text-(--content-meta) shrink-0">Closes</span>
                <input
                  type="time"
                  name={`close_${day}`}
                  value={entry.close || "19:00"}
                  disabled={!entry.isOpen}
                  class={INPUT_CLASS}
                  aria-label={`${day} closing time`}
                />
              </label>
            </div>

            <!-- Current display value (read-only hint) -->
            <span class="ml-auto text-xs text-(--content-meta) shrink-0 hidden sm:block">
              {entry.isOpen
                ? `${formatTime(entry.open)} – ${formatTime(entry.close)}`
                : "Closed"}
            </span>
          </div>
        );
      })}

      <!-- Footer actions -->
      <div class="flex items-center justify-between px-4 py-3 bg-(--surface-primary)">
        <p class="text-xs text-(--content-meta)">
          Use the <a href="/admin/notifications/shop-status" class="underline underline-offset-2 hover:text-(--content-body) transition-colors">Open Status</a> page to override today's badge for holidays or special closures.
        </p>
        <button type="submit" class={BTN_CLASS}>Save Hours</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  // Toggle time inputs enabled/disabled when a day's Open checkbox changes.
  document.querySelectorAll<HTMLInputElement>(".hours-toggle").forEach((cb) => {
    const row = cb.closest<HTMLElement>(".hours-row");
    if (!row) return;

    function syncInputs() {
      row!.querySelectorAll<HTMLInputElement>('input[type="time"]').forEach((input) => {
        input.disabled = !cb.checked;
      });
    }

    cb.addEventListener("change", syncInputs);
  });

  // Auto-dismiss saved banner
  const banner = document.querySelector<HTMLElement>(".saved-banner");
  if (banner) {
    setTimeout(() => {
      banner.style.transition = "opacity 0.5s ease";
      banner.style.opacity = "0";
      setTimeout(() => banner.remove(), 500);
      const url = new URL(window.location.href);
      url.searchParams.delete("saved");
      history.replaceState(null, "", url.toString());
    }, 4000);
  }
</script>
