---
// src/pages/admin/settings/social.astro
// Admin UI for managing social media links.

import AdminLayout from "@/layouts/AdminLayout.astro";
import { getSocialLinks, KNOWN_PLATFORMS } from "@/lib/socialLinks";

const saved = Astro.url.searchParams.has("saved");
const error = Astro.url.searchParams.get("error");
const links = await getSocialLinks();

const errorMessages: Record<string, string> = {
  "missing-fields": "Platform and URL are required.",
  duplicate: "That platform is already listed. Edit the existing URL instead.",
};

const BTN_CLASS =
  "font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap";
const INPUT_CLASS =
  "border border-(--border-primary) bg-(--surface-primary) text-(--content-body) rounded-sm px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-(--content-body)/30 focus:ring-offset-1";
const REMOVE_CLASS =
  "font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-transparent border-(--border-primary) hover:border-red-400 hover:text-red-500 text-sm py-1 px-3 whitespace-nowrap";
---

<AdminLayout
  title="Social Links"
  description="Manage social media profiles shown in the site footer."
>
  {saved && (
    <div role="status" class="saved-banner mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800">
      Social links saved successfully.
    </div>
  )}
  {error && (
    <div role="alert" class="error-banner mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-800">
      {errorMessages[error] ?? "Something went wrong."}
    </div>
  )}

  <!-- Current links -->
  <div class="border border-(--border-primary) border-l-4 border-l-violet-500 rounded-sm overflow-hidden mb-6">
    <div class="flex flex-wrap items-center gap-3 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
      <p class="text-base font-semibold text-(--content-heading)">Active Profiles</p>
      <p class="text-sm text-(--content-meta)">Edit a URL or remove a profile.</p>
    </div>

    {links.length === 0 ? (
      <p class="px-4 py-6 text-sm text-(--content-meta)">No social links configured yet.</p>
    ) : (
      <div class="divide-y divide-(--border-primary)">
        {links.map((link) => (
          <div class="flex flex-wrap items-center gap-3 px-4 py-3.5">
            <!-- Platform badge -->
            <span class="w-28 shrink-0 capitalize text-sm font-semibold text-(--content-heading)">
              {link.platform}
            </span>

            <!-- URL edit form -->
            <form method="POST" action="/api/admin/social" class="flex flex-1 min-w-0 items-center gap-2">
              <input type="hidden" name="action" value="update-url" />
              <input type="hidden" name="platform" value={link.platform} />
              <input
                type="url"
                name="url"
                value={link.url}
                required
                class={`${INPUT_CLASS} flex-1 min-w-0`}
                aria-label={`${link.platform} URL`}
              />
              <button type="submit" class={BTN_CLASS}>Save</button>
            </form>

            <!-- Remove form -->
            <form method="POST" action="/api/admin/social">
              <input type="hidden" name="action" value="remove" />
              <input type="hidden" name="platform" value={link.platform} />
              <button type="submit" class={REMOVE_CLASS} aria-label={`Remove ${link.platform}`}>
                Remove
              </button>
            </form>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Add new link -->
  <div class="border border-(--border-primary) border-l-4 border-l-violet-500 rounded-sm overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
      <p class="text-base font-semibold text-(--content-heading)">Add a Profile</p>
    </div>

    <form method="POST" action="/api/admin/social" class="flex flex-wrap items-end gap-4 px-4 py-4">
      <input type="hidden" name="action" value="add" />

      <div class="flex flex-col gap-1.5">
        <label for="add-platform" class="text-xs font-semibold text-(--content-meta) uppercase tracking-wide">
          Platform
        </label>
        <select
          id="add-platform"
          name="platform"
          required
          class={`${INPUT_CLASS} pr-8`}
        >
          <option value="" disabled selected>Choose…</option>
          {Object.keys(KNOWN_PLATFORMS).map((p) => {
            const alreadyAdded = links.some((l) => l.platform === p);
            return (
              <option value={p} disabled={alreadyAdded}>
                {p.charAt(0).toUpperCase() + p.slice(1)}{alreadyAdded ? " (added)" : ""}
              </option>
            );
          })}
        </select>
      </div>

      <div class="flex flex-col gap-1.5 flex-1 min-w-[16rem]">
        <label for="add-url" class="text-xs font-semibold text-(--content-meta) uppercase tracking-wide">
          Profile URL
        </label>
        <input
          id="add-url"
          type="url"
          name="url"
          placeholder="https://www.instagram.com/elcaminoskateshop/"
          required
          class={INPUT_CLASS}
        />
      </div>

      <button type="submit" class={BTN_CLASS}>Add Profile</button>
    </form>
  </div>
</AdminLayout>

<script>
  const banner = document.querySelector<HTMLElement>(".saved-banner");
  if (banner) {
    setTimeout(() => {
      banner.style.transition = "opacity 0.5s ease";
      banner.style.opacity = "0";
      setTimeout(() => banner.remove(), 500);
      const url = new URL(window.location.href);
      url.searchParams.delete("saved");
      history.replaceState(null, "", url.toString());
    }, 4000);
  }
</script>
