              </div>
              <div class="mt-auto border-t border-(--border-primary) px-5 py-2.5 flex justify-end">
                <span class="text-sm flex items-center font-semibold text-emerald-700 group-hover:text-emerald-600 transition-colors">
                  View pick ups{" "}
