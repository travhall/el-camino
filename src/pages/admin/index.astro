---
/**
 * Admin Dashboard Landing Page
 * Main entry point for all admin tools and performance monitoring.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";
import { Icon } from "astro-icon/components";
import { Client, Environment } from "square/legacy";
import { getAllProductSummaries } from "@/lib/backInStock";

const pageTitle = "Dashboard";
const pageDescription =
  "Admin tools for performance monitoring and content management.";

// ── Attention summary — fetch all three sources in parallel ──────────────────
function makeSquareClient() {
  return new Client({
    accessToken: process.env.SQUARE_ACCESS_TOKEN!,
    environment:
      import.meta.env.PUBLIC_SQUARE_ENVIRONMENT === "production"
        ? Environment.Production
        : Environment.Sandbox,
  });
}

interface ShippingSummary {
  count: number;
  oldestDate: string | null;
  totalCents: number;
}
interface PickupSummary {
  count: number;
  oldestDate: string | null;
}
interface BisSummary {
  products: number;
  subscribers: number;
}

const [shippingResult, pickupResult, bisResult] = await Promise.allSettled([
  // Pending shipments
  (async (): Promise<ShippingSummary> => {
    const client = makeSquareClient();
    const { result } = await client.ordersApi.searchOrders({
      locationIds: [import.meta.env.PUBLIC_SQUARE_LOCATION_ID],
      query: {
        filter: {
          fulfillmentFilter: {
            fulfillmentTypes: ["SHIPMENT"],
            fulfillmentStates: ["PROPOSED"],
          },
          stateFilter: { states: ["OPEN"] },
        },
        sort: { sortField: "CREATED_AT", sortOrder: "ASC" },
      },
    });
    const paid = (result.orders ?? []).filter((o) => o.tenders?.length);
    const totalCents = paid.reduce((sum, o) => {
      const v = o.totalMoney?.amount;
      return sum + (v != null ? (typeof v === "bigint" ? Number(v) : v) : 0);
    }, 0);
    const oldest = paid[0]?.createdAt ?? null;
    return { count: paid.length, oldestDate: oldest, totalCents };
  })(),

  // Pending pick ups
  (async (): Promise<PickupSummary> => {
    const client = makeSquareClient();
    const { result } = await client.ordersApi.searchOrders({
      locationIds: [import.meta.env.PUBLIC_SQUARE_LOCATION_ID],
      query: {
        filter: {
          fulfillmentFilter: {
            fulfillmentTypes: ["PICKUP"],
            fulfillmentStates: ["PROPOSED", "RESERVED", "PREPARED"],
          },
          stateFilter: { states: ["OPEN"] },
        },
        sort: { sortField: "CREATED_AT", sortOrder: "ASC" },
      },
    });
    const paid = (result.orders ?? []).filter((o) => o.tenders?.length);
    const oldest = paid[0]?.createdAt ?? null;
    return { count: paid.length, oldestDate: oldest };
  })(),

  // Back-in-stock subscribers
  (async (): Promise<BisSummary> => {
    const summaries = await getAllProductSummaries();
    const subscribers = summaries.reduce((n, p) => n + p.count, 0);
    return { products: summaries.length, subscribers };
  })(),
]);

const shipping: ShippingSummary =
  shippingResult.status === "fulfilled"
    ? shippingResult.value
    : { count: 0, oldestDate: null, totalCents: 0 };
const pickup: PickupSummary =
  pickupResult.status === "fulfilled"
    ? pickupResult.value
    : { count: 0, oldestDate: null };
const bis: BisSummary =
  bisResult.status === "fulfilled"
    ? bisResult.value
    : { products: 0, subscribers: 0 };

const shippingError = shippingResult.status === "rejected";
const pickupError = pickupResult.status === "rejected";
const bisError = bisResult.status === "rejected";

function formatMoney(cents: number) {
  return `$${(cents / 100).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}
function relativeDate(iso: string | null): string {
  if (!iso) return "";
  const d = new Date(iso);
  const now = new Date();
  const diffDays = Math.floor((now.getTime() - d.getTime()) / 86_400_000);
  if (diffDays === 0) return "today";
  if (diffDays === 1) return "yesterday";
  if (diffDays < 7) return `${diffDays}d ago`;
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---

<AdminLayout
  title={pageTitle}
  description={pageDescription}
  activeSection="overview"
>
  <!-- ── Needs Attention ────────────────────────────────────────────────── -->
  <section class="mb-10">
    <h2
      class="text-sm font-semibold uppercase tracking-widest text-(--content-meta) mb-3"
    >
      Needs Attention
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Shipping -->
      <a
        href="/admin/orders/shipping"
        class="group flex flex-col border border-(--border-primary) border-l-4 border-l-sky-600 rounded-sm bg-(--surface-secondary) hover:shadow-md transition-shadow no-underline overflow-hidden"
      >
        <!-- Label bar -->
        <div class="flex items-center gap-2 px-5 pt-4 pb-2">
          <Icon name="uil:box" class="w-5 h-5 text-sky-500 shrink-0" />
          <span
            class="text-sm font-semibold uppercase tracking-wider text-sky-600"
            >Shipping</span
          >
        </div>
        <!-- Content -->
        {
          shippingError ? (
            <p class="px-5 pb-4 text-xs text-red-500">Could not load data</p>
          ) : shipping.count > 0 ? (
            <>
              <div class="px-5 pb-3">
                <p class="text-5xl font-bold text-sky-700 leading-none tabular-nums">
                  {shipping.count}
                </p>
                <p class="text-base text-(--content-body) mt-1.5">
                  {shipping.count === 1 ? "order" : "orders"} waiting to ship
                </p>
                <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-2 text-sm text-(--content-meta)">
                  {shipping.oldestDate && (
                    <span>
                      Oldest:{" "}
                      <strong class="text-(--content-body) font-medium">
                        {relativeDate(shipping.oldestDate)}
                      </strong>
                    </span>
                  )}
                  {shipping.totalCents > 0 && (
                    <span>
                      Value:{" "}
                      <strong class="text-(--content-body) font-medium">
                        {formatMoney(shipping.totalCents)}
                      </strong>
                    </span>
                  )}
                </div>
              </div>
              <div class="mt-auto border-t border-(--border-primary) px-5 py-2.5 flex justify-end">
                <span class="text-sm flex items-center font-semibold text-sky-600 group-hover:text-sky-500 transition-colors">
                  View orders{" "}
                  <Icon
                    class="h-4 w-4 text-sky-600 group-hover:text-sky-500"
                    name="uil:arrow-right"
                  />
                </span>
              </div>
            </>
          ) : (
            <div class="px-5 pb-5 flex items-center gap-2.5">
              <Icon
                name="uil:check-circle"
                class="w-5 h-5 text-sky-400 shrink-0"
              />
