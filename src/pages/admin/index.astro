            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-(--content-heading)">
              WordPress Demo
            </h3>
            <p class="text-sm text-(--content-meta)">
              Block component reference and examples
            </p>
          </div>
        </div>

        <a
          href="/admin/content/wordpress-demo"
          class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-4 w-full text-center block"
        >
          View Demo
        </a>
      </div>
    </div>
  </section>
</AdminLayout>

<script>
  type CruxStatus =
    | { status: "no_data"; origin: string }
    | { status: "no_key"; origin: string }
    | {
        status: "ok";
        origin: string;
        lcp: number | null;
        inp: number | null;
        cls: number | null;
        fcp: number | null;
        ttfb: number | null;
        lcpGoodPercent: number | null;
        inpGoodPercent: number | null;
        clsGoodPercent: number | null;
      };

  function vitalClass(good: boolean | null): string {
    if (good === null) return "text-(--content-meta)";
    return good ? "text-green-600" : "text-yellow-600";
  }

  function lcpStatus(ms: number | null): {
    label: string;
    good: boolean | null;
  } {
    if (ms === null) return { label: "—", good: null };
    if (ms <= 2500) return { label: "Good", good: true };
    if (ms <= 4000) return { label: "Needs improvement", good: false };
    return { label: "Poor", good: false };
  }

  function inpStatus(ms: number | null): {
    label: string;
    good: boolean | null;
  } {
    if (ms === null) return { label: "—", good: null };
    if (ms <= 200) return { label: "Good", good: true };
    if (ms <= 500) return { label: "Needs improvement", good: false };
    return { label: "Poor", good: false };
  }

  function clsStatus(score: number | null): {
    label: string;
    good: boolean | null;
  } {
    if (score === null) return { label: "—", good: null };
    if (score <= 0.1) return { label: "Good", good: true };
    if (score <= 0.25) return { label: "Needs improvement", good: false };
    return { label: "Poor", good: false };
  }

  async function loadCrux() {
    const loading = document.getElementById("cwv-loading")!;
    const noData = document.getElementById("cwv-no-data")!;
    const noKey = document.getElementById("cwv-no-key")!;
    const metrics = document.getElementById("cwv-metrics")!;

    try {
      const res = await fetch("/api/crux-data");
      const data: CruxStatus = await res.json();

      loading.classList.add("hidden");

      if (data.status === "no_key") {
        noKey.classList.remove("hidden");
        return;
      }

      if (data.status === "no_data") {
        noData.classList.remove("hidden");
        return;
      }

      // LCP
      const lcpMs = data.lcp;
      const lcpSt = lcpStatus(lcpMs);
      document.getElementById("lcp-value")!.textContent =
        lcpMs !== null ? (lcpMs / 1000).toFixed(1) + "s" : "—";
      const lcpStatusEl = document.getElementById("lcp-status")!;
      lcpStatusEl.textContent = lcpSt.label;
      lcpStatusEl.className = `text-xs mt-1 ${vitalClass(lcpSt.good)}`;

      // INP
      const inpMs = data.inp;
      const inpSt = inpStatus(inpMs);
      document.getElementById("inp-value")!.textContent =
        inpMs !== null ? Math.round(inpMs) + "ms" : "—";
      const inpStatusEl = document.getElementById("inp-status")!;
      inpStatusEl.textContent = inpSt.label;
      inpStatusEl.className = `text-xs mt-1 ${vitalClass(inpSt.good)}`;

      // CLS
      const clsScore = data.cls;
      const clsSt = clsStatus(clsScore);
      document.getElementById("cls-value")!.textContent =
        clsScore !== null ? clsScore.toFixed(2) : "—";
      const clsStatusEl = document.getElementById("cls-status")!;
      clsStatusEl.textContent = clsSt.label;
      clsStatusEl.className = `text-xs mt-1 ${vitalClass(clsSt.good)}`;

      metrics.style.display = "grid";
    } catch {
      loading.textContent = "Could not load field data.";
    }
  }

  loadCrux();
</script>
