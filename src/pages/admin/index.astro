---
/**
 * Admin Dashboard Landing Page
 * Main entry point for all admin tools and performance monitoring.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";

const pageTitle = "Dashboard";
const pageDescription =
  "Admin tools for performance monitoring and content management.";
---

<AdminLayout
  title={pageTitle}
  description={pageDescription}
  activeSection="overview"
>
  <!-- Core Web Vitals summary (loaded client-side from /api/crux-data) -->
  <section class="mb-12">
    <div
      class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary)"
    >
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-(--content-heading)">
          Core Web Vitals
        </h2>
        <a
          href="/admin/performance"
          class="text-sm text-(--content-meta) hover:text-(--content-body) transition-colors"
          >View full report →</a
        >
      </div>

      <!-- Loading state -->
      <div id="cwv-loading" class="py-4 text-center text-(--content-meta) text-sm">
        Loading field data…
      </div>

      <!-- No data state (hidden by default) -->
      <div id="cwv-no-data" class="hidden py-6 text-center">
        <p class="text-(--content-meta) text-sm">
          No Chrome UX Report data yet for this origin.
        </p>
        <p class="text-xs text-(--content-meta) mt-1">
          Field data becomes available once the site has sufficient real-user traffic (~1,000 visits).
        </p>
      </div>

      <!-- No API key state (hidden by default) -->
      <div id="cwv-no-key" class="hidden py-6 text-center">
        <p class="text-(--content-meta) text-sm">
          Set the <code class="font-mono text-xs bg-(--surface-tertiary) px-1 rounded">CRUX_API_KEY</code> environment variable to enable field data.
        </p>
        <p class="text-xs text-(--content-meta) mt-1">
          Get a free key at <span class="font-mono text-xs">console.cloud.google.com</span> → APIs &amp; Services → Chrome UX Report API.
        </p>
      </div>

      <!-- Metrics grid (hidden until data loads) -->
      <div id="cwv-metrics" class="hidden grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- LCP -->
        <div class="text-center">
          <div id="lcp-value" class="text-4xl font-bold mb-1 text-(--content-heading)">—</div>
          <div class="text-sm text-(--content-meta)">LCP (p75)</div>
          <div id="lcp-status" class="text-xs mt-1"></div>
        </div>
        <!-- INP -->
        <div class="text-center">
          <div id="inp-value" class="text-4xl font-bold mb-1 text-(--content-heading)">—</div>
          <div class="text-sm text-(--content-meta)">INP (p75)</div>
          <div id="inp-status" class="text-xs mt-1"></div>
        </div>
        <!-- CLS -->
        <div class="text-center">
          <div id="cls-value" class="text-4xl font-bold mb-1 text-(--content-heading)">—</div>
          <div class="text-sm text-(--content-meta)">CLS (p75)</div>
          <div id="cls-status" class="text-xs mt-1"></div>
        </div>
      </div>

      <p class="text-xs text-(--content-meta) mt-4">
        Source: Chrome UX Report (real-user field data, p75)
      </p>
    </div>
  </section>

  <!-- Admin Tools Grid -->
  <section>
    <h2 class="text-2xl font-semibold text-(--content-heading) mb-6">
      Admin Tools
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Performance Monitoring -->
      <div
        class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary) hover:shadow-md transition-shadow"
      >
        <div class="flex items-center mb-4">
          <div
            class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mr-4"
          >
            <svg
              class="w-6 h-6 text-blue-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-(--content-heading)">
              Performance Monitor
            </h3>
            <p class="text-sm text-(--content-meta)">
              Core Web Vitals field data
            </p>
          </div>
        </div>

        <a
          href="/admin/performance"
          class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-4 w-full text-center block"
        >
          View Dashboard
        </a>
      </div>

      <!-- SKU Reference -->
      <div
        class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary) hover:shadow-md transition-shadow"
      >
        <div class="flex items-center mb-4">
          <div
            class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4"
          >
            <svg
              class="w-6 h-6 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-(--content-heading)">
              SKU Reference
            </h3>
            <p class="text-sm text-(--content-meta)">
              Product reference for content creators
            </p>
          </div>
        </div>

        <a
          href="/admin/content/sku-reference"
          class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-4 w-full text-center block"
        >
          Browse SKUs
        </a>
      </div>

      <!-- Style Guide -->
      <div
        class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary) hover:shadow-md transition-shadow"
      >
        <div class="flex items-center mb-4">
          <div
            class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mr-4"
          >
            <svg
              class="w-6 h-6 text-purple-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-(--content-heading)">Style Guide</h3>
            <p class="text-sm text-(--content-meta)">
              Design tokens and component reference
            </p>
          </div>
        </div>

        <a
          href="/admin/content/styleguide"
          class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-4 w-full text-center block"
        >
          View Style Guide
        </a>
      </div>

      <!-- Event Reference -->
      <div
        class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary) hover:shadow-md transition-shadow"
      >
        <div class="flex items-center mb-4">
          <div
            class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mr-4"
          >
            <svg
              class="w-6 h-6 text-orange-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-(--content-heading)">
              Event Reference
            </h3>
            <p class="text-sm text-(--content-meta)">
              Analytics events and tracking guide
            </p>
          </div>
        </div>

        <a
          href="/admin/content/event-reference"
          class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-4 w-full text-center block"
        >
          View Events
        </a>
      </div>

      <!-- WordPress Demo -->
      <div
        class="bg-(--surface-secondary) p-6 rounded-sm border border-(--border-primary) hover:shadow-md transition-shadow"
      >
        <div class="flex items-center mb-4">
          <div
            class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mr-4"
          >
            <svg
              class="w-6 h-6 text-blue-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-(--content-heading)">
              WordPress Demo
            </h3>
            <p class="text-sm text-(--content-meta)">
              Block component reference and examples
            </p>
          </div>
        </div>

        <a
          href="/admin/content/wordpress-demo"
          class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-4 w-full text-center block"
        >
          View Demo
        </a>
      </div>
    </div>
  </section>
</AdminLayout>

<style>
  section {
    animation: fadeInUp 0.5s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  type CruxStatus =
    | { status: "no_data"; origin: string }
    | { status: "no_key"; origin: string }
    | {
        status: "ok";
        origin: string;
        lcp: number | null;
        inp: number | null;
        cls: number | null;
        fcp: number | null;
        ttfb: number | null;
        lcpGoodPercent: number | null;
        inpGoodPercent: number | null;
        clsGoodPercent: number | null;
      };

  function vitalClass(good: boolean | null): string {
    if (good === null) return "text-(--content-meta)";
    return good ? "text-green-600" : "text-yellow-600";
  }

  function lcpStatus(ms: number | null): { label: string; good: boolean | null } {
    if (ms === null) return { label: "—", good: null };
    if (ms <= 2500) return { label: "Good", good: true };
    if (ms <= 4000) return { label: "Needs improvement", good: false };
    return { label: "Poor", good: false };
  }

  function inpStatus(ms: number | null): { label: string; good: boolean | null } {
    if (ms === null) return { label: "—", good: null };
    if (ms <= 200) return { label: "Good", good: true };
    if (ms <= 500) return { label: "Needs improvement", good: false };
    return { label: "Poor", good: false };
  }

  function clsStatus(score: number | null): { label: string; good: boolean | null } {
    if (score === null) return { label: "—", good: null };
    if (score <= 0.1) return { label: "Good", good: true };
    if (score <= 0.25) return { label: "Needs improvement", good: false };
    return { label: "Poor", good: false };
  }

  async function loadCrux() {
    const loading = document.getElementById("cwv-loading")!;
    const noData = document.getElementById("cwv-no-data")!;
    const noKey = document.getElementById("cwv-no-key")!;
    const metrics = document.getElementById("cwv-metrics")!;

    try {
      const res = await fetch("/api/crux-data");
      const data: CruxStatus = await res.json();

      loading.classList.add("hidden");

      if (data.status === "no_key") {
        noKey.classList.remove("hidden");
        return;
      }

      if (data.status === "no_data") {
        noData.classList.remove("hidden");
        return;
      }

      // LCP
      const lcpMs = data.lcp;
      const lcpSt = lcpStatus(lcpMs);
      document.getElementById("lcp-value")!.textContent =
        lcpMs !== null ? (lcpMs / 1000).toFixed(1) + "s" : "—";
      const lcpStatusEl = document.getElementById("lcp-status")!;
      lcpStatusEl.textContent = lcpSt.label;
      lcpStatusEl.className = `text-xs mt-1 ${vitalClass(lcpSt.good)}`;

      // INP
      const inpMs = data.inp;
      const inpSt = inpStatus(inpMs);
      document.getElementById("inp-value")!.textContent =
        inpMs !== null ? Math.round(inpMs) + "ms" : "—";
      const inpStatusEl = document.getElementById("inp-status")!;
      inpStatusEl.textContent = inpSt.label;
      inpStatusEl.className = `text-xs mt-1 ${vitalClass(inpSt.good)}`;

      // CLS
      const clsScore = data.cls;
      const clsSt = clsStatus(clsScore);
      document.getElementById("cls-value")!.textContent =
        clsScore !== null ? clsScore.toFixed(2) : "—";
      const clsStatusEl = document.getElementById("cls-status")!;
      clsStatusEl.textContent = clsSt.label;
      clsStatusEl.className = `text-xs mt-1 ${vitalClass(clsSt.good)}`;

      metrics.classList.remove("hidden");
    } catch {
      loading.textContent = "Could not load field data.";
    }
  }

  loadCrux();
</script>
