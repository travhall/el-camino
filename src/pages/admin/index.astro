        {shippingError ? (
          <p class="text-xs text-red-500">Could not load shipping data</p>
        ) : shipping.count > 0 ? (
          <>
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="text-3xl font-bold text-sky-700 leading-none">{shipping.count}</p>
                <p class="text-sm text-(--content-body) mt-1">
                  {shipping.count === 1 ? "order" : "orders"} to ship
                </p>
              </div>
              <svg class="w-5 h-5 text-sky-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
