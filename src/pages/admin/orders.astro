---
/**
 * Admin — Pending Shipments
 * Lists open shipping orders from Square. Tyler uses this to mark orders as
 * shipped and trigger the customer shipping confirmation email.
 */

import AdminLayout from "@/layouts/AdminLayout.astro";
import { Client, Environment } from "square/legacy";

function formatMoney(amount: bigint | number | undefined | null): string {
  if (amount == null) return "$0.00";
  const cents = typeof amount === "bigint" ? Number(amount) : amount;
  return `$${(cents / 100).toFixed(2)}`;
}

function shortId(orderId: string): string {
  return orderId.slice(-8).toUpperCase();
}

function formatDate(iso: string | undefined): string {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}

interface ShippingOrder {
  orderId: string;
  shortId: string;
  createdAt: string;
  customerName: string;
  customerEmail: string;
  address: string;
  items: { name: string; qty: string }[];
  total: string;
  fulfillmentUid: string;
  orderVersion: number;
}

let orders: ShippingOrder[] = [];
let fetchError = false;

try {
  const client = new Client({
    accessToken: process.env.SQUARE_ACCESS_TOKEN!,
    environment:
      import.meta.env.PUBLIC_SQUARE_ENVIRONMENT === "production"
        ? Environment.Production
        : Environment.Sandbox,
  });

  const locationId = import.meta.env.PUBLIC_SQUARE_LOCATION_ID;

  // Search for open orders with SHIPMENT fulfillment in PROPOSED state
  const { result } = await client.ordersApi.searchOrders({
    locationIds: [locationId],
    query: {
      filter: {
        fulfillmentFilter: {
          fulfillmentTypes: ["SHIPMENT"],
          fulfillmentStates: ["PROPOSED"],
        },
        stateFilter: {
          states: ["OPEN"],
        },
      },
      sort: {
        sortField: "CREATED_AT",
        sortOrder: "DESC",
      },
    },
  });

  for (const order of result.orders ?? []) {
    const fulfillment = order.fulfillments?.find((f) => f.type === "SHIPMENT");
    if (!fulfillment) continue;

    const recipient = fulfillment.shipmentDetails?.recipient;
    const addr = recipient?.address;
    const addressParts = [
      addr?.addressLine1,
      addr?.addressLine2,
      addr && `${addr.locality}, ${addr.administrativeDistrictLevel1} ${addr.postalCode}`,
    ].filter(Boolean);

    orders.push({
      orderId: order.id ?? "",
      shortId: shortId(order.id ?? ""),
      createdAt: formatDate(order.createdAt),
      customerName: recipient?.displayName ?? "Unknown",
      customerEmail: recipient?.emailAddress ?? "",
      address: addressParts.join(", ") || "No address",
      items: (order.lineItems ?? []).map((li) => ({
        name: li.name ?? "Item",
        qty: li.quantity ?? "1",
      })),
      total: formatMoney(order.totalMoney?.amount),
      fulfillmentUid: fulfillment.uid ?? "",
      orderVersion: order.version ?? 1,
    });
  }
} catch (err) {
  console.error("[admin/orders] Failed to fetch pending shipments:", err);
  fetchError = true;
}
---

<AdminLayout title="Pending Shipments" description="Shipping orders that need to be packed and sent.">
  {fetchError && (
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Could not load orders from Square. Check your API credentials and try refreshing.
    </div>
  )}

  {!fetchError && orders.length === 0 && (
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-12 text-center">
      <p class="text-(--content-heading) font-semibold text-lg mb-1">No pending shipments</p>
      <p class="text-(--content-meta) text-sm">All shipping orders have been fulfilled.</p>
    </div>
  )}

  {orders.length > 0 && (
    <div class="space-y-6">
      {orders.map((order) => (
        <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm overflow-hidden">
          <!-- Order header -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 px-6 py-4 border-b border-(--border-primary)">
            <div class="flex items-center gap-3">
              <span class="font-mono text-sm font-semibold text-(--content-heading)">#{order.shortId}</span>
              <span class="text-xs text-(--content-meta)">{order.createdAt}</span>
            </div>
            <span class="text-sm font-semibold text-(--content-heading)">{order.total}</span>
          </div>

          <!-- Customer + address -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 divide-y sm:divide-y-0 sm:divide-x divide-(--border-primary)">
            <div class="px-6 py-4">
              <p class="text-xs font-semibold uppercase tracking-wider text-(--content-meta) mb-2">Customer</p>
              <p class="text-sm font-semibold text-(--content-heading)">{order.customerName}</p>
              {order.customerEmail && (
                <p class="text-sm text-(--content-meta)">{order.customerEmail}</p>
              )}
            </div>
            <div class="px-6 py-4">
              <p class="text-xs font-semibold uppercase tracking-wider text-(--content-meta) mb-2">Ship To</p>
              <p class="text-sm text-(--content-body)">{order.address}</p>
            </div>
          </div>

          <!-- Items -->
          <div class="px-6 py-4 border-t border-(--border-primary)">
            <p class="text-xs font-semibold uppercase tracking-wider text-(--content-meta) mb-2">Items</p>
            <ul class="space-y-1">
              {order.items.map((item) => (
                <li class="text-sm text-(--content-body)">
                  {Number(item.qty) > 1 ? <span class="text-(--content-meta)">{item.qty}&times; </span> : null}
                  {item.name}
                </li>
              ))}
            </ul>
          </div>

          <!-- Mark shipped form -->
          <div class="px-6 py-4 border-t border-(--border-primary) bg-(--surface-tertiary,#f9f9f7)">
            <form
              method="POST"
              action="/api/admin/mark-shipped"
              class="flex flex-col sm:flex-row gap-3 items-start sm:items-end"
              data-order-id={order.orderId}
            >
              <input type="hidden" name="orderId" value={order.orderId} />
              <input type="hidden" name="fulfillmentUid" value={order.fulfillmentUid} />
              <input type="hidden" name="orderVersion" value={order.orderVersion} />

              <div class="flex-1 min-w-0">
                <label
                  for={`tracking-${order.orderId}`}
                  class="block text-xs font-semibold text-(--content-meta) mb-1"
                >
                  Tracking Number <span class="font-normal">(optional)</span>
                </label>
                <input
                  id={`tracking-${order.orderId}`}
                  name="trackingNumber"
                  type="text"
                  placeholder="1Z999AA10123456784"
                  class="w-full border border-(--border-primary) rounded-sm px-3 py-2 text-sm bg-(--surface-primary) text-(--content-body) focus:outline-none focus:ring-2 focus:ring-(--ui-button-ring,#4d7a2e)"
                />
              </div>

              <div>
                <label
                  for={`carrier-${order.orderId}`}
                  class="block text-xs font-semibold text-(--content-meta) mb-1"
                >
                  Carrier
                </label>
                <select
                  id={`carrier-${order.orderId}`}
                  name="carrier"
                  class="border border-(--border-primary) rounded-sm px-3 py-2 text-sm bg-(--surface-primary) text-(--content-body) focus:outline-none focus:ring-2 focus:ring-(--ui-button-ring,#4d7a2e)"
                >
                  <option value="">— Select —</option>
                  <option value="USPS">USPS</option>
                  <option value="UPS">UPS</option>
                  <option value="FedEx">FedEx</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <button
                type="submit"
                class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-2 px-5 whitespace-nowrap"
              >
                Mark as Shipped
              </button>
            </form>
          </div>
        </div>
      ))}
    </div>
  )}
</AdminLayout>
