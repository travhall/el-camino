---
// src/pages/admin/notifications/banner.astro
// Admin UI for the site-wide announcement banner.

import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAnnouncementBanner } from "@/lib/announcementBanner";

const saved = Astro.url.searchParams.has("saved");
const banner = await getAnnouncementBanner();

const INPUT_CLASS =
  "w-full border border-(--border-primary) bg-(--surface-primary) text-(--content-body) rounded-sm px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-(--content-body)/30 focus:ring-offset-1";
const BTN_CLASS =
  "font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap";
---

<AdminLayout
  title="Announcement Banner"
  description="Show a message across the top of the site — perfect for sales, events, or closures."
>
  {saved && (
    <div role="status" class="saved-banner mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800">
      Banner saved successfully.
    </div>
  )}

  <form
    method="POST"
    action="/api/admin/banner"
    class="border border-(--border-primary) border-l-4 border-l-violet-500 rounded-sm overflow-hidden"
  >
    <!-- Header -->
    <div class="flex flex-wrap items-center gap-3 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
      <p class="text-base font-semibold text-(--content-heading)">Banner Settings</p>
      <p class="text-sm text-(--content-meta)">Displayed above the navigation on every page while active.</p>
    </div>

    <div class="divide-y divide-(--border-primary)">
      <!-- Active toggle -->
      <div class="flex flex-wrap items-center gap-4 px-4 py-3.5">
        <span class="w-36 shrink-0 text-sm font-semibold text-(--content-heading)">Active</span>
        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input
            type="checkbox"
            name="active"
            id="banner-active"
            class="w-4 h-4 accent-(--content-heading) cursor-pointer"
            checked={banner.active}
          />
          <span class="text-sm text-(--content-body)">Show on site</span>
        </label>
      </div>

      <!-- Message text -->
      <div class="flex flex-wrap items-start gap-4 px-4 py-3.5">
        <label for="banner-text" class="w-36 shrink-0 text-sm font-semibold text-(--content-heading) pt-2">
          Message
        </label>
        <textarea
          id="banner-text"
          name="text"
          rows="2"
          placeholder="Grand reopening this Saturday — come ride with us!"
          class={INPUT_CLASS}
          maxlength="200"
        >{banner.text}</textarea>
      </div>

      <!-- Expires -->
      <div class="flex flex-wrap items-center gap-4 px-4 py-3.5">
        <label for="banner-expires" class="w-36 shrink-0 text-sm font-semibold text-(--content-heading)">
          Hide after
        </label>
        <div class="flex flex-col gap-1">
          <input
            id="banner-expires"
            type="date"
            name="expiresAt"
            value={banner.expiresAt ?? ""}
            class={`${INPUT_CLASS} w-auto`}
          />
          <p class="text-xs text-(--content-meta)">Optional — leave blank to show indefinitely.</p>
        </div>
      </div>
    </div>

    <!-- Footer actions -->
    <div class="flex items-center justify-between px-4 py-3 bg-(--surface-primary) border-t border-(--border-primary)">
      <p class="text-xs text-(--content-meta)">
        Max 200 characters. Links and formatting are not supported.
      </p>
      <button type="submit" class={BTN_CLASS}>Save Banner</button>
    </div>
  </form>

  <!-- Preview -->
  {banner.text && (
    <div class="mt-6">
      <p class="text-xs font-semibold text-(--content-meta) uppercase tracking-wide mb-2">Current preview</p>
      <div class="w-full px-4 py-2.5 text-sm text-center font-medium bg-(--content-heading) text-(--surface-primary)">
        {banner.text}
      </div>
      {banner.expiresAt && (
        <p class="text-xs text-(--content-meta) mt-1">
          {banner.active ? "Expires" : "Was set to expire"} {banner.expiresAt}
        </p>
      )}
    </div>
  )}
</AdminLayout>

<script>
  const banner = document.querySelector<HTMLElement>(".saved-banner");
  if (banner) {
    setTimeout(() => {
      banner.style.transition = "opacity 0.5s ease";
      banner.style.opacity = "0";
      setTimeout(() => banner.remove(), 500);
      const url = new URL(window.location.href);
      url.searchParams.delete("saved");
      history.replaceState(null, "", url.toString());
    }, 4000);
  }
</script>
