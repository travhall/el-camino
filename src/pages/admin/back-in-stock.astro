---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAllProductSummaries } from "@/lib/backInStock";

const params = Astro.url.searchParams;
const sent = params.get("sent");
const failed = params.get("failed");
const removed = params.get("removed");
const errorType = params.get("error");

let summaries: Awaited<ReturnType<typeof getAllProductSummaries>> = [];
let fetchError = false;

try {
  summaries = await getAllProductSummaries();
} catch (err) {
  console.error("[admin/back-in-stock] Failed to load subscriptions:", err);
  fetchError = true;
}
---

<AdminLayout title="Back in Stock" description="">
  {sent && (
    <div class="bis-banner mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800">
      {failed
        ? `Sent ${sent} notification${Number(sent) !== 1 ? "s" : ""}. ${failed} failed — check logs.`
        : `Sent ${sent} notification${Number(sent) !== 1 ? "s" : ""} successfully.`
      }
    </div>
  )}
  {removed && (
    <div class="bis-banner mb-4 px-4 py-3 bg-slate-50 border border-slate-200 rounded-sm text-sm text-slate-700">
      Removed {removed} subscriber{Number(removed) !== 1 ? "s" : ""} without sending notifications.
    </div>
  )}
  {errorType === "none" && (
    <div class="bis-banner mb-4 px-4 py-3 bg-amber-50 border border-amber-200 rounded-sm text-sm text-amber-800">
      No subscribers found for that product.
    </div>
  )}
  {fetchError && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Could not load subscriptions. Check Netlify Blobs configuration.
    </div>
  )}

  {!fetchError && summaries.length === 0 && (
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-10 text-center">
      <p class="text-(--content-heading) font-semibold mb-1">No pending subscriptions</p>
      <p class="text-(--content-meta) text-sm">Customers who request back-in-stock alerts will appear here.</p>
    </div>
  )}

  {summaries.length > 0 && (
    <div class="space-y-3">
      <p class="text-sm text-(--content-meta)">
        {summaries.length} {summaries.length === 1 ? "product" : "products"} with pending subscribers
      </p>

      {summaries.map((product) => (
        <div class="border border-(--border-primary) border-l-4 border-l-amber-500 rounded-sm overflow-hidden">
          <!-- Header -->
          <div class="flex flex-wrap items-center gap-4 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
            <p class="text-base font-semibold text-(--content-heading) flex-1 min-w-0">{product.productTitle}</p>
            <span class="shrink-0 inline-flex items-center gap-1.5 text-sm font-semibold text-amber-800 bg-amber-100 border border-amber-200 rounded-full px-3 py-1">
              {product.count} {product.count === 1 ? "subscriber" : "subscribers"}
            </span>
          </div>
          <!-- Subscriber list -->
          <div class="px-4 py-2.5 border-b border-(--border-primary)">
            <ol class="space-y-0.5">
              {product.subscribers.map((sub, i) => (
                <li class="flex items-baseline gap-3 text-sm">
                  <span class="text-amber-600 font-mono text-xs shrink-0 text-right">{i + 1}.</span>
                  <span class="text-(--content-body)">{sub.email}</span>
                  <span class="text-xs text-(--content-meta) ml-auto shrink-0">
                    {new Date(sub.submittedAt).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </span>
                </li>
              ))}
            </ol>
          </div>
          <!-- Action -->
          <div class="px-4 py-3 bg-(--surface-primary) flex flex-wrap items-center gap-3">
            <form method="POST" action="/api/admin/send-back-in-stock">
              <input type="hidden" name="productId" value={product.productId} />
              <button type="submit"
                      class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap">
                Send Notifications
              </button>
            </form>
            <form method="POST" action="/api/admin/remove-back-in-stock"
                  onsubmit="return confirm('Remove all subscribers for this product without emailing them?')">
              <input type="hidden" name="productId" value={product.productId} />
              <button type="submit"
                      class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-slate-600 bg-transparent border-slate-300 hover:bg-slate-100 focus-visible:ring-slate-400 text-sm py-1.5 px-4 whitespace-nowrap">
                Remove
              </button>
            </form>
            <p class="text-xs text-(--content-meta)">
              Notify all {product.count} {product.count === 1 ? "subscriber" : "subscribers"} and remove them from this list. <em>Remove</em> silently discards without emailing.
            </p>
          </div>
        </div>
      ))}
    </div>
  )}
<script>
  // Auto-dismiss flash banners after 5 s and clean query params from URL
  const banners = document.querySelectorAll<HTMLElement>(".bis-banner");
  if (banners.length) {
    setTimeout(() => {
      banners.forEach((el) => {
        el.style.transition = "opacity 0.5s ease";
        el.style.opacity = "0";
        setTimeout(() => el.remove(), 500);
      });
      const url = new URL(window.location.href);
      ["sent", "failed", "removed", "error"].forEach((p) => url.searchParams.delete(p));
      history.replaceState(null, "", url.toString());
    }, 5000);
  }
</script>
</AdminLayout>
