---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAllProductSummaries } from "@/lib/backInStock";

const params = Astro.url.searchParams;
const sent = params.get("sent");
const failed = params.get("failed");
const removed = params.get("removed");
const errorType = params.get("error");

let summaries: Awaited<ReturnType<typeof getAllProductSummaries>> = [];
let fetchError = false;

try {
  summaries = await getAllProductSummaries();
} catch (err) {
  console.error("[admin/back-in-stock] Failed to load subscriptions:", err);
  fetchError = true;
}
---

<AdminLayout title="Back in Stock" description="Manage back-in-stock notification subscribers by product.">
  {sent && (
    <div role="status" class="bis-banner mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800">
      {failed
        ? `Sent ${sent} notification${Number(sent) !== 1 ? "s" : ""}. ${failed} failed — check logs.`
        : `Sent ${sent} notification${Number(sent) !== 1 ? "s" : ""} successfully.`
      }
    </div>
  )}
  {removed && (
    <div role="status" class="bis-banner mb-4 px-4 py-3 bg-slate-50 border border-slate-200 rounded-sm text-sm text-slate-700">
      Removed {removed} subscriber{Number(removed) !== 1 ? "s" : ""} without sending notifications.
    </div>
  )}
  {errorType === "none" && (
    <div role="status" class="bis-banner mb-4 px-4 py-3 bg-amber-50 border border-amber-200 rounded-sm text-sm text-amber-800">
      No subscribers found for that product.
    </div>
  )}
  {fetchError && (
    <div role="alert" class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Could not load subscriptions. Check Netlify Blobs configuration.
    </div>
  )}

  {!fetchError && summaries.length === 0 && (
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-10 text-center">
      <p class="text-(--content-heading) font-semibold mb-1">No pending subscriptions</p>
      <p class="text-(--content-meta) text-sm">Customers who request back-in-stock alerts will appear here.</p>
    </div>
  )}

  {summaries.length > 0 && (
    <div class="space-y-3">
      <p class="text-sm text-(--content-meta)">
        {summaries.length} {summaries.length === 1 ? "product" : "products"} with pending subscribers
      </p>

      {summaries.map((product) => (
        <div
          class="bis-card border border-(--border-primary) border-l-4 border-l-amber-500 rounded-sm overflow-hidden"
          data-product-id={product.productId}
        >
          <!-- Header -->
          <div class="flex flex-wrap items-center gap-4 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
            <p class="text-base font-semibold text-(--content-heading) flex-1 min-w-0">{product.productTitle}</p>
            <span class="shrink-0 inline-flex items-center gap-1.5 text-sm font-semibold text-amber-800 bg-amber-100 border border-amber-200 rounded-full px-3 py-1">
              {product.count} {product.count === 1 ? "subscriber" : "subscribers"}
            </span>
          </div>
          <!-- Subscriber list -->
          <div class="px-4 py-2.5 border-b border-(--border-primary)">
            <ol class="space-y-0.5">
              {product.subscribers.map((sub, i) => (
                <li class="flex items-baseline gap-1 text-sm">
                  <span class="text-amber-600 font-mono text-xs shrink-0 text-right">{i + 1}.</span>
                  <span class="text-(--content-body)">{sub.email}</span>
                  <span class="text-xs text-(--content-meta) ml-auto shrink-0">
                    {new Date(sub.submittedAt).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </span>
                </li>
              ))}
            </ol>
          </div>
          <!-- Action row -->
          <div class="px-4 py-3 bg-(--surface-primary) flex flex-wrap items-center gap-3">
            <!-- Send -->
            <form method="POST" action="/api/admin/send-back-in-stock">
              <input type="hidden" name="productId" value={product.productId} />
              <button type="submit"
                      class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap">
                Send Notifications
              </button>
            </form>
            <p class="text-xs text-(--content-meta) flex-1">
              Emails all {product.count} {product.count === 1 ? "subscriber" : "subscribers"} and removes them from this list.
            </p>
            <!-- Discontinue — pushed to the right -->
            <button
              type="button"
              class="bis-discontinue-btn ml-auto font-sans font-medium transition-all ease-in-out duration-200 border border-dashed rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-slate-400 border-slate-300 hover:text-red-600 hover:border-red-300 hover:bg-red-50 focus-visible:ring-red-300 text-xs py-1.5 px-3 whitespace-nowrap"
              data-product-id={product.productId}
              aria-label={`Discontinue notifications for ${product.productTitle}`}
            >
              Discontinue
            </button>
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- Undo toast (hidden until a discontinue fires) -->
  <div
    id="bis-undo-toast"
    role="status"
    style="display:none"
    class="opacity-0 fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 px-4 py-3 bg-(--surface-secondary) border border-(--border-primary) rounded-md shadow-lg text-sm min-w-72 max-w-sm transition-opacity duration-200"
  >
    <span id="bis-undo-message" class="flex-1 text-(--content-body) truncate min-w-0">Subscribers removed</span>
    <div class="flex items-center gap-3 shrink-0">
      <button
        id="bis-undo-btn"
        type="button"
        class="font-semibold underline underline-offset-2 text-(--content-emphasis) hover:opacity-75 transition-opacity cursor-pointer"
      >Undo</button>
      <button
        id="bis-undo-dismiss"
        type="button"
        class="text-(--content-meta) hover:text-(--content-body) transition-colors leading-none"
        aria-label="Dismiss"
      >✕</button>
    </div>
    <!-- Progress bar -->
    <div
      id="bis-undo-progress"
      class="absolute bottom-0 left-0 h-0.5 bg-(--content-emphasis) opacity-40 rounded-b-md"
      style="width: 100%"
    ></div>
  </div>

<script>
  // ─── Auto-dismiss redirect banners ────────────────────────────────────────
  const banners = document.querySelectorAll<HTMLElement>(".bis-banner");
  if (banners.length) {
    setTimeout(() => {
      banners.forEach((el) => {
        el.style.transition = "opacity 0.5s ease";
        el.style.opacity = "0";
        setTimeout(() => el.remove(), 500);
      });
      const url = new URL(window.location.href);
      ["sent", "failed", "removed", "error"].forEach((p) => url.searchParams.delete(p));
      history.replaceState(null, "", url.toString());
    }, 5000);
  }

  // ─── Discontinue / undo toast ─────────────────────────────────────────────
  const toast       = document.getElementById("bis-undo-toast") as HTMLElement;
  const toastMsg    = document.getElementById("bis-undo-message") as HTMLElement;
  const toastUndo   = document.getElementById("bis-undo-btn") as HTMLButtonElement;
  const toastClose  = document.getElementById("bis-undo-dismiss") as HTMLButtonElement;
  const toastBar    = document.getElementById("bis-undo-progress") as HTMLElement;

  const TOAST_MS = 6000;

  let undoTimer: ReturnType<typeof setTimeout> | null = null;
  let pendingRestoreData: { productId: string; subscriptions: unknown[] } | null = null;
  let pendingCard: HTMLElement | null = null;

  function showToast(productId: string, subscriptions: unknown[], card: HTMLElement) {
    if (undoTimer) clearTimeout(undoTimer);

    pendingRestoreData = { productId, subscriptions };
    pendingCard = card;

    const count = subscriptions.length;
    toastMsg.textContent = `${count} subscriber${count !== 1 ? "s" : ""} removed`;

    // Reset + show
    toast.style.display = "flex";
    toastBar.style.transition = "none";
    toastBar.style.width = "100%";

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        toast.style.opacity = "1";
        toastBar.style.transition = `width ${TOAST_MS}ms linear`;
        toastBar.style.width = "0%";
      });
    });

    undoTimer = setTimeout(dismissToast, TOAST_MS);
  }

  function dismissToast() {
    if (undoTimer) { clearTimeout(undoTimer); undoTimer = null; }
    toast.style.opacity = "0";
    setTimeout(() => { toast.style.display = "none"; }, 200);
    pendingRestoreData = null;
    pendingCard = null;
  }

  async function handleUndo() {
    if (!pendingRestoreData || !pendingCard) return;

    const { subscriptions } = pendingRestoreData;
    const card = pendingCard;
    dismissToast();

    try {
      const res = await fetch("/api/admin/restore-back-in-stock", {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "application/json" },
        body: JSON.stringify({ subscriptions }),
      });
      if (res.ok) {
        // Restore the card to the list
        card.style.transition = "opacity 0.2s ease";
        card.style.opacity = "1";
        card.style.display = "";
        card.removeAttribute("aria-hidden");
      }
    } catch (err) {
      console.error("[bis] Undo failed:", err);
      // Reload as fallback so admin sees accurate state
      window.location.reload();
    }
  }

  toastUndo.addEventListener("click", handleUndo);
  toastClose.addEventListener("click", dismissToast);

  // Wire up all Discontinue buttons
  document.querySelectorAll<HTMLButtonElement>(".bis-discontinue-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const productId = btn.dataset.productId!;
      const card = btn.closest<HTMLElement>(".bis-card");
      if (!card) return;

      // Optimistically hide the card
      card.style.transition = "opacity 0.2s ease";
      card.style.opacity = "0";
      setTimeout(() => {
        card.style.display = "none";
        card.setAttribute("aria-hidden", "true");
      }, 200);

      try {
        const fd = new FormData();
        fd.append("productId", productId);

        const res = await fetch("/api/admin/remove-back-in-stock", {
          method: "POST",
          headers: { "Accept": "application/json" },
          body: fd,
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        const { removed } = await res.json();
        showToast(productId, removed, card);
      } catch (err) {
        console.error("[bis] Remove failed:", err);
        // Reveal card again on error
        card.style.display = "";
        card.style.opacity = "1";
        card.removeAttribute("aria-hidden");
      }
    });
  });
</script>
</AdminLayout>
