---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Button from "@/components/Button.astro";
import { Icon } from "astro-icon/components";
import { readFileSync } from "fs";

// ── Read global.css once at build time ───────────────────────────────────────
const css = readFileSync(
  new URL("../../../styles/global.css", import.meta.url),
  "utf-8"
);

/** Extract the first value of a CSS custom property from the stylesheet. */
function cssVar(name: string): string {
  const match = css.match(new RegExp(`${name}:\\s*([^;]+);`));
  return match ? match[1].trim() : "";
}

// ── Palette data — built from global.css ─────────────────────────────────────
type Stop = { stop: string; value: string; anchor?: boolean };

function buildPalette(prefix: string, anchor = "500"): Stop[] {
  return ["50", "100", "200", "300", "400", "500", "600", "700", "800", "900"].map(
    (stop) => ({
      stop,
      value: cssVar(`--color-${prefix}-${stop}`),
      ...(stop === anchor ? { anchor: true } : {}),
    })
  );
}

const palettes: { name: string; stops: Stop[] }[] = [
  { name: "Beeswax",     stops: buildPalette("elco-beeswax")     },
  { name: "Black Pearl", stops: buildPalette("elco-black-pearl") },
  { name: "Fig Leaf",    stops: buildPalette("elco-fig-leaf")    },
  { name: "Honey Cream", stops: buildPalette("elco-honey-cream") },
  { name: "Sweet Tea",   stops: buildPalette("elco-sweet-tea")   },
];

// ── State colors — built from global.css ─────────────────────────────────────
const stateColors = ["success", "error", "warning", "info"].map((name) => ({
  name:    name.charAt(0).toUpperCase() + name.slice(1),
  token:   `state-${name}`,
  surface: cssVar(`--color-state-${name}-surface`),
  text:    cssVar(`--color-state-${name}-text`),
}));

const iconList = [
  "uil:angle-down",
  "uil:angle-left",
  "uil:angle-right",
  "uil:angle-up",
  "uil:cloud-moon",
  "uil:cloud-sun",
  "uil:envelope",
  "uil:facebook",
  "uil:instagram-alt",
  "uil:fast-mail",
  "uil:map-marker",
  "uil:moon",
  "uil:mountains-sun",
  "uil:search",
  "uil:shopping-cart",
  "uil:sun",
  "uil:user",
  "uil:youtube",
];

const shopSites = [
  { name: "Familia", url: "https://familiaskate.com/" },
  { name: "Uprise", url: "https://upriseskateshop.com/" },
  {
    name: "The Block Skate Supply*",
    url: "https://www.theblockskatesupply.com/",
  },
  { name: "Marriage", url: "https://marriageskateshop.com/" },
  { name: "Ceremony*", url: "https://www.ceremonyskateshop.com/" },
  { name: "Icon", url: "https://www.iconboardshop.com/" },
  { name: "Atlas", url: "https://shop.atlasskateboarding.com/" },
  { name: "Labor", url: "https://laborskateshop.com/" },
  { name: "Humidity", url: "https://humiditynola.com/" },
  { name: "Recess", url: "https://recessrideshop.com/" },
  { name: "Black Sheep", url: "https://blacksheepskateshop.com/" },
  { name: "Home", url: "https://www.homeskateshop.com/" },
  { name: "First Gear", url: "https://www.firstgearskateshop.com/" },
  { name: "Vu", url: "https://vuskateboardshop.com/" },
  { name: "Premier", url: "https://thepremierstore.com/" },
  { name: "Antics*", url: "https://www.anticsskateshop.com/" },
  { name: "Central (Wausau)*", url: "https://www.central-boardshop.com/" },
