---

<AdminLayout
  title="Style Guide"
  description="Design tokens, components, and visual language for El Camino"
>
  <!-- ── Quick Navigation ─────────────────────────────────────────────── -->
  <nav
    class="sticky top-13 lg:top-16 z-20 -mx-1 mb-12 border-b border-(--border-primary) bg-(--surface-secondary)/95 px-8 py-3 backdrop-blur"
    aria-label="Style guide sections"
  >
    <ol class="flex flex-wrap gap-x-6 gap-y-1.5">
      {
        [
          ["#typography", "Typography"],
          ["#colors", "Colors"],
          ["#tokens", "Tokens"],
          ["#buttons", "Buttons"],
          ["#forms", "Forms"],
          ["#states", "States"],
          ["#loading", "Loading"],
          ["#icons", "Icons"],
          ["#references", "References"],
        ].map(([href, label]) => (
          <li>
            <a
              href={href}
              class="font-sans text-xs font-semibold uppercase tracking-wider text-(--content-meta) transition-colors duration-150 hover:text-(--content-emphasis)"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ol>
  </nav>

  <!-- ════════════════════════════════════════════════════════════════════
       TYPOGRAPHY
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="typography" class="scroll-mt-14 px-8 pb-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        01
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        Typography
      </h2>
      <p class="mt-1 font-sans text-sm text-(--content-meta)">
        Alumni Sans · Cabin
      </p>
    </header>

    <!-- Display — Heading Hierarchy -->
    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Display — Alumni Sans
      </p>
      <div class="space-y-1 border-l-2 border-(--border-primary) pl-6">
        <p
          class="font-display font-black leading-tight text-(--content-heading) text-7xl"
        >
          H1 · font-black
        </p>
        <p
          class="font-display font-black leading-tight text-(--content-heading) text-6xl"
        >
          H2 · font-black
        </p>
        <p
          class="font-display font-black leading-tight text-(--content-heading) text-5xl"
        >
          H3 · font-black
        </p>
        <p
          class="font-display font-black leading-tight text-(--content-heading) text-4xl"
        >
          H4 · font-black
        </p>
        <p
          class="font-display font-black leading-tight text-(--content-heading) text-3xl"
        >
          H5 · font-black
        </p>
        <p
          class="font-display font-black leading-tight text-(--content-heading) text-2xl"
        >
          H6 · font-black
        </p>
      </div>
    </div>

    <!-- Display Italic -->
    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Display Italic — Alumni Sans Italic
      </p>
      <div class="space-y-1 border-l-2 border-(--border-primary) pl-6">
        <p
          class="font-display-italic font-black leading-tight text-(--content-heading) text-7xl"
        >
          H1 · Italic
        </p>
        <p
          class="font-display-italic font-black leading-tight text-(--content-heading) text-5xl"
        >
          H3 · Italic
        </p>
        <p
          class="font-display-italic font-black leading-tight text-(--content-heading) text-3xl"
        >
          H5 · Italic
        </p>
      </div>
    </div>

    <!-- Body Font -->
    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Body — Cabin (font-sans)
      </p>
      <div
        class="max-w-2xl space-y-3 border-l-2 border-(--border-primary) pl-6"
      >
        <p class="font-sans text-lg leading-relaxed text-(--content-body)">
          <span class="font-semibold text-(--content-meta)"
            >text-lg · body —</span
          > Etiam porta sem malesuada magna mollis euismod. Morbi leo risus, porta
          ac consectetur ac, vestibulum at eros.
        </p>
        <p class="font-sans text-base leading-relaxed text-(--content-body)">
          <span class="font-semibold text-(--content-meta)"
            >text-base · body —</span
          > Etiam porta sem malesuada magna mollis euismod. Morbi leo risus, porta
          ac consectetur ac, vestibulum at eros.
        </p>
        <p class="font-sans text-sm leading-relaxed text-(--content-meta)">
          <span class="font-semibold">text-sm · meta —</span> Etiam porta sem malesuada
          magna mollis euismod. Morbi leo risus, porta ac consectetur.
        </p>
        <p class="font-sans text-xs leading-relaxed text-(--content-caption)">
          <span class="font-semibold">text-xs · caption —</span> Etiam porta sem malesuada
          magna mollis euismod.
        </p>
        <p
          class="font-sans text-base font-semibold leading-relaxed text-(--content-emphasis)"
        >
          <span class="">text-base · emphasis —</span> Etiam porta sem malesuada magna.
        </p>
      </div>
    </div>

    <!-- Weight Scale -->
    <div>
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Weight Scale — Alumni Sans
      </p>
      <div class="flex flex-wrap gap-x-8 gap-y-4">
        {
          [
            ["font-thin", "100"],
            ["font-extralight", "200"],
            ["font-light", "300"],
            ["font-normal", "400"],
            ["font-medium", "500"],
            ["font-semibold", "600"],
            ["font-bold", "700"],
            ["font-extrabold", "800"],
            ["font-black", "900"],
          ].map(([cls, weight]) => (
            <div class="flex flex-col items-center gap-0.5">
              <span
                class={`font-display text-4xl leading-none text-(--content-heading) ${cls}`}
              >
                Elco
              </span>
              <span class="font-sans text-xs text-(--content-meta)">
                {weight}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       BRAND COLORS
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="colors" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        02
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        Brand Colors
      </h2>
      <p class="mt-1 font-sans text-sm text-(--content-meta)">
        OKLCH color space · 500 is the brand anchor for each palette
      </p>
    </header>

    <div class="space-y-10">
      {
        palettes.map((palette) => (
          <div>
            <p class="mb-3 font-sans text-sm font-semibold text-(--content-body)">
              {palette.name}
            </p>
            <div class="grid grid-cols-5 gap-1.5 lg:grid-cols-10">
              {palette.stops.map((stop) => (
                <div class="flex flex-col items-center gap-1.5">
                  <div
                    class="w-full rounded-md shadow-sm"
                    style={`
                      aspect-ratio: 1;
                      background-color: ${stop.value};
                      ${stop.anchor ? "outline: 2px solid var(--content-body); outline-offset: 2px;" : ""}
                    `}
                  />
                  <div class="flex flex-col items-center gap-0">
                    <span
                      class={`font-sans text-xs text-(--content-body) ${stop.anchor ? "font-bold" : ""}`}
                    >
                      {stop.stop}
                      {stop.anchor ? " ★" : ""}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       SEMANTIC TOKENS
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="tokens" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        03
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        Semantic Tokens
      </h2>
      <p class="mt-1 font-sans text-sm text-(--content-meta)">
        Theme-aware design tokens · adapts between light and dark mode
      </p>
    </header>

    <!-- Surfaces -->
    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Surfaces
      </p>
      <div class="grid grid-cols-3 gap-3 sm:grid-cols-3 max-w-sm">
        {
          [
            ["--surface-primary", "surface-primary", "Page background"],
            ["--surface-secondary", "surface-secondary", "Card / section bg"],
            ["--surface-tertiary", "surface-tertiary", "Hover / elevated"],
          ].map(([token, name, desc]) => (
            <div class="flex flex-col gap-1.5">
              <div
                class="h-16 w-full rounded-md shadow-sm ring-1 ring-(--border-primary)"
                style={`background-color: var(${token})`}
              />
              <span class="font-sans text-xs font-semibold text-(--content-body)">
                {name}
              </span>
              <span class="font-sans text-xs text-(--content-meta)">
                {desc}
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Borders -->
    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Borders
      </p>
      <div class="grid grid-cols-3 gap-3 max-w-sm">
        {
          [
            ["--border-primary", "border-primary"],
            ["--border-secondary", "border-secondary"],
            ["--border-tertiary", "border-tertiary"],
          ].map(([token, name]) => (
            <div class="flex flex-col gap-1.5">
              <div
                class="h-16 w-full rounded-md"
                style={`border: 4px solid var(${token}); background: transparent`}
              />
              <span class="font-sans text-xs font-semibold text-(--content-body)">
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Content Tokens -->
    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Content
      </p>
      <div class="flex flex-wrap gap-6">
        {
          [
            ["--content-heading", "content-heading", "Headings"],
            ["--content-body", "content-body", "Body copy"],
            ["--content-meta", "content-meta", "Labels, captions"],
            ["--content-emphasis", "content-emphasis", "Links, highlights"],
            ["--content-caption", "content-caption", "Fine print"],
          ].map(([token, name, desc]) => (
            <div class="flex flex-col items-start gap-0.5">
              <span
                class={`font-display font-black text-4xl`}
                style={`color: var(${token})`}
              >
                Aa
              </span>
              <span class="font-sans text-xs font-semibold text-(--content-body)">
                {name}
              </span>
              <span class="font-sans text-xs text-(--content-meta)">
                {desc}
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- UI Tokens -->
    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        UI — Button (Primary)
      </p>
      <div class="flex flex-wrap gap-4">
        {
          [
            ["--ui-button-surface", "button-surface"],
            ["--ui-button-text", "button-text"],
            ["--ui-button-border", "button-border"],
            ["--ui-button-ring", "button-ring"],
          ].map(([token, name]) => (
            <div class="flex flex-col items-center gap-1.5">
              <div
                class="h-12 w-12 rounded-md shadow-sm"
                style={`background-color: var(${token})`}
              />
              <span class="font-sans text-xs text-(--content-meta)">
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mb-12">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        UI — Input
      </p>
      <div class="flex flex-wrap gap-4">
        {
          [
            ["--ui-input-surface", "input-surface"],
            ["--ui-input-text", "input-text"],
            ["--ui-input-border", "input-border"],
            ["--ui-input-focus", "input-focus"],
          ].map(([token, name]) => (
            <div class="flex flex-col items-center gap-1.5">
              <div
                class="h-12 w-12 rounded-md shadow-sm"
                style={`background-color: var(${token})`}
              />
              <span class="font-sans text-xs text-(--content-meta)">
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <div>
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        UI — Navigation
      </p>
      <div class="flex flex-wrap gap-4">
        {
          [
            ["--ui-nav-surface", "nav-surface"],
            ["--ui-nav-text", "nav-text"],
            ["--ui-nav-border", "nav-border"],
            ["--ui-nav-hover", "nav-hover"],
          ].map(([token, name]) => (
            <div class="flex flex-col items-center gap-1.5">
              <div
                class="h-12 w-12 rounded-md shadow-sm"
                style={`background-color: var(${token})`}
              />
              <span class="font-sans text-xs text-(--content-meta)">
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       BUTTONS
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="buttons" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        04
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        Buttons
      </h2>
    </header>

    <!-- Variants × Sizes grid -->
    <div class="mb-10 overflow-x-auto">
      <table class="w-full border-collapse">
        <thead>
          <tr>
            <th
              class="pb-3 text-left font-sans text-xs font-semibold uppercase tracking-wider text-(--content-meta)"
              >Variant</th
            >
            <th
              class="pb-3 text-left font-sans text-xs font-semibold uppercase tracking-wider text-(--content-meta)"
              >sm</th
            >
            <th
              class="pb-3 text-left font-sans text-xs font-semibold uppercase tracking-wider text-(--content-meta)"
              >md (default)</th
            >
            <th
              class="pb-3 text-left font-sans text-xs font-semibold uppercase tracking-wider text-(--content-meta)"
              >lg</th
            >
          </tr>
        </thead>
        <tbody class="divide-y divide-(--border-primary)">
          {
            (["primary", "secondary", "outline", "ghost"] as const).map(
              (variant) => (
                <tr>
                  <td class="py-4 pr-6 font-sans text-xs text-(--content-meta) align-middle">
                    {variant}
                  </td>
                  <td class="py-4 pr-4 align-middle">
                    <Button variant={variant} size="sm">
                      Button
                    </Button>
                  </td>
                  <td class="py-4 pr-4 align-middle">
                    <Button variant={variant} size="md">
                      Button
                    </Button>
                  </td>
                  <td class="py-4 pr-4 align-middle">
                    <Button variant={variant} size="lg">
                      Button
                    </Button>
                  </td>
                </tr>
              ),
            )
          }
        </tbody>
      </table>
    </div>

    <!-- States -->
    <div>
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        States
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <Button>Default</Button>
        <Button disabled>Disabled</Button>
        <Button loading loadingText="Saving...">Save</Button>
        <Button variant="secondary">Secondary</Button>
        <Button variant="secondary" disabled>Disabled</Button>
        <Button variant="secondary" loading loadingText="Loading..."
          >Load</Button
        >
      </div>
    </div>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       FORMS
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="forms" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        05
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        Forms
      </h2>
    </header>

    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 max-w-3xl">
      <!-- Text Input -->
      <div>
        <p
          class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
        >
          Text Input
        </p>
        <div class="space-y-4">
          <div>
            <label
              class="mb-1 block font-sans text-sm font-semibold text-(--content-body)"
              >Default</label
            >
            <input
              type="text"
              placeholder="Placeholder text..."
              class="w-full rounded-sm border border-(--ui-input-border) bg-(--ui-input-surface) px-3 py-2 font-sans text-sm text-(--ui-input-text) outline-none transition-colors focus:border-(--ui-input-focus) focus:ring-1 focus:ring-(--ui-input-focus)"
            />
          </div>
          <div>
            <label
              class="mb-1 block font-sans text-sm font-semibold text-(--content-body)"
              >Filled</label
            >
            <input
              type="text"
              value="El Camino Skate Co."
              class="w-full rounded-sm border border-(--ui-input-border) bg-(--ui-input-surface) px-3 py-2 font-sans text-sm text-(--ui-input-text) outline-none transition-colors focus:border-(--ui-input-focus) focus:ring-1 focus:ring-(--ui-input-focus)"
            />
          </div>
          <div>
            <label
              class="mb-1 block font-sans text-sm font-semibold text-(--content-meta)"
              >Disabled</label
            >
            <input
              type="text"
              value="Disabled value"
              disabled
              class="w-full cursor-not-allowed rounded-sm border border-(--ui-input-border) bg-(--ui-input-surface) px-3 py-2 font-sans text-sm text-(--ui-input-text) opacity-50 outline-none"
            />
          </div>
        </div>
      </div>

      <!-- Select -->
      <div>
        <p
          class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
        >
          Select
        </p>
        <div class="space-y-4">
          <div>
            <label
              class="mb-1 block font-sans text-sm font-semibold text-(--content-body)"
              >Dropdown</label
            >
            <select
              class="w-full rounded-sm border border-(--ui-input-border) bg-(--ui-input-surface) px-3 py-2 font-sans text-sm text-(--ui-input-text) outline-none transition-colors focus:border-(--ui-input-focus) focus:ring-1 focus:ring-(--ui-input-focus)"
            >
              <option>Option One</option>
              <option>Option Two</option>
              <option>Option Three</option>
            </select>
          </div>
          <div>
            <label
              class="mb-1 block font-sans text-sm font-semibold text-(--content-meta)"
              >Disabled</label
            >
            <select
              disabled
              class="w-full cursor-not-allowed rounded-sm border border-(--ui-input-border) bg-(--ui-input-surface) px-3 py-2 font-sans text-sm text-(--ui-input-text) opacity-50 outline-none"
            >
              <option>Option One</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Checkbox -->
      <div>
        <p
          class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
        >
          Checkbox
        </p>
        <div class="space-y-3">
          <label class="flex cursor-pointer items-center gap-2.5">
            <input type="checkbox" class="elco-checkbox" />
            <span class="font-sans text-sm text-(--content-body)"
              >Unchecked</span
            >
          </label>
          <label class="flex cursor-pointer items-center gap-2.5">
            <input type="checkbox" class="elco-checkbox" checked />
            <span class="font-sans text-sm text-(--content-body)">Checked</span>
          </label>
          <label class="flex cursor-not-allowed items-center gap-2.5">
            <input type="checkbox" class="elco-checkbox" disabled />
            <span class="font-sans text-sm text-(--content-meta)">Disabled</span
            >
          </label>
          <label class="flex cursor-not-allowed items-center gap-2.5">
            <input type="checkbox" class="elco-checkbox" checked disabled />
            <span class="font-sans text-sm text-(--content-meta)"
              >Checked + disabled</span
            >
          </label>
        </div>
      </div>

      <!-- Radio -->
      <div>
        <p
          class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
        >
          Radio
        </p>
        <div class="space-y-3">
          <label class="flex cursor-pointer items-center gap-2.5">
            <input type="radio" name="sg-radio" class="elco-radio h-4 w-4" />
            <span class="font-sans text-sm text-(--content-body)">Option A</span
            >
          </label>
          <label class="flex cursor-pointer items-center gap-2.5">
            <input
              type="radio"
              name="sg-radio"
              class="elco-radio h-4 w-4"
              checked
            />
            <span class="font-sans text-sm text-(--content-body)"
              >Option B (selected)</span
            >
          </label>
          <label class="flex cursor-not-allowed items-center gap-2.5">
            <input
              type="radio"
              name="sg-radio"
              class="elco-radio h-4 w-4"
              disabled
            />
            <span class="font-sans text-sm text-(--content-meta)"
              >Option C (disabled)</span
            >
          </label>
        </div>
      </div>

      <!-- Textarea -->
      <div class="md:col-span-2">
        <p
          class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
        >
          Textarea
        </p>
        <textarea
          rows="4"
          placeholder="Write something..."
          class="w-full max-w-lg rounded-sm border border-(--ui-input-border) bg-(--ui-input-surface) px-3 py-2 font-sans text-sm text-(--ui-input-text) outline-none transition-colors focus:border-(--ui-input-focus) focus:ring-1 focus:ring-(--ui-input-focus)"
        ></textarea>
      </div>
    </div>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       STATE COLORS
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="states" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        06
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        State Colors
      </h2>
    </header>

    <!-- Swatch chips -->
    <div class="mb-10 flex flex-wrap gap-3">
      {
        stateColors.map((s) => (
          <div class="flex flex-col items-center gap-1.5">
            <div
              class="flex h-16 w-28 items-center justify-center rounded-md shadow-sm font-sans text-sm font-semibold"
              style={`background-color: ${s.surface}; color: ${s.text}`}
            >
              {s.name}
            </div>
            <span class="font-sans text-xs text-(--content-meta)">
              {s.token}
            </span>
          </div>
        ))
      }
    </div>

    <!-- Alert banners -->
    <div class="space-y-3 max-w-xl">
      <p
        class="font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta) mb-4"
      >
        Alert Banners
      </p>
      {
        stateColors.map((s) => (
          <div
            class="flex items-center gap-3 rounded-sm px-4 py-3 font-sans text-sm font-semibold"
            style={`background-color: ${s.surface}; color: ${s.text}`}
          >
            <span class="uppercase tracking-wide text-xs opacity-75">
              {s.name}
            </span>
            <span>·</span>
            <span>Your changes have been applied successfully.</span>
          </div>
        ))
      }
    </div>

    <!-- Dark mode note -->
    <p class="mt-6 font-sans text-xs text-(--content-meta)">
      Dark mode overrides are active — state surface colors shift lighter to
      maintain contrast on deep fig-leaf backgrounds.
    </p>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       LOADING STATES
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="loading" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        07
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        Loading States
      </h2>
    </header>

    <!-- Spinner + text (current production version) -->
    <div class="mb-8">
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Infinite Scroll — Current
      </p>
      <div class="inline-flex items-center gap-2 py-4">
        <div
          class="inline-block h-4 w-4 animate-spin rounded-full border-b-2 border-(--content-heading)"
        >
        </div>
        <p class="font-sans text-(--content-meta)">Loading more products...</p>
      </div>
    </div>

    <!-- Skeleton placeholder -->
    <div>
      <p
        class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        Skeleton Placeholder
      </p>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 max-w-lg">
        {
          [1, 2, 3, 4].map(() => (
            <div class="space-y-2">
              <div class="h-32 w-full animate-pulse rounded-sm bg-(--surface-tertiary)" />
              <div class="h-3 w-3/4 animate-pulse rounded-sm bg-(--surface-tertiary)" />
              <div class="h-3 w-1/2 animate-pulse rounded-sm bg-(--surface-tertiary)" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       ICONS
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="icons" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        08
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        Icons
      </h2>
      <p class="mt-1 font-sans text-sm text-(--content-meta)">
        Unicons (uil:*)
      </p>
    </header>

    <div
      class="grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-9"
    >
      {
        iconList.map((name) => (
          <div class="flex flex-col items-center gap-2 rounded-md p-3 transition-colors hover:bg-(--surface-secondary)">
            <Icon class="h-8 w-8 text-(--content-body)" name={name} />
            <span class="text-center font-mono text-xs text-(--content-meta) leading-tight">
              {name.replace("uil:", "")}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="mx-8 border-(--border-primary)" />

  <!-- ════════════════════════════════════════════════════════════════════
       REFERENCES
  ═══════════════════════════════════════════════════════════════════════ -->
  <section id="references" class="scroll-mt-14 px-8 py-16">
    <header class="mb-10">
      <p
        class="mb-1 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
      >
        09
      </p>
      <h2 class="font-display font-black text-3xl text-(--content-heading)">
        References
      </h2>
    </header>

    <div class="grid gap-12 md:grid-cols-2">
      <!-- Shop Sites -->
      <div>
        <p
          class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
        >
          Competitor Shop Sites
        </p>
        <ul class="space-y-2">
          {
            shopSites.map((site) => (
              <li>
                <a
                  href={site.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-sm text-(--content-emphasis) underline decoration-(--content-emphasis)/0 underline-offset-2 transition-all hover:decoration-(--content-emphasis)/80 hover:underline-offset-4"
                >
                  {site.name}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="mt-4 font-sans text-xs text-(--content-meta)">
          * Uses Square
        </p>
      </div>

      <!-- Prototype Links -->
      <div>
        <p
          class="mb-4 font-sans text-xs font-semibold uppercase tracking-widest text-(--content-meta)"
        >
          Figma Prototypes
        </p>
        <ul class="space-y-2">
          {
            prototypes.map((p) => (
              <li>
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-sm text-(--content-emphasis) underline decoration-(--content-emphasis)/0 underline-offset-2 transition-all hover:decoration-(--content-emphasis)/80 hover:underline-offset-4"
                >
                  {p.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</AdminLayout>
