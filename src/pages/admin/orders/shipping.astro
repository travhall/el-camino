---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { Client, Environment } from "square/legacy";
import { filterDismissed } from "@/lib/admin/dismissedOrders";

function formatMoney(amount: bigint | number | undefined | null): string {
  if (amount == null) return "$0.00";
  const cents = typeof amount === "bigint" ? Number(amount) : amount;
  return `$${(cents / 100).toFixed(2)}`;
}
function toTotalCents(amount: bigint | number | undefined | null): number {
  if (amount == null) return 0;
  return typeof amount === "bigint" ? Number(amount) : amount;
}
function shortId(id: string) { return id.slice(-8).toUpperCase(); }
function formatDate(iso: string | undefined) {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

interface ShippingOrder {
  orderId: string; shortId: string;
  createdAt: string; createdAtIso: string;
  customerName: string; customerEmail: string; address: string;
  items: { name: string; qty: string }[];
  total: string; totalCents: number;
  fulfillmentUid: string;
}

const params = Astro.url.searchParams;
const successId = params.get("shipped");
const shippedId = params.get("shippedId");
const dismissedOne = params.get("dismissed");
const errorType = params.get("error");
const errorDetail = params.get("detail");

let orders: ShippingOrder[] = [];
let fetchError = false;

try {
  const client = new Client({
    accessToken: process.env.SQUARE_ACCESS_TOKEN!,
    environment: import.meta.env.PUBLIC_SQUARE_ENVIRONMENT === "production"
      ? Environment.Production : Environment.Sandbox,
  });
  const { result } = await client.ordersApi.searchOrders({
    locationIds: [import.meta.env.PUBLIC_SQUARE_LOCATION_ID],
    query: {
      filter: {
        fulfillmentFilter: { fulfillmentTypes: ["SHIPMENT"], fulfillmentStates: ["PROPOSED"] },
        stateFilter: { states: ["OPEN"] },
      },
      sort: { sortField: "CREATED_AT", sortOrder: "ASC" },
    },
  });

  for (const order of result.orders ?? []) {
    // Skip orders with no captured payment — Square will reject any fulfillment
    // update with "cannot be COMPLETED before the order is paid for".
    // In production all checkout orders have tenders; this only filters sandbox
    // orders created without going through the payment flow.
    if (!order.tenders?.length) continue;

    const f = order.fulfillments?.find((f) => f.type === "SHIPMENT");
    if (!f) continue;
    const r = f.shipmentDetails?.recipient;
    const a = r?.address;
    const addrParts = [a?.addressLine1, a?.addressLine2,
      a ? `${a.locality}, ${a.administrativeDistrictLevel1} ${a.postalCode}` : null,
    ].filter(Boolean).join(", ");
    const items = (order.lineItems ?? [])
      .filter((li) => li.catalogObjectId)
      .map((li) => ({ name: li.name ?? "Item", qty: li.quantity ?? "1" }));

    orders.push({
      orderId: order.id ?? "", shortId: shortId(order.id ?? ""),
      createdAt: formatDate(order.createdAt), createdAtIso: order.createdAt ?? "",
      customerName: r?.displayName ?? "Unknown",
      customerEmail: r?.emailAddress ?? "",
      address: addrParts || "No address",
      items, total: formatMoney(order.totalMoney?.amount),
      totalCents: toTotalCents(order.totalMoney?.amount),
      fulfillmentUid: f.uid ?? "",
    });
  }
} catch (err) {
  console.error("[admin/orders/shipping] Failed to fetch:", err);
  fetchError = true;
}

orders = await filterDismissed(orders);
if (shippedId) orders = orders.filter((o) => o.orderId !== shippedId);
const count = orders.length;
---

<AdminLayout title="Orders" description="">
  <!-- Sub-nav tabs -->
  <div class="flex gap-1 border-b border-(--border-primary) mb-6 -mt-4">
    <a href="/admin/orders/shipping"
       class="px-4 py-2 text-sm font-semibold border-b-2 border-(--content-heading) text-(--content-heading)">
      Shipping
    </a>
    <a href="/admin/orders/pickups"
       class="px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-(--content-meta) hover:text-(--content-body) transition-colors">
      Pick Ups
    </a>
    <a href="/admin/orders/archive"
       class="px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-(--content-meta) hover:text-(--content-body) transition-colors">
      Archive
    </a>
  </div>

  {successId && (
    <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800 font-medium">
      Order marked as shipped — shipping confirmation sent to customer.
    </div>
  )}
  {dismissedOne && (
    <div class="mb-4 px-4 py-3 bg-amber-50 border border-amber-200 rounded-sm text-sm text-amber-800">
      Order dismissed and hidden from this list.
    </div>
  )}
  {errorType === "update" && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      <strong>Square rejected the update.</strong>
      {errorDetail && <span class="block mt-1 font-mono text-xs">{errorDetail}</span>}
    </div>
  )}
  {errorType === "email" && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Square was updated but the confirmation email failed. Check Resend logs.
    </div>
  )}
  {errorType === "fetch" && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Could not retrieve that order from Square. Try again.
    </div>
  )}
  {errorType === "no-email" && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      No customer email on this order. Check Square for contact details.
    </div>
  )}
  {fetchError && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Could not load orders from Square. Check credentials and refresh.
    </div>
  )}

  {!fetchError && count === 0 && (
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-10 text-center">
      <p class="text-(--content-heading) font-semibold mb-1">No pending shipments</p>
      <p class="text-(--content-meta) text-sm">All shipping orders have been fulfilled.</p>
    </div>
  )}

  {count > 0 && (
    <>
      <!-- Toolbar -->
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <p class="text-sm text-(--content-meta) mr-auto">
          <span id="order-count">{count}</span> pending {count === 1 ? "shipment" : "shipments"}
        </p>
        <input id="order-search" type="search" placeholder="Search customer or order…"
               class="border border-(--border-primary) rounded-sm px-3 py-1.5 text-sm bg-(--surface-primary) text-(--content-body) w-56 focus:outline-none focus:ring-2 focus:ring-(--fig-leaf-500,#4d7a2e)" />
        <select id="order-sort"
                class="border border-(--border-primary) rounded-sm px-2 py-1.5 text-sm bg-(--surface-primary) text-(--content-body) focus:outline-none focus:ring-2 focus:ring-(--fig-leaf-500,#4d7a2e)">
          <option value="oldest">Oldest first</option>
          <option value="newest">Newest first</option>
          <option value="total-high">Total: high → low</option>
          <option value="total-low">Total: low → high</option>
        </select>
      </div>

      <!-- Orders list -->
      <div id="orders-list" class="space-y-2">
        {orders.map((order) => (
          <div class="order-row border border-(--border-primary) border-l-4 border-l-sky-700 rounded-sm overflow-hidden"
               data-customer={order.customerName.toLowerCase()}
               data-order-id={order.shortId.toLowerCase()}
               data-items={order.items.map(i => i.name).join(" ").toLowerCase()}
               data-date={order.createdAtIso}
               data-total={order.totalCents}>
            <!-- Row 1: customer / email / address / meta / total -->
            <div class="flex flex-wrap items-center gap-x-4 gap-y-0.5 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
              <div class="flex flex-col min-w-0">
                <span class="text-base font-semibold text-(--content-heading) leading-tight">{order.customerName}</span>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-0.5">
                  {order.customerEmail && (
                    <button class="copy-btn text-sm text-(--content-meta) hover:text-(--content-body) transition-colors text-left"
                            data-copy={order.customerEmail}>{order.customerEmail}</button>
                  )}
                  <span class="text-sm text-(--content-body)">{order.address}</span>
                </div>
              </div>
              <div class="flex items-center gap-2 ml-auto shrink-0">
                <span class="text-xs text-(--content-meta)">{order.createdAt}</span>
                <button class="copy-btn font-mono text-xs font-semibold text-(--content-meta) bg-(--surface-primary) border border-(--border-primary) rounded px-1.5 py-0.5 hover:text-(--content-body) transition-colors"
                        data-copy={order.shortId}>#{order.shortId}</button>
                <span class="text-base font-bold text-(--content-heading)">{order.total}</span>
              </div>
            </div>
            <!-- Row 2: item pills -->
            <div class="px-4 py-2.5 flex flex-wrap gap-1.5 bg-sky-50 border-b border-(--border-primary)">
              {order.items.map((item) => (
                <span class="inline-flex items-center gap-1 text-sm px-2.5 py-0.5 rounded-full border border-sky-200 bg-white text-sky-900 font-medium">
                  {Number(item.qty) > 1 && <span class="text-sky-500 font-semibold">{item.qty}×</span>}
                  {item.name}
                </span>
              ))}
            </div>
            <!-- Row 3: mark-shipped form -->
            <div class="px-4 py-2.5 bg-(--surface-secondary)">
              <form method="POST" action="/api/admin/mark-shipped"
                    class="flex flex-wrap items-center gap-2">
                <input type="hidden" name="orderId" value={order.orderId} />
                <input name="trackingNumber" type="text" placeholder="Tracking number (optional)"
                       class="flex-1 min-w-40 border border-(--border-primary) rounded-sm px-3 py-1.5 text-sm bg-(--surface-primary) text-(--content-body) focus:outline-none focus:ring-2 focus:ring-(--fig-leaf-500,#4d7a2e)" />
                <select name="carrier"
                        class="border border-(--border-primary) rounded-sm px-2 py-1.5 text-sm bg-(--surface-primary) text-(--content-body) focus:outline-none focus:ring-2 focus:ring-(--fig-leaf-500,#4d7a2e)">
                  <option value="">Carrier</option>
                  <option value="USPS">USPS</option>
                  <option value="UPS">UPS</option>
                  <option value="FedEx">FedEx</option>
                  <option value="Other">Other</option>
                </select>
                <button type="submit"
                        class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap shrink-0">
                  Mark as Shipped
                </button>
              </form>
            </div>
          </div>
        ))}
      </div>

      <p id="no-results" class="hidden text-sm text-(--content-meta) text-center py-8">
        No orders match your search.
      </p>
    </>
  )}
</AdminLayout>

<script>
  const searchEl = document.getElementById("order-search") as HTMLInputElement;
  const sortEl = document.getElementById("order-sort") as HTMLSelectElement;
  const list = document.getElementById("orders-list");
  const countEl = document.getElementById("order-count");
  const noResults = document.getElementById("no-results");

  if (searchEl && sortEl && list) {
    function rows() {
      return [...list!.querySelectorAll<HTMLElement>(".order-row")];
    }

    function applySort() {
      const val = sortEl.value;
      const sorted = rows().sort((a, b) => {
        if (val === "oldest") return (a.dataset.date ?? "").localeCompare(b.dataset.date ?? "");
        if (val === "newest") return (b.dataset.date ?? "").localeCompare(a.dataset.date ?? "");
        if (val === "total-high") return Number(b.dataset.total ?? 0) - Number(a.dataset.total ?? 0);
        if (val === "total-low") return Number(a.dataset.total ?? 0) - Number(b.dataset.total ?? 0);
        return 0;
      });
      sorted.forEach((r) => list!.appendChild(r));
    }

    function applySearch() {
      const q = searchEl.value.toLowerCase().trim();
      let visible = 0;
      rows().forEach((row) => {
        const match = !q ||
          (row.dataset.customer ?? "").includes(q) ||
          (row.dataset.orderId ?? "").includes(q) ||
          (row.dataset.items ?? "").includes(q);
        row.style.display = match ? "" : "none";
        if (match) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
      if (noResults) noResults.classList.toggle("hidden", visible > 0);
    }

    searchEl.addEventListener("input", applySearch);
    sortEl.addEventListener("change", () => { applySort(); applySearch(); });
  }

  // Auto-detect carrier from tracking number pattern
  function detectCarrier(tracking: string): string | null {
    const t = tracking.replace(/\s+/g, "").toUpperCase();
    if (!t) return null;
    if (/^1Z/i.test(t)) return "UPS";                          // UPS: always starts with 1Z
    if (/^9[0-9]{19,21}$/.test(t)) return "USPS";             // USPS domestic: 20–22 digits starting with 9
    if (/^[A-Z]{2}[0-9]{8}[A-Z]{2}$/.test(t)) return "USPS"; // USPS international: EA123456789US
    if (/^96[0-9]{18,20}$/.test(t)) return "FedEx";           // FedEx Ground: starts with 96
    if (/^[0-9]{12}$/.test(t) && !t.startsWith("9")) return "FedEx";
    if (/^[0-9]{15}$/.test(t) && !t.startsWith("9")) return "FedEx";
    return null;
  }

  document.querySelectorAll<HTMLElement>(".order-row").forEach((row) => {
    const trackingInput = row.querySelector<HTMLInputElement>("input[name='trackingNumber']");
    const carrierSelect = row.querySelector<HTMLSelectElement>("select[name='carrier']");
    if (!trackingInput || !carrierSelect) return;

    trackingInput.addEventListener("input", () => {
      const detected = detectCarrier(trackingInput.value);
      if (detected) {
        carrierSelect.value = detected;
        carrierSelect.classList.add("ring-2", "ring-sky-400");
        setTimeout(() => carrierSelect.classList.remove("ring-2", "ring-sky-400"), 1200);
      }
    });
  });

  // Click-to-copy for email, address, and order ID
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy ?? btn.textContent?.trim() ?? "";
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = "Copied!";
      btn.classList.add("text-sky-600");
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove("text-sky-600");
      }, 1500);
    });
  });
</script>
