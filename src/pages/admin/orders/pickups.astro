---
import AdminLayout from "@/layouts/AdminLayout.astro";
import OrdersSubNav from "@/components/admin/OrdersSubNav.astro";
import { Client, Environment } from "square/legacy";
import { filterDismissed } from "@/lib/admin/dismissedOrders";

function formatMoney(amount: bigint | number | undefined | null): string {
  if (amount == null) return "$0.00";
  const cents = typeof amount === "bigint" ? Number(amount) : amount;
  return `$${(cents / 100).toFixed(2)}`;
}
function toTotalCents(amount: bigint | number | undefined | null): number {
  if (amount == null) return 0;
  return typeof amount === "bigint" ? Number(amount) : amount;
}
function shortId(id: string) { return id.slice(-8).toUpperCase(); }
function formatDate(iso: string | undefined) {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

interface PickupOrder {
  orderId: string; shortId: string;
  createdAt: string; createdAtIso: string;
  customerName: string; customerEmail: string; customerPhone: string;
  items: { name: string; qty: string }[];
  total: string; totalCents: number; note: string;
  pickupAt: string; // formatted ready-by time, empty string if not set
}

const params = Astro.url.searchParams;
const successId = params.get("completed");
const completedId = params.get("completedId");
const dismissedOne = params.get("dismissed");
const errorType = params.get("error");
const errorDetail = params.get("detail");

let orders: PickupOrder[] = [];
let fetchError = false;

try {
  const client = new Client({
    accessToken: process.env.SQUARE_ACCESS_TOKEN!,
    environment: import.meta.env.PUBLIC_SQUARE_ENVIRONMENT === "production"
      ? Environment.Production : Environment.Sandbox,
  });
  const { result } = await client.ordersApi.searchOrders({
    locationIds: [import.meta.env.PUBLIC_SQUARE_LOCATION_ID],
    query: {
      filter: {
        fulfillmentFilter: { fulfillmentTypes: ["PICKUP"], fulfillmentStates: ["PROPOSED", "RESERVED", "PREPARED"] },
        stateFilter: { states: ["OPEN"] },
      },
      sort: { sortField: "CREATED_AT", sortOrder: "ASC" },
    },
  });

  for (const order of result.orders ?? []) {
    if (!order.tenders?.length) continue;

    const f = order.fulfillments?.find((f) => f.type === "PICKUP");
    if (!f) continue;
    const pd = f.pickupDetails;
    const recipient = pd?.recipient;
    const rawNote = pd?.note ?? "";
    const customerNotesMatch = rawNote.match(/Customer Notes:\s*(.+)$/s);
    const note = customerNotesMatch?.[1]?.trim() ?? "";
    const pickupAtIso = pd?.pickupAt ?? "";
    const pickupAt = pickupAtIso
      ? new Date(pickupAtIso).toLocaleString("en-US", {
          weekday: "short", month: "short", day: "numeric",
          hour: "numeric", minute: "2-digit",
          timeZone: "America/Chicago", timeZoneName: "short",
        })
      : "";
    const items = (order.lineItems ?? [])
      .filter((li) => li.catalogObjectId)
      .map((li) => ({ name: li.name ?? "Item", qty: li.quantity ?? "1" }));

    orders.push({
      orderId: order.id ?? "", shortId: shortId(order.id ?? ""),
      createdAt: formatDate(order.createdAt), createdAtIso: order.createdAt ?? "",
      customerName: recipient?.displayName ?? "Unknown",
      customerEmail: recipient?.emailAddress ?? "",
      customerPhone: recipient?.phoneNumber ?? "",
      items, total: formatMoney(order.totalMoney?.amount),
      totalCents: toTotalCents(order.totalMoney?.amount),
      note, pickupAt,
    });
  }
} catch (err) {
  console.error("[admin/orders/pickups] Failed to fetch:", err);
  fetchError = true;
}

orders = await filterDismissed(orders);
if (completedId) orders = orders.filter((o) => o.orderId !== completedId);
const count = orders.length;
---

<AdminLayout
  title="Orders"
  description="Mark orders as picked up and notify customers that their order is ready."
>
  <OrdersSubNav activeTab="pickups" />

  <!-- Screen-reader live region for copy-to-clipboard feedback -->
  <div role="status" aria-live="polite" aria-atomic="true" class="sr-only" id="copy-status"></div>

  {successId && (
    <div role="status" class="mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-sm text-sm text-green-800 font-medium">
      Order marked as picked up.
    </div>
  )}
  {dismissedOne && (
    <div role="status" class="mb-4 px-4 py-3 bg-amber-50 border border-amber-200 rounded-sm text-sm text-amber-800">
      Order dismissed and hidden from this list.
    </div>
  )}
  {errorType === "fetch" && (
    <div role="alert" class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Could not retrieve that order from Square. Try again.
    </div>
  )}
  {errorType === "update" && (
    <div role="alert" class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      <strong>Square rejected the update.</strong>
      {errorDetail && <span class="block mt-1 font-mono text-xs">{errorDetail}</span>}
    </div>
  )}
  {fetchError && (
    <div role="alert" class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-sm text-sm text-red-700">
      Could not load orders from Square. Check credentials and refresh.
    </div>
  )}

  {!fetchError && count === 0 && (
    <div class="bg-(--surface-secondary) border border-(--border-primary) rounded-sm p-10 text-center">
      <p class="text-(--content-heading) font-semibold mb-1">No pending pick ups</p>
      <p class="text-(--content-meta) text-sm">All pickup orders have been collected.</p>
    </div>
  )}

  {count > 0 && (
    <>
      <!-- Toolbar -->
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <p class="text-sm text-(--content-meta) mr-auto">
          <span id="order-count">{count}</span> pending {count === 1 ? "pick up" : "pick ups"}
        </p>
        <label for="order-search" class="sr-only">Search orders</label>
        <input id="order-search" type="search" placeholder="Search customer or order…"
               class="border border-(--border-primary) rounded-sm px-3 py-1.5 text-sm bg-(--surface-primary) text-(--content-body) w-56 focus:outline-none focus:ring-2 focus:ring-(--fig-leaf-500,#4d7a2e)" />
        <label for="order-sort" class="sr-only">Sort orders by</label>
        <select id="order-sort"
                class="border border-(--border-primary) rounded-sm px-2 py-1.5 text-sm bg-(--surface-primary) text-(--content-body) focus:outline-none focus:ring-2 focus:ring-(--fig-leaf-500,#4d7a2e)">
          <option value="oldest">Oldest first</option>
          <option value="newest">Newest first</option>
          <option value="total-high">Total: high → low</option>
          <option value="total-low">Total: low → high</option>
        </select>
      </div>

      <!-- Orders list -->
      <div id="orders-list" class="space-y-2">
        {orders.map((order) => (
          <div class="order-row border border-(--border-primary) border-l-4 border-l-emerald-600 rounded-sm overflow-hidden"
               data-customer={order.customerName.toLowerCase()}
               data-order-id={order.shortId.toLowerCase()}
               data-items={order.items.map(i => i.name).join(" ").toLowerCase()}
               data-date={order.createdAtIso}
               data-total={order.totalCents}>
            <!-- Row 1: customer / contact / meta / total -->
            <div class="flex flex-wrap items-center gap-x-4 gap-y-0.5 px-4 py-3 bg-(--surface-secondary) border-b border-(--border-primary)">
              <div class="flex flex-col min-w-0">
                <h2 class="text-base font-semibold text-(--content-heading) leading-tight">{order.customerName}</h2>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-0.5">
                  {order.customerEmail && (
                    <button class="copy-btn text-sm text-(--content-meta) hover:text-(--content-body) transition-colors text-left"
                            data-copy={order.customerEmail}
                            aria-label={`Copy email address for ${order.customerName}`}>{order.customerEmail}</button>
                  )}
                  {order.customerPhone && (
                    <button class="copy-btn text-sm text-(--content-meta) hover:text-(--content-body) transition-colors text-left"
                            data-copy={order.customerPhone}
                            aria-label={`Copy phone number for ${order.customerName}`}>{order.customerPhone}</button>
                  )}
                </div>
              </div>
              <div class="flex flex-col items-end gap-1 ml-auto shrink-0">
                <div class="flex items-center gap-2">
                  <span class="text-xs text-(--content-meta)">{order.createdAt}</span>
                  <button class="copy-btn font-mono text-xs font-semibold text-(--content-meta) bg-(--surface-primary) border border-(--border-primary) rounded px-1.5 py-0.5 hover:text-(--content-body) transition-colors"
                          data-copy={order.shortId}
                          aria-label={`Copy order ID ${order.shortId}`}>#{order.shortId}</button>
                  <span class="text-base font-bold text-(--content-heading)">{order.total}</span>
                </div>
                {order.pickupAt && (
                  <span class="text-xs font-medium text-emerald-700">Ready by {order.pickupAt}</span>
                )}
              </div>
            </div>
            <!-- Row 2: item pills -->
            <div class="px-4 py-2.5 flex flex-wrap gap-1.5 bg-emerald-50 border-b border-(--border-primary)">
              {order.items.map((item) => (
                <span class="inline-flex items-center gap-1 text-sm px-2.5 py-0.5 rounded-full border border-emerald-200 bg-white text-emerald-900 font-medium">
                  {Number(item.qty) > 1 && <span class="text-emerald-500 font-semibold">{item.qty}×</span>}
                  {item.name}
                </span>
              ))}
            </div>
            <!-- Row 3: customer note (only when present) -->
            {order.note && (
              <div class="px-4 py-2 flex items-start gap-2 bg-(--surface-primary) border-b border-(--border-primary)">
                <span class="shrink-0 text-xs font-semibold text-emerald-700 uppercase tracking-wide mt-0.5">Customer note</span>
                <span class="text-sm text-(--content-body) italic">{order.note}</span>
              </div>
            )}
            <!-- Row 4: action -->
            <div class="flex flex-wrap items-center gap-3 px-4 py-2.5 bg-(--surface-secondary)">
              <form method="POST" action="/api/admin/mark-pickedup">
                <input type="hidden" name="orderId" value={order.orderId} />
                <button type="submit"
                        class="font-sans font-semibold transition-all ease-in-out duration-300 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-(--ui-button-text) bg-(--ui-button-surface) border-(--ui-button-border) hover:bg-(--ui-button-surface)/75 focus-visible:ring-(--ui-button-ring) text-sm py-1.5 px-4 whitespace-nowrap">
                  Mark as Picked Up
                </button>
              </form>
              <button
                type="button"
                class="reminder-btn font-sans font-medium transition-all ease-in-out duration-200 border-2 rounded-sm focus-visible:ring outline-0 focus-visible:ring-offset-2 text-emerald-800 border-emerald-700 hover:bg-emerald-700/10 focus-visible:ring-emerald-400 text-sm py-1.5 px-4 whitespace-nowrap"
                data-order-id={order.orderId}
                aria-label={`Send pickup reminder to ${order.customerName}`}
              >
                Send Reminder
              </button>
            </div>
          </div>
        ))}
      </div>

      <p id="no-results" class="hidden text-sm text-(--content-meta) text-center py-8">
        No orders match your search.
      </p>
    </>
  )}
</AdminLayout>

<script>
  const searchEl = document.getElementById("order-search") as HTMLInputElement;
  const sortEl = document.getElementById("order-sort") as HTMLSelectElement;
  const list = document.getElementById("orders-list");
  const countEl = document.getElementById("order-count");
  const noResults = document.getElementById("no-results");
  const copyStatus = document.getElementById("copy-status");

  if (searchEl && sortEl && list) {
    function rows() {
      return [...list!.querySelectorAll<HTMLElement>(".order-row")];
    }

    function applySort() {
      const val = sortEl.value;
      const sorted = rows().sort((a, b) => {
        if (val === "oldest") return (a.dataset.date ?? "").localeCompare(b.dataset.date ?? "");
        if (val === "newest") return (b.dataset.date ?? "").localeCompare(a.dataset.date ?? "");
        if (val === "total-high") return Number(b.dataset.total ?? 0) - Number(a.dataset.total ?? 0);
        if (val === "total-low") return Number(a.dataset.total ?? 0) - Number(b.dataset.total ?? 0);
        return 0;
      });
      sorted.forEach((r) => list!.appendChild(r));
    }

    function applySearch() {
      const q = searchEl.value.toLowerCase().trim();
      let visible = 0;
      rows().forEach((row) => {
        const match = !q ||
          (row.dataset.customer ?? "").includes(q) ||
          (row.dataset.orderId ?? "").includes(q) ||
          (row.dataset.items ?? "").includes(q);
        row.style.display = match ? "" : "none";
        if (match) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
      if (noResults) noResults.classList.toggle("hidden", visible > 0);
    }

    searchEl.addEventListener("input", applySearch);
    sortEl.addEventListener("change", () => { applySort(); applySearch(); });
  }

  // Send reminder — fetch-based, no page reload
  document.querySelectorAll<HTMLButtonElement>(".reminder-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const orderId = btn.dataset.orderId!;
      const orig = btn.textContent!;
      btn.textContent = "Sending…";
      btn.disabled = true;

      try {
        const fd = new FormData();
        fd.append("orderId", orderId);
        const res = await fetch("/api/admin/send-pickup-reminder", {
          method: "POST",
          body: fd,
        });
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          console.error("[reminder] failed:", res.status, body);
          throw new Error(`HTTP ${res.status}`);
        }

        btn.textContent = "Sent!";
        btn.classList.add("text-emerald-600", "border-emerald-400");
      } catch (err) {
        console.error("[reminder] error:", err);
        btn.textContent = "Failed";
        btn.classList.add("text-red-600", "border-red-400");
      } finally {
        btn.disabled = false;
        setTimeout(() => {
          btn.textContent = orig;
          btn.classList.remove("text-emerald-600", "border-emerald-400", "text-red-600", "border-red-400");
        }, 2500);
      }
    });
  });

  // Click-to-copy with screen-reader announcement
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy ?? btn.textContent?.trim() ?? "";
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = "Copied!";
      btn.classList.add("text-emerald-600");
      if (copyStatus) {
        copyStatus.textContent = "Copied to clipboard";
        setTimeout(() => { copyStatus.textContent = ""; }, 1500);
      }
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove("text-emerald-600");
      }, 1500);
    });
  });
</script>
