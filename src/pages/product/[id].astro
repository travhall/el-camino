---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/Button.astro";
import Modal from "@/components/Modal.astro";
import RecentlyViewed from "@/components/RecentlyViewed.astro";
import RelatedProducts from "@/components/RelatedProducts.astro";
import SizeGuide from "@/components/SizeGuide.astro";
import BackInStock from "@/components/BackInStock.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { fetchProduct, fetchProducts } from "@/lib/square/client";
import { MoneyUtils } from "@/lib/square/money";
import { checkBulkInventory } from "@/lib/square/inventory";
import {
  createInitialSelectionState,
  getAttributeDisplayName,
} from "@/lib/square/variationParser";
import type { Product } from "@/lib/square/types";
import {
  extractIdFromSlug,
  createSlug,
  getVariationFromVariantParam,
  createSEOTitle,
  createSlugMapping,
} from "@/lib/square/slugUtils";
import { slugResolver } from "@/lib/square/slugResolver";
import {
  EL_CAMINO_LOGO_DATA_URI,
  EL_CAMINO_LOADER_DATA_URI,
} from "@/lib/constants/assets";
import {
  generateProductSchema,
  generateOGData,
  generateTwitterCardData,
} from "@/lib/product/structuredData";
import { generateBreadcrumbs } from "@/lib/product/breadcrumbs";
import { fetchCategories } from "@/lib/square/categories";
import { EnhancedImageOptimizer } from "@/lib/image/enhanced-optimizer";

// Get the slug or ID from URL params
const { id: slugOrId } = Astro.params;
const variantParam = Astro.url.searchParams.get("variant");

if (!slugOrId) {
  return Astro.redirect("/404");
}

// Check if this looks like a Square ID (uppercase alphanumeric, 24+ chars)
const looksLikeSquareId = /^[A-Z0-9]{24,}$/.test(slugOrId);

// Start fetching categories immediately — independent of product resolution
const categoriesPromise = fetchCategories();

let product;
let id;
let allProductsCache: Product[] | undefined;

if (looksLikeSquareId) {
  // Direct ID URL - fast path, no slug mapping needed
  product = await fetchProduct(slugOrId);
  id = slugOrId;
} else {
  // Slug URL - resolve to ID directly via slugResolver (blob cache, no HTTP hop)
  try {
    // Fast path: blob-cached slug → ID map (same data as /api/resolve-product, no round-trip)
    id = await slugResolver.resolve(slugOrId);

    if (!id) {
      // Fallback: full catalog fetch + mapping (handles slugs not yet in cache)
      allProductsCache = await fetchProducts();
      const slugMapping = createSlugMapping(allProductsCache);
      id = extractIdFromSlug(slugOrId, slugMapping);
    }

    if (id) {
      product = await fetchProduct(id);
    } else {
      console.error(`[PDP] Failed to resolve slug: ${slugOrId}`);
    }
  } catch (error) {
    console.error("[PDP] Error resolving slug:", error);
    // Last-resort fallback: full catalog fetch
    try {
      allProductsCache = await fetchProducts();
      const slugMapping = createSlugMapping(allProductsCache);
      id = extractIdFromSlug(slugOrId, slugMapping);
      if (id) {
        product = await fetchProduct(id);
      }
    } catch {
      console.error(`[PDP] All slug resolution attempts failed: ${slugOrId}`);
    }
  }
}

if (!product) {
  console.error(`Product not found for: ${slugOrId}`);
  return Astro.redirect("/404");
}

// console.log(
//   `[PDP] Successfully loaded product: ${product.title} (ID: ${product.id})`
// );

// Shallow-clone the product before any mutations so the BlobCache reference
// (fallbackCache returns the same object in dev/production) is never touched.
// Without this, mutations like product.image or product.selectedVariationId
// persist in the in-memory fallback cache and bleed across unrelated requests.
product = { ...product };

// Handle variant parameter
if (variantParam && product.variations) {
  const targetVariation = getVariationFromVariantParam(product, variantParam);

  if (targetVariation) {
    product.selectedVariationId = targetVariation.variationId;
    product.price = targetVariation.price;
    if (targetVariation.image) {
      product.image = targetVariation.image;
    }
  } else {
    // Invalid variant parameter - redirect to base product
    return Astro.redirect(`/product/${id}`, 301);
  }
}

if (!product) {
  return Astro.redirect("/404");
}

// Detect gift card via custom attribute set in Square Dashboard.
// More robust than category name matching — survives any category rename.
const isGiftCard = product.isGiftCard ?? false;

// Set default variation ID and prepare for inventory checking
// selectedVariationId is set above when ?variant= param is present.
let defaultVariationId = product.selectedVariationId ?? product.variationId;
let variations = product.variations || [];

// Fetch and process inventory (API call + data processing in one try block)
// Skip entirely for gift cards — they have no tracked inventory
if (!isGiftCard && variations.length > 0) {
  try {
    const inventoryMap = await checkBulkInventory(
      variations.map((v) => v.variationId),
    );

    variations = variations.map((v) => ({
      ...v,
      inStock: (inventoryMap[v.variationId] || 0) > 0,
      quantity: inventoryMap[v.variationId] || 0,
    }));

    // If default variation is out of stock, promote first in-stock variation
    const defaultIsInStock = (inventoryMap[defaultVariationId] || 0) > 0;
    if (!defaultIsInStock && variations.length > 0) {
      const firstInStockVariation = variations.find((v) => v.inStock);
      if (firstInStockVariation) {
        defaultVariationId = firstInStockVariation.variationId;
        if (firstInStockVariation.image) {
          product.image = firstInStockVariation.image;
        }
      }
    }
  } catch (err) {
    console.error(
      `Inventory check failed: ${err instanceof Error ? err.message : String(err)}`,
    );
    // Fail safe: mark out-of-stock so we never oversell on API failure.
    variations = variations.map((v) => ({
      ...v,
      inStock: false,
      quantity: 0,
    }));
  }
} else if (isGiftCard) {
  // Gift cards: unlimited stock, always in-stock, no API call needed
  variations = (
    product.variations?.length
      ? product.variations
      : [
          {
            id: product.variationId,
            variationId: product.variationId,
            name: product.title,
            price: product.price,
            attributes: {},
          },
        ]
  ).map((v) => ({
    ...v,
    inStock: true,
    quantity: 99, // sentinel — UI will suppress display of this value
  }));
} else {
  // Single-variation product — fetch inventory for the lone variation
  try {
    const inventoryMap = await checkBulkInventory([product.variationId]);
    const quantity = inventoryMap[product.variationId] || 0;
    variations = [
      {
        id: product.variationId,
        variationId: product.variationId,
        name: product.title,
        price: product.price,
        inStock: quantity > 0,
        quantity,
        attributes: {},
      },
    ];
  } catch (err) {
    console.error(
      `Inventory check failed for single variation: ${err instanceof Error ? err.message : String(err)}`,
    );
    // Fail safe: mark out-of-stock so we never oversell on API failure.
    variations = [
      {
        id: product.variationId,
        variationId: product.variationId,
        name: product.title,
        price: product.price,
        inStock: false,
        quantity: 0,
        attributes: {},
      },
    ];
  }
}

// Create initial selection state using the parser
// NOTE: this mutates variation.attributes in-place via parseVariationName — must
// run BEFORE any code that reads variation.attributes (e.g. the image assignment below).
const selectionState = createInitialSelectionState(variations);

// Fallback image assignment — covers the common Square pattern where color variant
// images are stored at the Item level (itemData.imageIds) rather than on each
// ItemVariation. After createInitialSelectionState, every variation has attributes
// parsed, so we can reliably find the color key and map product-level images onto
// the variations that lack a variation-level image.
// Mutates in place so all downstream references (selectionState, selectedVariation,
// the serialized hidden input) all see the updated image values.
if (product.images && product.images.length > 1) {
  const colorKey = Object.keys(variations[0]?.attributes ?? {}).find(
    (k) => k.toLowerCase() === "color" || k.toLowerCase() === "colour",
  );

  if (colorKey) {
    // Color variants: map one product image per color value onto variation.image.
    // Collect unique color values in catalog order (first-seen order)
    const colorOrder: string[] = [];
    for (const v of variations) {
      const c = v.attributes?.[colorKey];
      if (c && !colorOrder.includes(c)) colorOrder.push(c);
    }

    // Only map when there are at least as many product images as colors
    if (product.images.length >= colorOrder.length) {
      for (const v of variations) {
        if (v.image) continue; // Variation-level image always wins
        const colorValue = v.attributes?.[colorKey];
        const idx = colorOrder.indexOf(colorValue ?? "");
        if (idx >= 0 && product.images[idx]) {
          v.image = product.images[idx];
        }
      }
    }
  } else {
    // No color attribute — product.images are multi-angle shots shared by all
    // variations (e.g. a deck in multiple sizes). Assign the full image array to
    // every variation that doesn't already have variation-level images.
    for (const v of variations) {
      if (!v.images || v.images.length === 0) {
        v.images = product.images;
        if (!v.image) v.image = product.images[0];
      }
    }
  }
}
const availableAttributes = selectionState.availableAttributes;
const attributeTypes = Object.keys(availableAttributes);

// Find selected variation
const selectedVariation =
  variations.find((v) => v.variationId === defaultVariationId) || variations[0];
const selectedVariationInStock = selectedVariation?.inStock || false;
const selectedVariationQuantity = selectedVariation?.quantity || 0;

// Get sale info from selected variation
const saleInfo = selectedVariation?.saleInfo;
const isOnSale = !!saleInfo && selectedVariationInStock;

// Format prices based on sale status
const formattedPrice = saleInfo
  ? MoneyUtils.format(MoneyUtils.fromFloat(saleInfo.salePrice))
  : MoneyUtils.format(
      MoneyUtils.fromFloat(selectedVariation?.price || product.price),
    );

const formattedOriginalPrice = saleInfo
  ? MoneyUtils.format(MoneyUtils.fromFloat(saleInfo.originalPrice))
  : null;

// Check if we have multiple variations
const hasMultipleVariations = variations.length > 1;

// Generate structured data and social meta tags
const baseUrl = Astro.url.origin;

// Generate breadcrumbs (categories were fetched in parallel, above)
let breadcrumbPath;
try {
  const categories = await categoriesPromise;
  breadcrumbPath = await generateBreadcrumbs(product, categories, baseUrl);
} catch (err) {
  console.error("Failed to generate breadcrumbs:", err);
  // Non-critical, continue without breadcrumbs
}

const productSchema = generateProductSchema(
  product,
  selectedVariation,
  baseUrl,
);
const ogData = generateOGData(product, selectedVariation, baseUrl);
const twitterData = generateTwitterCardData(product, baseUrl);

// Fetch related products (same brand first, then same category — capped at 8)
let relatedProducts: Product[] = [];
try {
  const allProducts = allProductsCache ?? (await fetchProducts());
  const sameBrand = product.brand
    ? allProducts.filter(
        (p) => p.id !== product.id && p.brand === product.brand,
      )
    : [];
  const sameCategory = product.categories?.length
    ? allProducts.filter(
        (p) =>
          p.id !== product.id &&
          (!product.brand || p.brand !== product.brand) &&
          p.categories?.some((c) => product.categories?.includes(c)),
      )
    : [];
  relatedProducts = [...sameBrand, ...sameCategory].slice(0, 8);
} catch {
  // Non-critical — page renders fine without related products
}

// Set product metadata
const pageTitle = product.title;

// Strip brand prefix from the display title so the H1 doesn't read "Brand Brand Product"
const displayTitle =
  product.brand &&
  product.title.toLowerCase().startsWith(product.brand.toLowerCase() + " ")
    ? product.title.slice(product.brand.length + 1)
    : product.title;
const selectedVariationForSEO =
  variantParam && product.variations
    ? product.variations.find(
        (v) => v.variationId === product.selectedVariationId,
      )
    : undefined;
const fullTitle = createSEOTitle(product, selectedVariationForSEO);
const unitDisplay = selectedVariation?.unit || product.unit || "";

// Extract active category from breadcrumbs for navigation highlighting
let activeCategory = "";
if (breadcrumbPath && breadcrumbPath.items.length > 1) {
  // Find the first category in breadcrumbs (after Home)
  const categoryItem = breadcrumbPath.items.find(
    (item, index) => index > 0 && item.url.startsWith("/category/"),
  );
  if (categoryItem) {
    // Extract the category slug from the URL
    const match = categoryItem.url.match(/^\/category\/([^\/]+)/);
    if (match) {
      activeCategory = match[1];
    }
  }
}

// Determine if a size guide should be shown (apparel only)
type SizeGuideCategory = "tops" | "bottoms" | null;
let sizeGuideCategory: SizeGuideCategory = null;
if (breadcrumbPath) {
  const slugs = breadcrumbPath.items.map((i) => i.url);
  if (slugs.some((s) => s.includes("bottoms") || s.includes("pants"))) {
    sizeGuideCategory = "bottoms";
  } else if (
    slugs.some(
      (s) =>
        s.includes("tees") ||
        s.includes("tops") ||
        s.includes("apparel") ||
        s.includes("hoodies") ||
        s.includes("sweatshirts") ||
        s.includes("jackets"),
    )
  ) {
    sizeGuideCategory = "tops";
  }
}

// Generate optimized image sources using EnhancedImageOptimizer
const imageSet = product.image
  ? EnhancedImageOptimizer.generateOptimizedSources(product.image, {
      width: 800,
      height: 800,
      quality: 85,
      priority: true,
    })
  : null;

// Set response caching headers for performance optimization
// Browser: Cache for 1 minute, then revalidate
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, must-revalidate",
);

// Netlify CDN: Serve fresh for 5 minutes, then serve stale for 1 hour while revalidating
// durable directive shares cache globally across all edge nodes
Astro.response.headers.set(
  "Netlify-CDN-Cache-Control",
  "public, max-age=0, s-maxage=300, stale-while-revalidate=3600, durable", //cSpell:ignore maxage
);

// Add cache tag for per-product invalidation via webhooks
Astro.response.headers.set(
  "Netlify-Cache-Tag",
  `product-${product.id},products`,
);

// Vary header for cookie-based personalization (if needed in future)
Astro.response.headers.set("Netlify-Vary", "cookie");
---

<Layout
  title={fullTitle}
  structuredData={productSchema}
  activeCategory={activeCategory}
>
  <!-- Open Graph Tags -->
  <meta property="og:title" content={ogData.title} slot="head" />
  <meta property="og:description" content={ogData.description} slot="head" />
  <meta property="og:image" content={ogData.image} slot="head" />
  <meta property="og:url" content={ogData.url} slot="head" />
  <meta property="og:type" content={ogData.type} slot="head" />
  <meta property="og:site_name" content={ogData.siteName} slot="head" />
  <meta property="product:price:amount" content={ogData.price} slot="head" />
  <meta
    property="product:price:currency"
    content={ogData.currency}
    slot="head"
  />
  <meta
    property="product:availability"
    content={ogData.availability}
    slot="head"
  />

  <!-- Twitter Card Tags -->
  <meta name="twitter:card" content={twitterData.card} slot="head" />
  <meta name="twitter:title" content={twitterData.title} slot="head" />
  <meta
    name="twitter:description"
    content={twitterData.description}
    slot="head"
  />
  <meta name="twitter:image" content={twitterData.image} slot="head" />

  <!-- Preload LCP image for faster loading -->
  {
    imageSet && (
      <link
        rel="preload"
        as="image"
        imagesrcset={EnhancedImageOptimizer.generateResponsiveSrcSet(
          product.image,
          imageSet.avif ? "avif" : imageSet.webp ? "webp" : "jpeg",
          { width: 800, height: 800, quality: 85 },
        )}
        imagesizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 800px"
        type={
          imageSet.avif
            ? "image/avif"
            : imageSet.webp
              ? "image/webp"
              : "image/jpeg"
        }
        fetchpriority="high"
        slot="head"
      />
    )
  }

  <section class="p-4 sm:p-6 lg:p-8 relative">
    <div
      class="lg:grid lg:grid-cols-2 lg:gap-x-8 xl:gap-x-12 2xl:gap-x-16 items-start"
    >
      <!-- Product Image (+ thumbnail gallery when multiple images exist) -->
      <div class="flex flex-col gap-3">
        <div
          id="product-image-container"
          class="aspect-square md:aspect-video lg:aspect-square border-4 border-(--border-primary) overflow-hidden bg-(--surface-secondary) relative"
        >
          <!-- Loading placeholder with logo -->
          <div
            class="loading-skeleton loading-image absolute inset-0 w-full h-full"
            id="pdp-image-placeholder"
            aria-hidden="true"
          >
            <!-- El Camino logo using data URI -->
            <div
              class="absolute inset-0 flex items-center justify-center"
              style={`background-image: url('${EL_CAMINO_LOADER_DATA_URI}'); background-size: auto; background-position: center; background-repeat: no-repeat; opacity: 0.7;`}
            >
            </div>
          </div>

          {
            imageSet ? (
              <picture>
                {/* AVIF format (best compression) */}
                {imageSet.avif && (
                  <source
                    type="image/avif"
                    srcset={EnhancedImageOptimizer.generateResponsiveSrcSet(
                      product.image,
                      "avif",
                      {
                        width: 800,
                        height: 800,
                        quality: 85,
                      },
                    )}
                    sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 800px"
                  />
                )}

                {/* WebP format (good compression) */}
                {imageSet.webp && (
                  <source
                    type="image/webp"
                    srcset={EnhancedImageOptimizer.generateResponsiveSrcSet(
                      product.image,
                      "webp",
                      {
                        width: 800,
                        height: 800,
                        quality: 85,
                      },
                    )}
                    sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 800px"
                  />
                )}

                {/* JPEG fallback */}
                <img
                  id="product-image"
                  src={imageSet.jpeg}
                  srcset={EnhancedImageOptimizer.generateResponsiveSrcSet(
                    product.image,
                    "jpeg",
                    {
                      width: 800,
                      height: 800,
                      quality: 85,
                    },
                  )}
                  sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 800px"
                  alt={product.title}
                  class={`w-full h-full object-cover transition-opacity duration-300 ${!selectedVariationInStock ? "opacity-75" : "opacity-100"}`}
                  width="800"
                  height="800"
                  loading="eager"
                  fetchpriority="high"
                  decoding="sync"
                  data-placeholder-id="pdp-image-placeholder"
                  onload="document.getElementById('pdp-image-placeholder')?.remove()"
                  onerror={`this.src='${EL_CAMINO_LOGO_DATA_URI}'; document.getElementById('pdp-image-placeholder')?.remove()`}
                  role="img"
                  aria-label={product.title || "Product image"}
                />
              </picture>
            ) : (
              <img
                id="product-image"
                src={EL_CAMINO_LOGO_DATA_URI}
                alt={product.title}
                class={`w-full h-full object-contain opacity-100 ${!selectedVariationInStock ? "opacity-75" : ""}`}
                width="800"
                height="800"
                loading="eager"
                role="img"
                aria-label={product.title || "Product image"}
              />
            )
          }

          <!-- Initial overlay (updated by JavaScript on variation change) -->
          {
            !selectedVariationInStock ? (
              <div
                data-overlay="stock"
                class="absolute top-0 left-0 bg-state-error-surface text-state-error-text px-3 py-2 text-base font-bold rounded-br-sm"
              >
                Sold Out
              </div>
            ) : isOnSale && saleInfo ? (
              <div
                data-overlay="sale"
                class="absolute top-0 left-0 bg-state-success-surface text-state-success-text px-3 py-2 text-base font-bold rounded-br-sm"
              >
                {saleInfo.discountPercent}% Off
              </div>
            ) : null
          }
        </div>

        <!-- Thumbnail strip — always rendered; JS updates it on variant change -->
        <div
          id="gallery-thumbnails"
          class:list={[
            "flex gap-2 overflow-x-auto pb-1",
            !selectedVariation?.images || selectedVariation.images.length <= 1
              ? "hidden"
              : "",
          ]}
          role="list"
          aria-label="Product images"
        >
          {
            selectedVariation?.images &&
              selectedVariation.images.length > 1 &&
              selectedVariation.images.map((imgUrl, i) => (
                <button
                  type="button"
                  role="listitem"
                  class:list={[
                    "gallery-thumb shrink-0 w-16 h-16 border-2 overflow-hidden bg-(--surface-secondary) transition-all",
                    i === 0
                      ? "border-(--ui-button-border) opacity-100"
                      : "border-(--border-secondary) opacity-60 hover:opacity-100 hover:border-(--border-primary)",
                  ]}
                  data-gallery-src={imgUrl}
                  aria-label={`View image ${i + 1}`}
                  aria-pressed={i === 0 ? "true" : "false"}
                >
                  <img
                    src={imgUrl}
                    alt={`${product.title} — image ${i + 1}`}
                    class="w-full h-full object-cover"
                    loading={i < 3 ? "eager" : "lazy"}
                    width="64"
                    height="64"
                  />
                </button>
              ))
          }
        </div>
      </div><!-- end gallery wrapper -->

      <!-- Product Info -->
      <div class="product-info mt-4 max-w-xl">
        {breadcrumbPath && <Breadcrumbs breadcrumbPath={breadcrumbPath} />}
        <h1
          class="flex flex-col font-display font-bold text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl leading-[0.8] text-(--content-heading) text-balance mt-4 lg:mt-8"
        >
          <!-- Brand display -->
          {
            product.brand && (
              <span class="text-xl font-bold uppercase">{product.brand}</span>
            )
          }
          {displayTitle}
        </h1>

        <!-- Price Display -->
        <div class="mb-6">
          {/* Original price strikethrough when on sale */}
          <div
            id="original-price-display"
            class:list={[
              "text-lg text-(--content-meta) line-through",
              !isOnSale || !formattedOriginalPrice ? "hidden" : "",
            ]}
          >
            {formattedOriginalPrice || ""}
          </div>
          {/* Sale/Regular price */}
          <p
            id="price-display"
            class="text-4xl lg:text-5xl xl:text-6xl font-display font-bold text-(--content-emphasis)"
          >
            {formattedPrice}
            {/* Unit display */}
            {
              unitDisplay && (
                <span class="text-xl" id="unit-display">
                  {unitDisplay}
                </span>
              )
            }
          </p>
          <small class="italic text-(--content-emphasis)"
            >Shipping &amp; taxes are calculated at checkout</small
          >
        </div>

        <!-- Dynamic Attribute Selectors -->
        {
          hasMultipleVariations &&
            attributeTypes.map((attributeType) => {
              const attributeValues = availableAttributes[attributeType];
              const displayName = getAttributeDisplayName(attributeType);
              const isSingleValue = attributeValues?.length === 1;

              return (
                <div class="mt-6">
                  <div class="flex items-center mb-1">
                    <span class="text-sm font-medium">{displayName}</span>
                    {sizeGuideCategory && attributeType === "size" && (
                      <SizeGuide category={sizeGuideCategory} />
                    )}
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {isSingleValue
                      ? attributeValues.map((value) => (
                          <span
                            class="px-2.5 py-1.5 border rounded-sm bg-(--ui-variant-selected-surface) text-(--ui-variant-selected-text) border-(--ui-variant-selected-border) cursor-default"
                            aria-label={`${displayName}: ${value}`}
                          >
                            {value}
                          </span>
                        ))
                      : attributeValues.map((value) => {
                          const isAvailable = variations.some((variation) => {
                            if (!variation.attributes || !variation.inStock)
                              return false;
                            return (
                              variation.attributes[attributeType] === value
                            );
                          });
                          const isSelected =
                            selectedVariation?.attributes?.[attributeType] ===
                            value;

                          return (
                            <button
                              type="button"
                              data-attribute-type={attributeType}
                              data-attribute-value={value}
                              class:list={[
                                "px-2.5 py-1.5 rounded-sm attribute-button cursor-pointer relative",
                                isSelected
                                  ? "border border-(--ui-variant-selected-border) bg-(--ui-variant-selected-surface) text-(--ui-variant-selected-text)"
                                  : "border border-(--ui-input-border)/50 bg-(--ui-input-surface) text-(--ui-input-text)",
                                !isAvailable &&
                                  "opacity-40 line-through cursor-not-allowed",
                              ]}
                              disabled={!isAvailable}
                              title={!isAvailable ? "Out of stock" : undefined}
                              aria-label={
                                !isAvailable ? `${value} — out of stock` : value
                              }
                            >
                              {value}
                            </button>
                          );
                        })}
                  </div>
                </div>
              );
            })
        }

        <!-- Single attribute display (rendered as a selected, non-interactive button for visual consistency) -->
        {
          !hasMultipleVariations &&
            attributeTypes.length > 0 &&
            attributeTypes.map((attributeType) => {
              const attributeValues = availableAttributes[attributeType];
              const displayName = getAttributeDisplayName(attributeType);

              return (
                <div class="mt-6">
                  <div class="flex items-center mb-1">
                    <span class="text-sm font-medium">{displayName}</span>
                    {sizeGuideCategory && attributeType === "size" && (
                      <SizeGuide category={sizeGuideCategory} />
                    )}
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {attributeValues.map((value) => (
                      <span
                        class="px-2.5 py-1.5 border rounded-sm bg-(--ui-variant-selected-surface) text-(--ui-variant-selected-text) border-(--ui-variant-selected-border) cursor-default"
                        aria-label={`${displayName}: ${value}`}
                      >
                        {value}
                      </span>
                    ))}
                  </div>
                </div>
              );
            })
        }

        <!-- Single-variation name display: shown when the parser suppressed attribute parsing
             (no commas in name) but the name is still meaningful — i.e. it differs from
             the product title so we're not showing "Option: Thrasher Thorns T Shirt". -->
        {
          !hasMultipleVariations &&
            attributeTypes.length === 0 &&
            variations.length > 0 &&
            variations[0].name !== product.title &&
            variations[0].name?.trim() && (
              <div class="mt-6">
                <div class="flex items-center mb-1">
                  <span class="text-sm font-medium">Option</span>
                </div>
                <div class="flex flex-wrap gap-2">
                  <span
                    class="px-2.5 py-1.5 border rounded-sm bg-(--ui-variant-selected-surface) text-(--ui-variant-selected-text) border-(--ui-variant-selected-border) cursor-default"
                    aria-label={`Option: ${variations[0].name}`}
                  >
                    {variations[0].name}
                  </span>
                </div>
              </div>
            )
        }

        <!-- Fallback: Standard Variation Selection (for variations that don't have structured attributes) -->
        {
          hasMultipleVariations && attributeTypes.length === 0 && (
            <div class="mt-6">
              <h3 class="text-sm font-medium text-(--content-heading) mb-2">
                Options
              </h3>
              <div id="variation-buttons" class="flex flex-wrap gap-2">
                {variations.map((variation) => (
                  <button
                    type="button"
                    data-variation-id={variation.variationId}
                    data-price={variation.price}
                    data-name={variation.name}
                    data-quantity={variation.quantity}
                    data-in-stock={variation.inStock ? "true" : "false"}
                    data-image={variation.image || ""}
                    data-unit={variation.unit || ""}
                    class:list={[
                      "px-4 py-2 border rounded-sm cursor-pointer",
                      variation.variationId === defaultVariationId
                        ? "bg-(--ui-variant-selected-surface) text-(--ui-variant-selected-text) border-(--ui-variant-selected-border)"
                        : "bg-(--ui-input-surface) text-(--ui-input-text) border-(--ui-input-border)/50",
                      !variation.inStock && "opacity-75",
                    ]}
                    disabled={!variation.inStock}
                  >
                    {variation.name}
                  </button>
                ))}
              </div>
            </div>
          )
        }

        <!-- Quantity Input — only shown when more than 1 unit is available (or gift card) -->
        {
          selectedVariationInStock && (
            <div class="mt-6">
              <div class="flex flex-col space-y-2 items-start">
                <div
                  id="quantity-stepper"
                  class:list={[
                    !isGiftCard && selectedVariationQuantity <= 1
                      ? "hidden"
                      : "",
                  ]}
                >
                  <label
                    for="quantity-input"
                    class="text-sm font-medium mb-2 block"
                  >
                    Quantity
                  </label>
                  <div class="flex border border-(--ui-input-border)/50 rounded-sm overflow-hidden">
                    <button
                      type="button"
                      id="decrease-quantity"
                      class="w-10 h-10 flex items-center justify-center border-r border-(--ui-input-border)/50 bg-(--ui-input-surface) text-(--ui-input-text) disabled:cursor-not-allowed disabled:opacity-50 enabled:cursor-pointer"
                      disabled={true}
                    >
                      -
                    </button>
                    <input
                      type="number"
                      id="quantity-input"
                      min="1"
                      max={isGiftCard ? 10 : selectedVariationQuantity}
                      value="1"
                      class="w-14 h-10 text-center bg-(--surface-primary) text-(--ui-input-text) [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                    />
                    <button
                      type="button"
                      id="increase-quantity"
                      class="w-10 h-10 flex items-center justify-center border-l border-(--ui-input-border)/50 bg-(--ui-input-surface) text-(--ui-input-text) disabled:cursor-not-allowed disabled:opacity-50 enabled:cursor-pointer"
                      disabled={!isGiftCard && selectedVariationQuantity <= 1}
                    >
                      +
                    </button>
                  </div>
                </div>
                <div id="availability-indicator" class="text-sm">
                  {!isGiftCard && (
                    <span class="text-(--content-meta)" id="remaining-count">
                      {selectedVariationQuantity} available
                    </span>
                  )}
                  <span id="cart-quantity" class="ml-1 hidden">
                    ( 0 in cart )
                  </span>
                </div>
              </div>
            </div>
          )
        }

        <!-- Hidden data for JavaScript -->
        <input
          type="hidden"
          id="variation-data"
          value={JSON.stringify({
            variations: variations,
            availableAttributes: availableAttributes,
            selectedVariationId: defaultVariationId,
            productId: product.id,
          })}
        />

        <!-- Enhanced Add to Cart Button with Loading States -->
        <div class="mt-4">
          <Button
            type="button"
            variant="primary"
            size="lg"
            classes="w-full md:w-auto"
            loading={false}
            loadingText="Adding to Cart..."
            data-product={JSON.stringify({
              id: product.id,
              catalogObjectId: product.catalogObjectId,
              variationId: defaultVariationId,
              title: product.title,
              price: selectedVariation?.price || product.price,
              image: product.image,
              unit: unitDisplay,
              variationName: selectedVariation?.name || "",
              saleInfo: selectedVariation?.saleInfo || undefined,
              isGiftCard: isGiftCard || undefined,
            })}
            id="add-to-cart-button"
            disabled={!selectedVariationInStock}
          >
            {selectedVariationInStock ? "Add to Cart" : "Sold Out"}
          </Button>
        </div>

        <!-- Back-in-Stock capture — always in DOM so JS can show/hide on variant switch -->
        <BackInStock
          productId={product.id}
          variationId={defaultVariationId}
          productTitle={displayTitle}
          variationName={selectedVariation?.name}
          hidden={selectedVariationInStock}
        />

        <!-- Product Description -->
        {
          product.description && (
            <div class="my-6 max-w-[52ch]">
              <p class="text-base text-(--content-body) text-pretty max-w-[44ch]">
                {product.description}
              </p>
            </div>
          )
        }

        <!-- Trust Signals -->
        <div class="mt-8 border-t border-(--border-secondary)">
          <p
            class="text-xs uppercase tracking-widest text-(--content-meta) my-2.5"
          >
            Why shop with El Camino?
          </p>
          <div
            class="flex flex-wrap gap-x-5 gap-y-1.5 text-sm text-(--content-meta)"
          >
            <button
              type="button"
              id="easy-returns-trigger"
              class="flex items-center gap-1.5 text-(--content-emphasis) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all cursor-pointer"
              aria-label="View return policy"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><polyline points="23 4 23 10 17 10"></polyline><polyline
                  points="1 20 1 14 7 14"></polyline><path
                  d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"
                ></path></svg
              >
              Easy returns
            </button>
            <button
              id="local-pickup-trigger"
              type="button"
              class="flex items-center gap-1.5 text-(--content-emphasis) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all cursor-pointer"
              aria-label="View store location and hours"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                ></path><circle cx="12" cy="10" r="3"></circle></svg
              >
              Local pickup available
            </button>
            <button
              type="button"
              id="secure-checkout-trigger"
              class="flex items-center gap-1.5 text-(--content-emphasis) hover:text-(--content-emphasis) hover:underline underline-offset-0 hover:underline-offset-4 transition-all cursor-pointer"
              aria-label="Learn about our secure checkout"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path></svg
              >
              Secure checkout
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products Section -->
  {
    relatedProducts.length > 0 && (
      <div class="px-4 sm:px-6 lg:px-8">
        <RelatedProducts
          products={relatedProducts}
          title={
            product.brand ? `More from ${product.brand}` : "You Might Also Like"
          }
        />
      </div>
    )
  }

  <!-- Recently Viewed Section -->
  <div class="px-4 sm:px-6 lg:px-8">
    <RecentlyViewed currentProductId={product.id} />
  </div>

  <!-- Sticky mobile ATC bar — hidden on lg+ screens -->
  <div
    id="sticky-atc-bar"
    class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-(--surface-primary) border-t-2 border-(--border-primary) p-3 flex items-center gap-3 translate-y-full transition-transform duration-300 shadow-lg"
    aria-hidden="true"
  >
    <div class="flex-1 min-w-0">
      <p class="text-sm text-(--content-meta) truncate">
        {product.brand ?? ""}
      </p>
      <p class="text-base font-semibold text-(--content-heading) truncate">
        {displayTitle}
      </p>
      <p
        id="sticky-price"
        class="text-xl font-display font-bold text-(--content-emphasis)"
      >
        {formattedPrice}
      </p>
    </div>
    <button
      type="button"
      id="sticky-atc-button"
      class="shrink-0 px-5 h-11 font-sans font-semibold text-sm rounded-sm bg-(--ui-button-surface) text-(--ui-button-text) border-2 border-(--ui-button-border) enabled:cursor-pointer enabled:hover:bg-(--ui-button-surface)/70 disabled:opacity-50 disabled:cursor-not-allowed disabled:data-[loading=true]:opacity-75 transition-opacity"
      disabled={!selectedVariationInStock}
    >
      {selectedVariationInStock ? "Add to Cart" : "Sold Out"}
    </button>
  </div>

  <Modal />
</Layout>

<script>
  import { PDPController } from "@/lib/product/pdpController";
  import { processClientError, logError } from "@/lib/square/errorUtils";
  import { recentlyViewed } from "@/lib/product/recentlyViewed";
  import type { Product } from "@/lib/square/types";

  let pdpController: PDPController | null = null;

  /**
   * Initialize controller from DOM data - with resilient error handling
   */
  function initializePDP(): boolean {
    const dataInput = document.getElementById(
      "variation-data",
    ) as HTMLInputElement;
    if (!dataInput?.value) return false;

    // Clean up existing controller to prevent double event binding
    if (pdpController) {
      pdpController.cleanup();
      pdpController = null;
    }

    try {
      const productData = JSON.parse(dataInput.value);

      // Check if we have the minimum required elements for PDP controller
      const hasAttributeButtons =
        document.querySelectorAll(".attribute-button").length > 0;
      const hasVariationButtons =
        document.querySelectorAll("[data-variation-id]").length > 0;
      const hasQuantityControls =
        document.getElementById("quantity-input") !== null;

      // Only initialize PDP controller if we have interactive elements that need it
      if (hasAttributeButtons || hasVariationButtons || hasQuantityControls) {
        pdpController = new PDPController(productData);
        return true;
      } else {
        return true; // No interactive elements, not an error
      }
    } catch (error) {
      const appError = processClientError(error, "initializePDP");
      logError(appError);
      return true; // Don't fail the whole page for this
    }
  }

  function setupGallery(): void {
    const container = document.getElementById("gallery-thumbnails");
    if (!container) return;

    // Use event delegation so this handler works even after JS rebuilds the thumbs
    if (container.dataset.galleryReady) return; // only attach once per page load
    container.dataset.galleryReady = "true";

    container.addEventListener("click", (e) => {
      const thumb = (e.target as Element).closest<HTMLButtonElement>(
        ".gallery-thumb",
      );
      if (!thumb) return;

      const src = thumb.dataset.gallerySrc;
      const mainImage = document.getElementById(
        "product-image",
      ) as HTMLImageElement | null;
      if (!src || !mainImage) return;

      // Update active thumb styles
      container
        .querySelectorAll<HTMLButtonElement>(".gallery-thumb")
        .forEach((t) => {
          t.classList.remove("border-(--ui-button-border)", "opacity-100");
          t.classList.add("border-(--border-secondary)", "opacity-60");
          t.setAttribute("aria-pressed", "false");
        });
      thumb.classList.add("border-(--ui-button-border)", "opacity-100");
      thumb.classList.remove("border-(--border-secondary)", "opacity-60");
      thumb.setAttribute("aria-pressed", "true");

      // Crossfade the main image
      mainImage.classList.remove("opacity-100");
      mainImage.classList.add("opacity-0");
      // Clear srcset so <picture> source tags don't override the new src
      mainImage.removeAttribute("srcset");
      mainImage.src = src;
      // Handle cached images where onload won't fire
      if (mainImage.complete && mainImage.naturalWidth > 0) {
        mainImage.classList.remove("opacity-0");
        mainImage.classList.add("opacity-100");
      } else {
        mainImage.onload = () => {
          mainImage.classList.remove("opacity-0");
          mainImage.classList.add("opacity-100");
        };
        mainImage.onerror = () => {
          mainImage.classList.remove("opacity-0");
          mainImage.classList.add("opacity-100");
        };
      }
    });
  }

  function setupStickyATC(): void {
    const stickyBar = document.getElementById("sticky-atc-bar");
    const rawStickyBtn = document.getElementById(
      "sticky-atc-button",
    ) as HTMLButtonElement | null;
    const mainBtn = document.getElementById(
      "add-to-cart-button",
    ) as HTMLButtonElement | null;

    if (!stickyBar || !mainBtn || !rawStickyBtn) return;

    // Clone to remove any listeners from a prior initialization.
    // initializePage() runs twice on first load (DOMContentLoaded + astro:page-load),
    // so without this clone each call would stack another click listener on the same
    // element, causing two cart.addItem() calls per tap and "max quantity" errors.
    const stickyBtn = rawStickyBtn.cloneNode(true) as HTMLButtonElement;
    rawStickyBtn.parentNode!.replaceChild(stickyBtn, rawStickyBtn);

    // Track both visibility states so the sticky hides when either is true
    let mainBtnVisible = false;
    let footerVisible = false;
    const updateStickyVisibility = () => {
      const hide = mainBtnVisible || footerVisible;
      stickyBar.classList.toggle("translate-y-full", hide);
      stickyBar.setAttribute("aria-hidden", hide ? "true" : "false");
    };

    // Hide when the main ATC button is in view
    const mainBtnObserver = new IntersectionObserver(
      ([entry]) => {
        mainBtnVisible = entry.isIntersecting;
        updateStickyVisibility();
      },
      { threshold: 0.5 },
    );
    mainBtnObserver.observe(mainBtn);

    // Also hide when the footer enters view so it never covers footer links
    const footer = document.querySelector("footer");
    if (footer) {
      const footerObserver = new IntersectionObserver(
        ([entry]) => {
          footerVisible = entry.isIntersecting;
          updateStickyVisibility();
        },
        { threshold: 0 },
      );
      footerObserver.observe(footer);
    }

    // Proxy clicks from sticky button to main ATC button
    stickyBtn.addEventListener("click", () => {
      mainBtn.click();
    });

    // Keep sticky button state in sync with main button.
    // CSS pseudo-classes in the sticky button's class list handle opacity/cursor
    // automatically from the disabled attribute and data-loading attribute alone —
    // no manual class mirroring needed.
    const syncStickyState = () => {
      if (!stickyBtn || !mainBtn) return;
      stickyBtn.disabled = mainBtn.disabled;
      // Sync innerHTML so the loading spinner is visible during cart add
      stickyBtn.innerHTML = mainBtn.innerHTML;
      // Sync data-loading so CSS drives the correct opacity (75% loading, 50% disabled)
      const loading = mainBtn.getAttribute("data-loading");
      if (loading) stickyBtn.setAttribute("data-loading", loading);
      else stickyBtn.removeAttribute("data-loading");
      // Sync price (handles variant switches and sale price changes)
      const priceEl = document.getElementById("sticky-price");
      const mainPrice = document.getElementById("price-display");
      if (priceEl && mainPrice) priceEl.textContent = mainPrice.textContent;
    };

    // Run immediately so sticky reflects any state PDPController already applied
    // (e.g. "All in Cart" if items are already in cart on page load)
    syncStickyState();

    // Observe main button for text/disabled/class/children changes
    const mutationObs = new MutationObserver(syncStickyState);
    mutationObs.observe(mainBtn, {
      attributes: true,
      childList: true,
      subtree: true,
      characterData: true,
    });

    // Also observe price-display so sticky price stays in sync on variant switches
    // even when the button text itself doesn't change (e.g. "Add to Cart" → "Add to Cart")
    const priceDisplay = document.getElementById("price-display");
    if (priceDisplay) {
      mutationObs.observe(priceDisplay, {
        childList: true,
        characterData: true,
        subtree: true,
      });
    }
  }

  function setupPolicyTriggers(): void {
    // Easy returns → return policy modal
    const returnsTrigger = document.getElementById("easy-returns-trigger");
    if (
      returnsTrigger &&
      returnsTrigger.getAttribute("data-modal-initialized") !== "true"
    ) {
      returnsTrigger.setAttribute("data-modal-initialized", "true");
      returnsTrigger.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const open = () => window.showPolicyModal?.("return-policy");
        if (typeof window.showPolicyModal === "function") open();
        else setTimeout(open, 100);
      });
    }

    // Secure checkout → security assurance modal
    const secureTrigger = document.getElementById("secure-checkout-trigger");
    if (
      secureTrigger &&
      secureTrigger.getAttribute("data-modal-initialized") !== "true"
    ) {
      secureTrigger.setAttribute("data-modal-initialized", "true");
      secureTrigger.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const open = () => window.showSecureCheckoutModal?.();
        if (typeof window.showSecureCheckoutModal === "function") open();
        else setTimeout(open, 100);
      });
    }
  }

  function setupLocationModal(): void {
    const triggerIds = ["location-hours-link", "local-pickup-trigger"];
    triggerIds.forEach((triggerId) => {
      const trigger = document.getElementById(triggerId);
      if (!trigger) return;
      if (trigger.getAttribute("data-modal-initialized") === "true") return;
      trigger.setAttribute("data-modal-initialized", "true");
      trigger.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (typeof window.showLocationModal === "function") {
          window.showLocationModal();
        } else {
          setTimeout(() => {
            if (typeof window.showLocationModal === "function") {
              window.showLocationModal();
            }
          }, 100);
        }
      });
    });
  }

  function initializePage() {
    const variationDataElement = document.getElementById("variation-data");
    const isProductPage = variationDataElement !== null;

    if (isProductPage) {
      // Track recently viewed product
      try {
        const productButton = document.getElementById("add-to-cart-button");
        if (productButton) {
          const productDataStr = productButton.getAttribute("data-product");
          if (productDataStr) {
            const productData = JSON.parse(productDataStr);
            const productImage =
              (document.getElementById("product-image") as HTMLImageElement)
                ?.src || "";
            const productBrand =
              document
                .querySelector(".product-info h1 span.uppercase")
                ?.textContent?.trim() || undefined;

            const product: Product = {
              id: productData.id,
              catalogObjectId: productData.catalogObjectId,
              variationId: productData.variationId,
              title: productData.title,
              image: productImage,
              price: productData.price,
              url: window.location.pathname,
              brand: productBrand,
              unit: productData.unit,
              isGiftCard: productData.isGiftCard || undefined,
            };

            recentlyViewed.add(product);
          }
        }
      } catch (error) {
        console.error("Failed to track recently viewed:", error);
      }

      if (!initializePDP()) {
        console.error("Failed to initialize PDP controller");
      }

      setupLocationModal();
      setupPolicyTriggers();
      setupStickyATC();
      setupGallery();
    }
  }

  // Run on DOM ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePage);
  } else {
    initializePage();
  }

  // Also handle view transitions when re-enabled
  document.addEventListener("astro:page-load", initializePage);

  /**
   * ✅ ASTRO VIEW TRANSITIONS: Clean up on navigation
   */
  document.addEventListener("astro:after-swap", () => {
    pdpController?.cleanup();
    pdpController = null;
  });
</script>
