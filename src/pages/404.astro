---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="404 — Bailed | El Camino">
  <section
    class="relative min-h-[70vh] flex flex-col justify-center overflow-hidden p-4 sm:p-8 lg:p-12"
  >
    <!-- Ghost 404 watermark -->
    <span
      aria-hidden="true"
      class="absolute top-0 left-0 font-display font-black leading-[0.85] text-(--content-heading) opacity-[0.04] select-none pointer-events-none text-[clamp(10rem,40vw,32rem)]"
    >
      404
    </span>

    <!-- Main content -->
    <div class="relative z-10 max-w-xl">
      <h1
        class="font-display font-black text-6xl lg:text-7xl xl:text-8xl 2xl:text-9xl leading-[0.85] text-(--content-heading) mb-6"
      >
        Bailed
      </h1>

      <p class="text-lg text-(--content-body) mb-2 max-w-prose">
        That page took a slam — it might have been moved, renamed, or never even
        existed in the first place &hellip; but hey, you made it to the slam
        section!
      </p>
      <p class="text-(--content-meta) mb-10">
        Let's get you set up and back on the streets.
      </p>

      <nav aria-label="Find your way back" class="flex flex-wrap gap-3">
        <a
          href="/shop/all"
          class="px-6 py-3 bg-(--ui-button-surface) text-(--ui-button-text) font-semibold transition-opacity duration-200 hover:opacity-80"
        >
          Go Shopping
        </a>
        <a
          href="/shop/sale/"
          class="px-6 py-3 border border-(--border-primary) text-(--content-body) font-semibold hover:text-(--content-emphasis) transition-colors duration-200"
        >
          See What's On Sale
        </a>
      </nav>
    </div>
  </section>
</Layout>
