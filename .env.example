# Square Configuration — required
SQUARE_ACCESS_TOKEN=
PUBLIC_SQUARE_APP_ID=
PUBLIC_SQUARE_LOCATION_ID=
PUBLIC_SQUARE_ENVIRONMENT=sandbox

# Square webhook — required for real-time inventory/order events
# Get from: Square Developer Dashboard → your app → Webhooks → Signature key
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Square reliability tuning — optional
SQUARE_MAX_RETRIES=3
SQUARE_BASE_DELAY=500
SQUARE_CIRCUIT_THRESHOLD=5
# SQUARE_MAX_DELAY=5000          # max retry delay in ms
# SQUARE_JITTER_RANGE=0.1        # random jitter factor (fraction of delay)
# SQUARE_TIMEOUT_MS=10000        # per-request timeout in ms
# SQUARE_RECOVERY_TIMEOUT=30000  # circuit breaker reset timeout in ms
# SQUARE_MONITOR_WINDOW=60000    # circuit breaker monitoring window in ms

# Local dev server
HOST=0.0.0.0
PORT=1337

# Admin auth — required for /admin
# ADMIN_SECRET should be a long random string, e.g. `openssl rand -hex 32`
ADMIN_PASSWORD=
ADMIN_SECRET=

# Chrome UX Report (Core Web Vitals data) — optional
CRUX_API_KEY=

# Resend email — required for contact / back-in-stock notifications
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
TYLER_EMAIL=

# WordPress — optional; defaults to production API
# PUBLIC_WORDPRESS_API_URL=https://public-api.wordpress.com/rest/v1.1/sites/elcaminoskateshop.wordpress.com
